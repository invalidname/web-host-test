mentation\/Swift\/UnsafeMutableBufferPointer","doc:\/\/com.apple.Swift\/documentation\/Swift\/UnsafeMutablePointer","doc:\/\/com.apple.Swift\/documentation\/Swift\/UnsafeMutableRawBufferPointer","doc:\/\/com.apple.Swift\/documentation\/Swift\/UnsafeMutableRawPointer","doc:\/\/com.apple.Swift\/documentation\/Swift\/UnsafePointer","doc:\/\/com.apple.Swift\/documentation\/Swift\/UnsafeRawBufferPointer","doc:\/\/com.apple.Swift\/documentation\/Swift\/UnsafeRawPointer","doc:\/\/com.apple.Swift\/documentation\/Synchronization\/WordPair"],"type":"conformingTypes","title":"Conforming Types"}],"topicSections":[{"anchor":"Associated-Types","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Synchronization\/AtomicRepresentable\/AtomicRepresentation"],"title":"Associated Types"},{"anchor":"Type-Methods","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Synchronization\/AtomicRepresentable\/decodeAtomicRepresentation(_:)","doc:\/\/com.apple.Swift\/documentation\/Synchronization\/AtomicRepresentable\/encodeAtomicRepresentation(_:)"],"title":"Type Methods"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/synchronization\/atomicrepresentable"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"anchor":"Atomic-Values","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Synchronization\/Atomic","doc:\/\/com.apple.Swift\/documentation\/Synchronization\/AtomicLazyReference","doc:\/\/com.apple.Swift\/documentation\/Synchronization\/WordPair","doc:\/\/com.apple.Swift\/documentation\/Synchronization\/AtomicOptionalRepresentable"],"title":"Atomic Values"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AtomicRepresentable"}]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Types that conform to the "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" protocol can be used as the"},{"type":"text","text":" "},{"code":"Value","type":"codeVoice"},{"type":"text","text":" type parameter with the "},{"code":"Atomic","type":"codeVoice"},{"type":"text","text":" type. Conformances that utilize"},{"type":"text","text":" "},{"type":"text","text":"existing atomic storage representations as their own representation will get"},{"type":"text","text":" "},{"type":"text","text":"the primitive atomic operations available on "},{"code":"Atomic","type":"codeVoice"},{"type":"text","text":" for free. Such"},{"type":"text","text":" "},{"type":"text","text":"operations include "},{"code":"load","type":"codeVoice"},{"type":"text","text":", "},{"code":"store","type":"codeVoice"},{"type":"text","text":", "},{"code":"exchange","type":"codeVoice"},{"type":"text","text":", "},{"code":"compareExchange","type":"codeVoice"},{"type":"text","text":", and"},{"type":"text","text":" "},{"code":"weakCompareExchange","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Conforming to the AtomicRepresentable protocol","level":2,"anchor":"Conforming-to-the-AtomicRepresentable-protocol","type":"heading"},{"inlineContent":[{"type":"text","text":"Conforming your own custom types allow them to be used in the "},{"code":"Atomic","type":"codeVoice"},{"type":"text","text":" type"},{"type":"text","text":" "},{"type":"text","text":"and get access to all of the primitive atomic operations explained above."},{"type":"text","text":" "},{"type":"text","text":"There are two main ways to conform your type to "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Using a predefined "},{"type":"codeVoice","code":"RawRepresentable"},{"type":"text","text":" conformance"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Manually conforming to "},{"type":"codeVoice","code":"AtomicRepresentable"}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"If you custom type already conforms to "},{"code":"RawRepresentable","type":"codeVoice"},{"type":"text","text":", then adding the"},{"type":"text","text":" "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" conformance may be really simple! If the "},{"code":"RawValue","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"associated type of your type is already itself an "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"then all you need to do is add the conformance and you’re done!"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["enum TrafficLight: UInt8 {","  case red","  case yellow","  case green","}","","extension TrafficLight: AtomicRepresentable {}"]},{"inlineContent":[{"type":"text","text":"And that’s it! Here, we’re utilizing Swift’s automatic "},{"code":"RawRepresentable","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"conformance synthesis for enums by declaring our “raw value” to be a"},{"type":"text","text":" "},{"code":"UInt8","type":"codeVoice"},{"type":"text","text":". By adding the "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" conformance, we automatically"},{"type":"text","text":" "},{"type":"text","text":"figure out how to do the conformance from the "},{"code":"RawRepresentable","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"implementation and do all of the necessary work for you. However, it is still"},{"type":"text","text":" "},{"type":"text","text":"possible to customize this behavior using the manual method explained below."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Defining your own "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" conformance is pretty simple. All"},{"type":"text","text":" "},{"type":"text","text":"you have to do is decide what atomic storage representation fits best for"},{"type":"text","text":" "},{"type":"text","text":"your type, and create the bidirectional relationship between the two."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ A point in an x-y coordinate system.","struct GridPoint {","  var x: Int","  var y: Int","}","","extension GridPoint: AtomicRepresentable {","  typealias AtomicRepresentation = WordPair.AtomicRepresentation","","  static func encodeAtomicRepresentation(","    _ value: consuming GridPoint","  ) -> AtomicRepresentation {","    let wordPair = WordPair(","      first: UInt(bitPattern: value.x),","      second: UInt(bitPattern: value.y)","    )","","    return WordPair.encodeAtomicRepresentation(wordPair)","  }","","  static func decodeAtomicRepresentation(","    _ representation: consuming AtomicRepresentation","  ) -> GridPoint {","    let wordPair = WordPair.decodeAtomicRepresentation(representation)","","    return GridPoint(","      x: Int(bitPattern: wordPair.first),","      y: Int(bitPattern: wordPair.second)","    )","  }","}"]},{"inlineContent":[{"type":"text","text":"Here, we’re going to select "},{"code":"WordPair","type":"codeVoice"},{"type":"text","text":"’s atomic storage representation as"},{"type":"text","text":" "},{"type":"text","text":"our own. This is very important because we only get the atomic operations"},{"type":"text","text":" "},{"type":"text","text":"like "},{"code":"load","type":"codeVoice"},{"type":"text","text":" and "},{"code":"store","type":"codeVoice"},{"type":"text","text":" if our representation is one of the "},{"type":"emphasis","inlineContent":[{"text":"fundamental","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"storage representations. Luckily for us, "},{"code":"WordPair","type":"codeVoice"},{"type":"text","text":" does use one of these"},{"type":"text","text":" "},{"type":"text","text":"types as its storage type."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In addition to selecting what storage representation our type will use, we"},{"type":"text","text":" "},{"type":"text","text":"define two static functions that go from both our custom type to its"},{"type":"text","text":" "},{"type":"text","text":"representation and the representation back to our own type. Because our"},{"type":"text","text":" "},{"type":"text","text":"representation is the same as "},{"code":"WordPair.AtomicRepresentation","type":"codeVoice"},{"type":"text","text":", we will"},{"type":"text","text":" "},{"type":"text","text":"actually go through "},{"code":"WordPair","type":"codeVoice"},{"type":"text","text":"’s "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" conformance to help"},{"type":"text","text":" "},{"type":"text","text":"define our own."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This is all you need to do to conform your custom type to the"},{"type":"text","text":" "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" protocol. From here, you can use this type in all of"},{"type":"text","text":" "},{"type":"text","text":"the primitive atomic operations like shown below:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func atomicGridPoint(_ gridPoint: Atomic<GridPoint>) {","  let newGridPoint = GridPoint(x: 123, y: -456)","","  let oldGridPoint1 = gridPoint.load(ordering: .relaxed)","","  gridPoint.store(newGridPoint, ordering: .releasing)","","  let oldGridPoint2 = gridPoint.exchange(","    desired: oldGridPoint1,","    ordering: .acquiringAndReleasing","  )","","  let (exchanged1, oldGridPoint2) = gridPoint.compareExchange(","    expected: oldGridPoint1,","    desired: newGridPoint,","    ordering: .sequentiallyConsistent","  )","","  let (exchanged2, oldGridPoint3) = gridPoint.weakCompareExchange(","    expected: newGridPoint,","    desired: oldGridPoint2,","    ordering: .relaxed","  )","}"]},{"text":"List of Fundamental Atomic Representations","level":2,"anchor":"List-of-Fundamental-Atomic-Representations","type":"heading"},{"inlineContent":[{"type":"text","text":"When defining your own "},{"code":"AtomicRepresentable","type":"codeVoice"},{"type":"text","text":" conformance, it is critical"},{"type":"text","text":" "},{"type":"text","text":"that your custom type should choose from the following list of types as its"},{"type":"text","text":" "},{"type":"text","text":"own "},{"code":"AtomicRepresentation","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"UInt8.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UInt16.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UInt32.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UInt64.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UInt.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int8.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int16.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int32.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int64.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int.AtomicRepresentation"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"WordPair.AtomicRepresentation"}],"type":"paragraph"}]}]},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"Int8.AtomicRepresentation","type":"codeVoice"},{"text":" is the same type as","type":"text"},{"text":" ","type":"text"},{"code":"UInt8.AtomicRepresentation","type":"codeVoice"},{"text":" and the same is true for all of the same","type":"text"},{"text":" ","type":"text"},{"text":"sized integer types. If your type wraps an unsigned integer, you should","type":"text"},{"text":" ","type":"text"},{"text":"prefer to use an unsigned integer’s atomic representation instead of a","type":"text"},{"text":" ","type":"text"},{"text":"signed ones and vice versa. ","type":"text"},{"code":"Int","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"UInt","type":"codeVoice"},{"text":"’s representation will be","type":"text"},{"text":" ","type":"text"},{"text":"64 bits wide on 64 bit systems and 32 bit wide on 32 bit systems. ","type":"text"},{"code":"Int64","type":"codeVoice"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"code":"UInt64","type":"codeVoice"},{"text":" always conform to ","type":"text"},{"code":"AtomicRepresentable","type":"codeVoice"},{"text":" on 64 bit systems,","type":"text"},{"text":" ","type":"text"},{"text":"but on 32 bit systems they will only conform if the platform supports","type":"text"},{"text":" ","type":"text"},{"text":"double wide atomics. ","type":"text"},{"code":"WordPair","type":"codeVoice"},{"text":" will only conform to ","type":"text"},{"code":"AtomicRepresentable","type":"codeVoice"},{"text":" ","type":"text"},{"text":"on platforms that support double wide atomics, but if they do it will be","type":"text"},{"text":" ","type":"text"},{"text":"128 bits wide on 64 bit systems and 64 bits wide on 32 bit systems.","type":"text"}]}]}]}],"metadata":{"modules":[{"name":"Synchronization"}],"role":"symbol","platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"18.0","deprecated":false},{"unavailable":false,"beta"