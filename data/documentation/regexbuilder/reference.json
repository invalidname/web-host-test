Builder/TryCapture":{"url":"\/documentation\/regexbuilder\/trycapture","abstract":[{"type":"text","text":"A regex component that attempts to transform a matched substring, saving"},{"type":"text","text":" "},{"type":"text","text":"the result if successful and backtracking if the transformation fails."}],"title":"TryCapture","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/RegexBuilder\/TryCapture","navigatorTitle":[{"text":"TryCapture","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TryCapture","kind":"identifier"}],"type":"topic","role":"symbol"},"doc://com.apple.Swift/documentation/RegexBuilder/Reference/init(_:)":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/RegexBuilder\/Reference\/init(_:)","kind":"symbol","type":"topic","abstract":[{"text":"Creates a reference with the specified capture type.","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"text":"Capture","preciseIdentifier":"s:12RegexBuilder9ReferenceV7Capturexmfp","kind":"typeIdentifier"},{"text":".Type)","kind":"text"}],"url":"\/documentation\/regexbuilder\/reference\/init(_:)","title":"init(_:)"},"doc://com.apple.Swift/documentation/RegexBuilder":{"url":"\/documentation\/regexbuilder","abstract":[],"title":"RegexBuilder","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/RegexBuilder","type":"topic","role":"collection"},"doc://com.apple.Swift/documentation/Swift/RegexComponent":{"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RegexComponent","kind":"identifier"}],"url":"\/documentation\/swift\/regexcomponent","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/RegexComponent","navigatorTitle":[{"text":"RegexComponent","kind":"identifier"}],"type":"topic","title":"RegexComponent","kind":"symbol","abstract":[{"text":"A type that represents a regular expression.","type":"text"}]}}