{"seeAlsoSections":[{"generated":true,"anchor":"Remote-Calls","title":"Remote Calls","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/RemoteCallTarget","doc:\/\/com.apple.Swift\/documentation\/Distributed\/RemoteCallArgument","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationDecoder","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationResultHandler"]}],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Distributed"]]},"metadata":{"title":"DistributedTargetInvocationEncoder","externalID":"s:11Distributed0A23TargetInvocationEncoderP","modules":[{"name":"Distributed"}],"symbolKind":"protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedTargetInvocationEncoder","kind":"identifier"}],"roleHeading":"Protocol","navigatorTitle":[{"text":"DistributedTargetInvocationEncoder","kind":"identifier"}],"role":"symbol","platforms":[{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"iOS"},{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"iPadOS"},{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"Mac Catalyst"},{"introducedAt":"13.0","unavailable":false,"beta":false,"deprecated":false,"name":"macOS"},{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"tvOS"},{"introducedAt":"9.0","unavailable":false,"beta":false,"deprecated":false,"name":"watchOS"}]},"kind":"symbol","identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Used to encode an invocation of a distributed target (method or computed property).","type":"text"}],"topicSections":[{"generated":true,"anchor":"Associated-Types","title":"Associated Types","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder\/SerializationRequirement"]},{"generated":true,"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder\/doneRecording()","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder\/recordArgument(_:)","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder\/recordErrorType(_:)","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder\/recordGenericSubstitution(_:)","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder\/recordReturnType(_:)"]}],"relationshipsSections":[{"type":"conformingTypes","kind":"relationships","title":"Conforming Types","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/LocalTestingInvocationEncoder"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedTargetInvocationEncoder","kind":"identifier"},{"text":"<","kind":"text"},{"text":"SerializationRequirement","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder\/SerializationRequirement","preciseIdentifier":"s:11Distributed0A23TargetInvocationEncoderP24SerializationRequirementQa"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Forming an invocation","level":2,"anchor":"Forming-an-invocation","type":"heading"},{"inlineContent":[{"text":"On the sending-side an instance of an invocation is constructed by the runtime,","type":"text"},{"text":" ","type":"text"},{"text":"and calls to: ","type":"text"},{"type":"codeVoice","code":"recordGenericSubstitution"},{"text":", ","type":"text"},{"type":"codeVoice","code":"recordArgument"},{"text":", ","type":"text"},{"type":"codeVoice","code":"recordReturnType"},{"text":",","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"recordErrorType"},{"text":", and finally ","type":"text"},{"type":"codeVoice","code":"doneRecording"},{"text":" are made (in this order).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the return type of the target is ","type":"text"},{"type":"codeVoice","code":"Void"},{"text":" the ","type":"text"},{"type":"codeVoice","code":"recordReturnType"},{"text":" is not invoked.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the error type thrown by the target is not defined the ","type":"text"},{"type":"codeVoice","code":"recordErrorType"},{"text":" is not invoked.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"An invocation implementation may decide to perform serialization right-away in the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"record..."},{"text":" invocations, or it may choose to delay doing so until the invocation is passed","type":"text"},{"text":" ","type":"text"},{"text":"to the ","type":"text"},{"type":"codeVoice","code":"remoteCall"},{"text":". This decision largely depends on if serialization is allowed to happen","type":"text"},{"text":" ","type":"text"},{"text":"on the caller’s task, and if any smarter encoding can be used once all parameter calls have been","type":"text"},{"text":" ","type":"text"},{"text":"recorded (e.g. it may be possible to run-length encode values of certain types etc.)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Once encoded, the system should use some underlying transport mechanism to send the","type":"text"},{"text":" ","type":"text"},{"text":"bytes serialized by the invocation to the remote peer.","type":"text"}],"type":"paragraph"},{"text":"Decoding an invocation","level":2,"anchor":"Decoding-an-invocation","type":"heading"},{"inlineContent":[{"text":"Since every actor system is going to deal with a concrete invocation type, they may","type":"text"},{"text":" ","type":"text"},{"text":"implement decoding them whichever way is most optimal for the given system.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Once decided, the invocation must be passed to ","type":"text"},{"type":"codeVoice","code":"executeDistributedTarget"},{"text":" ","type":"text"},{"text":"which will decode the substitutions, argument values, return and error types (in that order).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Note that the decoding will be provided the specific types that the sending side used to preform the call,","type":"text"},{"text":" ","type":"text"},{"text":"so decoding can rely on simply invoking e.g. ","type":"text"},{"type":"codeVoice","code":"Codable"},{"text":" (if that is the ","type":"text"},{"type":"codeVoice","code":"SerializationRequirement"},{"text":") decoding","type":"text"},{"text":" ","type":"text"},{"text":"entry points on the provided types.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/distributed\/distributedtargetinvocationencoder"]}],"references":{"doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationEncoder":{"role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedTargetInvocationEncoder","kind":"identifier"}],"url":"\/documentation\/distributed\/distributedtargetinvocationencoder","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedTargetInvocationEncoder","navigatorTitle":[{"text":"DistributedTargetInvocationEncoder","kind":"identifier"}],"type":"topic","title":"DistributedTargetInvocationEncoder","kind":"symbol","abstract":[{"type":"text","text":"Used to encode an invocation of a distributed target (method or computed property)."}]},"doc://com.apple.Swift/documentation/Distributed/DistributedTargetInvocationEncoder/recordReturn