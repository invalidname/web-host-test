{"seeAlsoSections":[{"title":"Distributed Actors","anchor":"Distributed-Actors","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActorSystem","doc:\/\/com.apple.Swift\/documentation\/Distributed\/Resolvable()","doc:\/\/com.apple.Swift\/documentation\/Distributed\/buildDefaultDistributedRemoteActorExecutor(_:)"]}],"metadata":{"externalID":"s:11Distributed0A5ActorP","title":"DistributedActor","modules":[{"name":"Distributed"}],"symbolKind":"protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedActor","kind":"identifier"}],"roleHeading":"Protocol","navigatorTitle":[{"text":"DistributedActor","kind":"identifier"}],"role":"symbol","platforms":[{"name":"iOS","introducedAt":"16.0","beta":false,"deprecated":false,"unavailable":false},{"name":"iPadOS","introducedAt":"16.0","beta":false,"deprecated":false,"unavailable":false},{"name":"Mac Catalyst","introducedAt":"16.0","beta":false,"deprecated":false,"unavailable":false},{"name":"macOS","introducedAt":"13.0","beta":false,"deprecated":false,"unavailable":false},{"name":"tvOS","introducedAt":"16.0","beta":false,"deprecated":false,"unavailable":false},{"name":"watchOS","introducedAt":"9.0","beta":false,"deprecated":false,"unavailable":false}]},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Distributed"]]},"kind":"symbol","identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Common protocol to which all distributed actors conform implicitly."}],"topicSections":[{"title":"Associated Types","anchor":"Associated-Types","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/ActorSystem-swift.associatedtype","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/SerializationRequirement"]},{"title":"Initializers","anchor":"Initializers","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/init(from:)"]},{"title":"Instance Properties","anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/actorSystem-swift.property","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/asLocalActor","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/unownedExecutor"]},{"title":"Instance Methods","anchor":"Instance-Methods","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/assertIsolated(_:file:line:)","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/assumeIsolated(_:file:line:)","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/encode(to:)","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/preconditionIsolated(_:file:line:)","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/whenLocal(_:)"]},{"title":"Type Methods","anchor":"Type-Methods","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/resolve(id:using:)"]}],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/Equatable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Hashable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Identifiable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","doc:\/\/com.apple.Swift\/documentation\/Swift\/SendableMetatype"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedActor","kind":"identifier"},{"text":" : AnyObject, ","kind":"text"},{"text":"Hashable","kind":"typeIdentifier","preciseIdentifier":"s:SH","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Hashable"},{"text":", ","kind":"text"},{"text":"Identifiable","kind":"typeIdentifier","preciseIdentifier":"s:s12IdentifiableP","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Identifiable"},{"text":", ","kind":"text"},{"text":"Sendable","kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"DistributedActor"},{"text":" protocol generalizes over all distributed actor types.","type":"text"},{"text":" ","type":"text"},{"text":"Distributed actor types implicitly conform to this protocol.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is not possible to conform to this protocol by any other declaration other than a ","type":"text"},{"type":"codeVoice","code":"distributed actor"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is possible to require a type to conform to the","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor"},{"text":" protocol by refining it with another protocol,","type":"text"},{"text":" ","type":"text"},{"text":"or by using a generic constraint.","type":"text"}]},{"type":"heading","level":2,"text":"Synthesized properties","anchor":"Synthesized-properties"},{"type":"paragraph","inlineContent":[{"text":"For every concrete distributed actor declaration, the compiler synthesizes two properties: ","type":"text"},{"type":"codeVoice","code":"actorSystem"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"id"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"They witness the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/actorSystem-swift.property"},{"text":" and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id"},{"text":" protocol requirements of the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor"},{"text":" protocol.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is not possible to implement these properties explicitly in user code.","type":"text"},{"text":" ","type":"text"},{"text":"These properties are ","type":"text"},{"type":"codeVoice","code":"nonisolated"},{"text":" and accessible even if the instance is ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"remote"}]},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"because ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"all"}]},{"text":" distributed actor references must store the actor system remote calls","type":"text"},{"text":" ","type":"text"},{"text":"will be delivered through, as well as the id identifying the target of those calls.","type":"text"}]},{"type":"heading","level":2,"text":"The ActorSystem associated type","anchor":"The-ActorSystem-associated-type"},{"type":"paragraph","inlineContent":[{"text":"Every distributed actor must declare what type of actor system","type":"text"},{"text":" ","type":"text"},{"text":"it is part of by implementing the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/ActorSystem-swift.associatedtype"},{"text":" associated type requirement.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This causes a number of other properties of the actor to be inferred:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/SerializationRequirement","isActive":true},{"type":"text","text":" that will be used at compile time to"},{"type":"text","text":" "},{"type":"text","text":"verify "},{"type":"codeVoice","code":"distributed"},{"type":"text","text":" target declarations are well formed,"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"if the distributed actor is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", based on the "},{"type":"codeVoice","code":"ID"},{"type":"text","text":" being Codable or not,"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"the type of the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/ActorSystem-swift.associatedtype","isActive":true},{"type":"text","text":" accepted in the synthesized default initializer."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"A distributed actor must declare what type of actor system it is ready to","type":"text"},{"text":" ","type":"text"},{"text":"work with by fulfilling the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/ActorSystem-swift.associatedtype"},{"text":" type member requirement:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["distributed actor Greeter {","  typealias ActorSystem = GreetingSystem \/\/ which conforms to DistributedActorSystem","","  func greet() -> String { \"Hello!\" }","}"]},{"type":"heading","level":3,"text":"The DefaultDistributedActorSystem type alias","anchor":"The-DefaultDistributedActorSystem-type-alias"},{"type":"paragraph","inlineContent":[{"text":"Since it is fairly common to only be using one specific type of actor system","type":"text"},{"text":" ","type":"text"},{"text":"within a module or entire codebase, it is possible to declare the default type","type":"text"},{"text":" ","type":"text"},{"text":"of actor system all distributed actors will be using in a module by declaring","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"type":"codeVoice","code":"DefaultDistributedActorSystem"},{"text":" module wide typealias:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["import Distributed","import AmazingActorSystemLibrary","","typealias DefaultDistributedActorSystem = AmazingActorSystem","","distributed actor Greeter {} \/\/ ActorSystem == AmazingActorSystem"]},{"type":"paragraph","inlineContent":[{"text":"This declaration makes all ","type":"text"},{"type":"codeVoice","code":"distributed actor"},{"text":" declarations","type":"text"},{"text":" ","type":"text"},{"text":"that do not explicitly specify an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/ActorSystem-swift.associatedtype"},{"text":" type alias to assume the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"AmazingActorSystem"},{"text":" as their ","type":"text"},{"type":"codeVoice","code":"ActorSystem"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is possible for a specific actor to override the system it is using,","type":"text"},{"text":" ","type":"text"},{"text":"by declaring an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/ActorSystem-swift.associatedtype"},{"text":" type alias as usual:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["typealias DefaultDistributedActorSystem = AmazingActorSystem","","distributed actor Amazing {","  \/\/ ActorSystem == AmazingActorSystem","}","","distributed actor Superb {","  typealias ActorSystem = SuperbActorSystem","}"]},{"type":"paragraph","inlineContent":[{"text":"In general the ","type":"text"},{"type":"codeVoice","code":"DefaultDistributedActorSystem"},{"text":" should not be declared public,","type":"text"},{"text":" ","type":"text"},{"text":"as picking the default should be left up to each specific module of a project.","type":"text"}]},{"type":"heading","level":2,"text":"Default initializer","anchor":"Default-initializer"},{"type":"paragraph","inlineContent":[{"text":"While classes and actors receive a synthesized ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"argument-free default"},{"type":"text","text":" "},{"type":"text","text":"initializer"}]},{"text":" (","type":"text"},{"type":"codeVoice","code":"init()"},{"text":"), distributed actors synthesize a default initializer","type":"text"},{"text":" ","type":"text"},{"text":"that accepts a distributed actor system the actor is part of: ","type":"text"},{"type":"codeVoice","code":"init(actorSystem:)"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The accepted actor system must be of the ","type":"text"},{"type":"codeVoice","code":"Self.ActorSystem"},{"text":" type, which","type":"text"},{"text":" ","type":"text"},{"text":"must conform to the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActorSystem"},{"text":" protocol. This is required","type":"text"},{"text":" ","type":"text"},{"text":"because distributed actors are always managed by a concrete","type":"text"},{"text":" ","type":"text"},{"text":"distributed actor system and cannot exist on their own without one.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is possible to explicitly declare a parameter-free initializer (","type":"text"},{"type":"codeVoice","code":"init()"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"however the ","type":"text"},{"type":"codeVoice","code":"actorSystem"},{"text":" property still must be assigned a concrete actor","type":"text"},{"text":" ","type":"text"},{"text":"system instance the actor shall be part of.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In general it is recommended to always have an ","type":"text"},{"type":"codeVoice","code":"actorSystem"},{"text":" parameter as","type":"text"},{"text":" ","type":"text"},{"text":"the last non-defaulted non-closure parameter in every actor’s","type":"text"},{"text":" ","type":"text"},{"text":"initializer parameter list. This way it is simple to swap in a “test actor","type":"text"},{"text":" ","type":"text"},{"text":"system” instance in unit tests, and avoid relying on global state which could","type":"text"},{"text":" ","type":"text"},{"text":"make testing more difficult.","type":"text"}]},{"type":"heading","level":2,"text":"Implicit properties","anchor":"Implicit-properties"},{"type":"paragraph","inlineContent":[{"text":"Every concrete ","type":"text"},{"type":"codeVoice","code":"distributed actor"},{"text":" type receives two synthesized properties,","type":"text"},{"text":" ","type":"text"},{"text":"which implement the protocol requirements of this protocol: ","type":"text"},{"type":"codeVoice","code":"id"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"actorSystem"},{"text":".","type":"text"}]},{"type":"heading","level":3,"text":"Property: Actor System","anchor":"Property-Actor-System"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/actorSystem-swift.property"},{"text":" property is an important part of every distributed actor’s lifecycle management.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Both initialization as well as de-initialization require interactions with the actor system,","type":"text"},{"text":" ","type":"text"},{"text":"and it is the actor system that handles all remote interactions of an actor, by both sending","type":"text"},{"text":" ","type":"text"},{"text":"or receiving remote calls made on the actor.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/actorSystem-swift.property"},{"text":" property must be assigned in every designated initializer","type":"text"},{"text":" ","type":"text"},{"text":"of a distributed actor explicitly. It is highly recommended to make it a","type":"text"},{"text":" ","type":"text"},{"text":"parameter of every distributed actor initializer, and simply forward the","type":"text"},{"text":" ","type":"text"},{"text":"value to the stored property, like this:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["init(name: String, actorSystem: Self.ActorSystem) {","  self.name = name","  self.actorSystem = actorSystem","}"]},{"type":"paragraph","inlineContent":[{"text":"Forgetting to initialize the actor system, will result in a compile time error:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ BAD","init(name: String, actorSystem: Self.ActorSystem) {","  self.name = name","  \/\/ BAD, will cause compile-time error; the `actorSystem` was not initialized.","}"]},{"type":"heading","level":3,"text":"Property: Distributed Actor Identity","anchor":"Property-Distributed-Actor-Identity"},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id"},{"text":" is assigned by the actor system during the distributed actor’s","type":"text"},{"text":" ","type":"text"},{"text":"initialization, and cannot be set or mutated by the actor itself.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id"},{"text":" is the effective identity of the actor, and is used in equality checks,","type":"text"},{"text":" ","type":"text"},{"text":"as well as the actor’s synthesized ","type":"text"},{"type":"codeVoice","code":"Codable"},{"text":" conformance if the ","type":"text"},{"type":"codeVoice","code":"ID"},{"text":" type","type":"text"},{"text":" ","type":"text"},{"text":"conforms to ","type":"text"},{"type":"codeVoice","code":"Codable"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Automatic Conformances","anchor":"Automatic-Conformances"},{"type":"heading","level":3,"text":"Hashable and Identifiable conformance","anchor":"Hashable-and-Identifiable-conformance"},{"type":"paragraph","inlineContent":[{"text":"Every distributed actor conforms to the ","type":"text"},{"type":"codeVoice","code":"Hashable"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Identifiable"},{"text":" protocols.","type":"text"},{"text":" ","type":"text"},{"text":"Its identity is strictly driven by its ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id"},{"text":", and therefore hash and equality","type":"text"},{"text":" ","type":"text"},{"text":"implementations directly delegate to the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id"},{"text":" property.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Comparing a local distributed actor instance and a remote reference to it","type":"text"},{"text":" ","type":"text"},{"text":"(both using the same ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id"},{"text":") always returns true, as they both conceptually","type":"text"},{"text":" ","type":"text"},{"text":"point at the same distributed actor.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It is not possible to implement these protocols relying on the actual actor’s","type":"text"},{"text":" ","type":"text"},{"text":"state, because it may be remote and the state may not be available. In other","type":"text"},{"text":" ","type":"text"},{"text":"words, since these protocols must be implemented using ","type":"text"},{"type":"codeVoice","code":"nonisolated"},{"text":" functions,","type":"text"},{"text":" ","type":"text"},{"text":"only ","type":"text"},{"type":"codeVoice","code":"nonisolated"},{"text":" ","type":"text"},{"type":"codeVoice","code":"id"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"actorSystem"},{"text":" properties are accessible for their","type":"text"},{"text":" ","type":"text"},{"text":"implementations.","type":"text"}]},{"type":"heading","level":3,"text":"Implicit Codable conformance","anchor":"Implicit-Codable-conformance"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If created with an actor system whose "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActorSystem\/ActorID","isActive":true},{"type":"text","text":" is "},{"type":"codeVoice","code":"Codable"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"compiler will synthesize code for the concrete distributed actor to conform"},{"text":" ","type":"text"},{"text":"to ","type":"text"},{"code":"Codable","type":"codeVoice"},{"text":" as well.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is necessary to support distributed calls where the "},{"type":"codeVoice","code":"SerializationRequirement"},{"text":" ","type":"text"},{"type":"text","text":"is "},{"code":"Codable","type":"codeVoice"},{"type":"text","text":" and thus users may want to pass actors as arguments to remote calls."}]},{"type":"paragraph","inlineContent":[{"text":"The synthesized implementations use a single ","type":"text"},{"code":"SingleValueEncodingContainer","type":"codeVoice"},{"text":" to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"encode\/decode the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id","isActive":true},{"type":"text","text":" property of the actor. The "},{"type":"codeVoice","code":"Decoder"},{"type":"text","text":" required"},{"type":"text","text":" "},{"type":"codeVoice","code":"Decoder\/init(from:)"},{"type":"text","text":" is implemented by retrieving an actor system from the"},{"type":"text","text":" "},{"type":"text","text":"decoders’ "},{"type":"codeVoice","code":"userInfo"},{"type":"text","text":", effectively like as follows:"}]},{"code":["decoder.userInfo[.actorSystemKey] as? ActorSystem","","The such obtained actor system is then used to ``resolve(id:using:)`` the decoded ``ID``.","","Use the ``CodingUserInfoKey\/actorSystemKey`` to provide the necessary","actor system for the decoding initializer when decoding a distributed actor.","","- SeeAlso: ``DistributedActorSystem``","- SeeAlso: ``Actor``","- SeeAlso: ``AnyActor``"],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/distributed\/distributedactor"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Distributed/DistributedActor":{"url":"\/documentation\/distributed\/distributedactor","abstract":[{"text":"Common protocol to which all distributed actors conform implicitly.","type":"text"}],"title":"DistributedActor","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor","navigatorTitle":[{"text":"DistributedActor","kind":"identifier"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DistributedActor","kind":"identifier"}],"type":"topic","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/Sendable":{"role":"symbol","fragments":[{"