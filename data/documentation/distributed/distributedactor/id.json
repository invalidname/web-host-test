{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"override","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"id","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ID","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Identifiable\/ID-swift.associatedtype","preciseIdentifier":"s:s12IdentifiableP2IDQa"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Many distributed actor references may be pointing at, logically, the same actor.","type":"text"},{"text":" ","type":"text"},{"text":"For example, calling ","type":"text"},{"type":"codeVoice","code":"resolve(id:using:)"},{"text":" multiple times, is not guaranteed","type":"text"},{"text":" ","type":"text"},{"text":"to return the same exact resolved actor instance, however all the references would","type":"text"},{"text":" ","type":"text"},{"text":"represent logically references to the same distributed actor, e.g. on a different node.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Depending on the capabilities of the actor system producing the identifiers,","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"ID"},{"text":" may also be used to store instance specific metadata.","type":"text"}],"type":"paragraph"},{"text":"Synthesized property","level":2,"anchor":"Synthesized-property","type":"heading"},{"inlineContent":[{"text":"In concrete distributed actor declarations, a witness for this protocol requirement is synthesized by the compiler.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"It is not possible to assign a value to the ","type":"text"},{"type":"codeVoice","code":"id"},{"text":" directly; instead, it is assigned during an actors ","type":"text"},{"type":"codeVoice","code":"init"},{"text":" (or ","type":"text"},{"type":"codeVoice","code":"resolve"},{"text":"),","type":"text"},{"text":" ","type":"text"},{"text":"by the managing actor system.","type":"text"}],"type":"paragraph"}]}],"sections":[],"metadata":{"externalID":"s:11Distributed0A5ActorP2id2IDQzvp","platforms":[{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"iOS"},{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"iPadOS"},{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"Mac Catalyst"},{"introducedAt":"13.0","unavailable":false,"beta":false,"deprecated":false,"name":"macOS"},{"introducedAt":"16.0","unavailable":false,"beta":false,"deprecated":false,"name":"tvOS"},{"introducedAt":"9.0","unavailable":false,"beta":false,"deprecated":false,"name":"watchOS"}],"title":"id","roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"id","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ID","preciseIdentifier":"s:s12IdentifiableP2IDQa","kind":"typeIdentifier"}],"symbolKind":"property","role":"symbol","modules":[{"name":"Distributed"}],"required":true},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Distributed","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor"]]},"abstract":[{"text":"Logical identity of this distributed actor.","type":"text"}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActor\/id"},"variants":[{"paths":["\/documentation\/distributed\/distributedactor\/id"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Distributed":{"url":"\/documentat