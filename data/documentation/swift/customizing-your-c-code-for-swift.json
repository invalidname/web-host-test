{"sections":[],"metadata":{"title":"Customizing Your C Code for Swift","roleHeading":"Article","role":"article","modules":[{"name":"Swift"}]},"kind":"article","identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/customizing-your-c-code-for-swift","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/using-imported-c-structs-and-unions-in-swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/using-imported-c-functions-in-swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/using-imported-c-macros-in-swift"],"title":"Language Interoperability with C and C++","anchor":"Language-Interoperability-with-C-and-C++"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Because structures in C can’t have methods, property accessors, or custom initializers,","type":"text"},{"text":" ","type":"text"},{"text":"you often need to write such functionality using global functions. Structures in","type":"text"},{"text":" ","type":"text"},{"text":"Swift can declare methods, property accessors, and initializers. You use the ","type":"text"},{"code":"CF_SWIFT_NAME","type":"codeVoice"},{"text":" ","type":"text"},{"text":"macro to group together related global functions into a single structure type that’s","type":"text"},{"text":" ","type":"text"},{"text":"imported into Swift.","type":"text"}]},{"level":3,"anchor":"Apply-CFSWIFTNAME-to-Related-Functions","type":"heading","text":"Apply CF_SWIFT_NAME to Related Functions"},{"type":"paragraph","inlineContent":[{"text":"The example below shows several functions that are all related to a ","type":"text"},{"code":"Color","type":"codeVoice"},{"text":" type.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"code":"CF_SWIFT_NAME","type":"codeVoice"},{"text":" macro is applied to each function, giving each one a new name","type":"text"},{"text":" ","type":"text"},{"text":"for Swift that’s nested together under the ","type":"text"},{"code":"Color","type":"codeVoice"},{"text":" type:","type":"text"}]},{"type":"codeListing","syntax":"occ","code":["Color ColorCreateWithCMYK(float c, float m, float y, float k) CF_SWIFT_NAME(Color.init(c:m:y:k:));","","float ColorGetHue(Color color) CF_SWIFT_NAME(getter:Color.hue(self:));","void ColorSetHue(Color color, float hue) CF_SWIFT_NAME(setter:Color.hue(self:newValue:));","","Color ColorDarkenColor(Color color, float amount) CF_SWIFT_NAME(Color.darken(self:amount:));","","extern const Color ColorBondiBlue CF_SWIFT_NAME(Color.bondiBlue);","","Color ColorGetCalibrationColor(void) CF_SWIFT_NAME(getter:Color.calibration());","Color ColorSetCalibrationColor(Color color) CF_SWIFT_NAME(setter:Color.calibration(newValue:));"]},{"type":"paragraph","inlineContent":[{"text":"The argument you pass to the ","type":"text"},{"code":"CF_SWIFT_NAME","type":"codeVoice"},{"text":" macro uses the same syntax as the ","type":"text"},{"code":"#selector","type":"codeVoice"},{"text":" ","type":"text"},{"text":"expression. You use ","type":"text"},{"code":"self","type":"codeVoice"},{"text":" in a ","type":"text"},{"code":"CF_SWIFT_NAME","type":"codeVoice"},{"text":" argument to refer to the instance","type":"text"},{"text":" ","type":"text"},{"text":"that the method belongs to.","type":"text"}]},{"level":3,"anchor":"Import-Related-Functions-into-Swift","type":"heading","text":"Import Related Functions into Swift"},{"type":"paragraph","inlineContent":[{"text":"Here’s how Swift imports the related functions above into a single type:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension Color {","    init(c: Float, m: Float, y: Float, k: Float)","","    var hue: Float { get set }","","    func darken(amount: Float) -> Color","","    static var bondiBlue: Color","","    static var calibration: Color","}"]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"You can’t reorder or change the number of arguments for type members imported","type":"text"},{"text":" ","type":"text"},{"text":"using the ","type":"text"},{"type":"codeVoice","code":"CF_SWIFT_NAME"},{"text":" macro.","type":"text"}]}],"type":"aside","name":"Note"}]}],"abstract":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"CF_SWIFT_NAME"},{"type":"text","text":" macro to group functions that have related behavior."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/customizing-your-c-code-for-swift"]}],"references":{"doc://com.apple.Swift/documentation/Swift/using-imported-c-functions-in-swift":{"title":"Using Imported C Functions in Swift","type":"topic","role":"article","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/using-imported-c-functions-in-swift","kind":"article","abstract":[{"text":"Learn how to call imported functions that are declared in a C header.","type":"text"}],"url":"\/documentation\/swift\/using-imported-c-functions-in-swift"},"doc://com.apple.Swift/documentation/Swift/using-imported-c-structs-and-unions-in-swift":{"kind":"article","type":"topic","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/using-imported-c-structs-and-unions-in-swift","abstract":[{"text":"Learn how Swift represents imported C structures and unions, including types with","type":"text"},{"text":" ","type":"text"},{"text":"bitfields and unnamed fields.","type":"text"}],"role":"article","title":"Using Imported C Structs and Unions in Swift","url":"\/documentation\/swift\/using-imported-c-structs-and-unions-in-swift"},"doc://com.apple.Swift/documentation/Swift/using-imported-c-macros-in-swift":{"title":"Using Imported C Macros in Swift","type":"topic","role":"article","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/using-imported-c-macros-in-swift","kind":"article","abstract":[{"text":"Use imported C-defined macros as constants.","type":"text"}],"url":"\/documentation\/swift\/using-imported-c-macros-in-swift"},"Swift-PageImage-card.png":{"alt":"An orange Swift logo on a gradient background.","identifier":"Swift-PageImage-card.png","type":"image","variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png","traits":["2x","dark"]}]},"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","type":"topic","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","kind":"symbol"}}}