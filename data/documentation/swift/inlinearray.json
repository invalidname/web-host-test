{"sections":[],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/InlineArray","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"relationshipsSections":[{"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BitwiseCopyable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Copyable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","doc:\/\/com.apple.Swift\/documentation\/Swift\/SendableMetatype"],"title":"Conforms To","type":"conformsTo","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"InlineArray","kind":"identifier"},{"text":"<let ","kind":"text"},{"text":"count","kind":"genericParameter"},{"text":" : ","kind":"text"},{"text":"Int","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Int","preciseIdentifier":"s:Si","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Element","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Element","kind":"typeIdentifier"},{"text":" : ~Copyable","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"text":"An ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" is a specialized container that doesn’t use a separate","type":"text"},{"text":" ","type":"text"},{"text":"memory allocation just to store its elements. When a value is copied, all of","type":"text"},{"text":" ","type":"text"},{"text":"its elements are copied eagerly, like those of a tuple. Use an ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" ","type":"text"},{"text":"when you have a fixed number of elements and need to avoid a separate heap","type":"text"},{"text":" ","type":"text"},{"text":"allocation.","type":"text"}],"type":"paragraph"},{"text":"Initializing a Value","type":"heading","level":2,"anchor":"Initializing-a-Value"},{"inlineContent":[{"text":"When initializing a new ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" value, you must initialize all of its","type":"text"},{"text":" ","type":"text"},{"text":"elements. You can use an array literal just as with ","type":"text"},{"code":"Array","type":"codeVoice"},{"text":", rely on type","type":"text"},{"text":" ","type":"text"},{"text":"inference for the ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"Element","type":"codeVoice"},{"text":" type, and spell the type with the","type":"text"},{"text":" ","type":"text"},{"text":"shorthand ","type":"text"},{"code":"[count of Element]","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let a: InlineArray<3, Int> = [1, 2, 3]","let b: InlineArray<_, Int> = [1, 2, 3]","let c: InlineArray<3, _>   = [1, 2, 3]","let d: InlineArray         = [1, 2, 3]","","let e: [3 of Int]          = [1, 2, 3]","let f: [_ of Int]          = [1, 2, 3]","let g: [3 of _]            = [1, 2, 3]","let h: [_ of _]            = [1, 2, 3]"],"type":"codeListing"},{"inlineContent":[{"text":"You can also use one of the type’s initializers to create a new value.","type":"text"}],"type":"paragraph"},{"text":"Accessing Elements","type":"heading","level":2,"anchor":"Accessing-Elements"},{"inlineContent":[{"text":"Just as with ","type":"text"},{"code":"Array","type":"codeVoice"},{"text":", you can read and modify an element in an ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" ","type":"text"},{"text":"using a subscript. Unless you use the memory-unsafe ","type":"text"},{"code":"unchecked","type":"codeVoice"},{"text":" subscript,","type":"text"},{"text":" ","type":"text"},{"text":"any index you provide is subject to bounds checking; an invalid index","type":"text"},{"text":" ","type":"text"},{"text":"triggers a runtime error in your program.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var values: [3 of Double] = [1, 1.5, 2]","print(values[0])  \/\/ Prints \"1.0\"","values[1] -= 0.25","print(values[1])  \/\/ Prints \"1.25\"","values[3] = 42.0  \/\/ Fatal error: Index out of bounds"],"type":"codeListing"},{"inlineContent":[{"text":"You can use the ","type":"text"},{"code":"indices","type":"codeVoice"},{"text":" property to iterate over all elements in order.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["for index in values.indices {","    print(values[index])","}"],"type":"codeListing"},{"text":"Working with Noncopyable Elements","type":"heading","level":2,"anchor":"Working-with-Noncopyable-Elements"},{"inlineContent":[{"text":"An ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" can store elements of potentially noncopyable type. When","type":"text"},{"text":" ","type":"text"},{"code":"Element","type":"codeVoice"},{"text":" isn’t copyable, the ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" itself also isn’t copyable. You","type":"text"},{"text":" ","type":"text"},{"text":"must then explicitly move or consume the value if you want to transfer","type":"text"},{"text":" ","type":"text"},{"text":"ownership.","type":"text"}],"type":"paragraph"},{"text":"Memory Layout","type":"heading","level":2,"anchor":"Memory-Layout"},{"inlineContent":[{"text":"An ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" stores its elements contiguously. If an ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" is a","type":"text"},{"text":" ","type":"text"},{"text":"stored property of a class, then it’s allocated on the heap along with the","type":"text"},{"text":" ","type":"text"},{"text":"other stored properties of the class. Otherwise, in general, an","type":"text"},{"text":" ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":" is allocated on the stack.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"non-empty","type":"text"}]},{"text":" ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":"’s size and stride are both found by multiplying","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"count","type":"codeVoice"},{"text":" of elements by the ","type":"text"},{"code":"Element","type":"codeVoice"},{"text":"’s stride. Its alignment is equal to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"Element","type":"codeVoice"},{"text":"’s alignment.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct Record {","    let x: UInt32","    let y: Bool","}","MemoryLayout<Record>.size                 \/\/ 5","MemoryLayout<Record>.stride               \/\/ 8","MemoryLayout<Record>.alignment            \/\/ 4","MemoryLayout<[2 of Record]>.size          \/\/ 16","MemoryLayout<[2 of Record]>.stride        \/\/ 16","MemoryLayout<[2 of Record]>.alignment     \/\/ 4","MemoryLayout<(Record, Record)>.size       \/\/ 13","MemoryLayout<(Record, Record)>.stride     \/\/ 16","MemoryLayout<(Record, Record)>.alignment  \/\/ 4"],"type":"codeListing"},{"inlineContent":[{"text":"An ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"empty","type":"text"}]},{"text":" ","type":"text"},{"code":"InlineArray","type":"codeVoice"},{"text":"’s size is zero. Its stride and alignment are both","type":"text"},{"text":" ","type":"text"},{"text":"one byte.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"topicSections":[{"anchor":"Initializers","generated":true,"title":"Initializers","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/InlineArray\/init(_:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/InlineArray\/init(first:next:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/InlineArray\/in