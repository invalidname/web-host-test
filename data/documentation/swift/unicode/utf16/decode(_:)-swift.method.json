{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Unicode\/UTF16\/decode(_:)-swift.method"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/Unicode","doc:\/\/com.apple.Swift\/documentation\/Swift\/Unicode\/UTF16"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"decode"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"input"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I","preciseIdentifier":"s:s7UnicodeO5UTF16O6decodeys0A14DecodingResultOxzStRzs6UInt16V7ElementRtzlF1IL_xmfp"},{"kind":"text","text":") -> "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UnicodeDecodingResult","kind":"typeIdentifier","text":"UnicodeDecodingResult","preciseIdentifier":"s:s21UnicodeDecodingResultO"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/IteratorProtocol","kind":"typeIdentifier","text":"IteratorProtocol","preciseIdentifier":"s:St"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":"."},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/IteratorProtocol\/Element","kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:St7ElementQa"},{"kind":"text","text":" == "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UInt16","kind":"typeIdentifier","text":"UInt16","preciseIdentifier":"s:s6UInt16V"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"An iterator of code units to be decoded. ","type":"text"},{"code":"input","type":"codeVoice"},{"text":" must be","type":"text"},{"text":" ","type":"text"},{"text":"the same iterator instance in repeated calls to this method. Do not","type":"text"},{"text":" ","type":"text"},{"text":"advance the iterator or any copies of the iterator outside this","type":"text"},{"type":"text","text":" "},{"text":"method.","type":"text"}],"type":"paragraph"}],"name":"input"}]},{"content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"text":" instance, representing the next","type":"text"},{"text":" ","type":"text"},{"text":"Unicode scalar, an indication of an error, or an indication that the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"UTF sequence has been fully decoded."}]}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To decode a code unit sequence completely, call this method repeatedly"},{"type":"text","text":" "},{"type":"text","text":"until it returns "},{"type":"codeVoice","code":"UnicodeDecodingResult.emptyInput"},{"type":"text","text":". Checking that the"},{"type":"text","text":" "},{"type":"text","text":"iterator was exhausted is not sufficient, because the decoder can store"},{"type":"text","text":" "},{"type":"text","text":"buffered data from the input iterator."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}]},{"type":"paragraph","inlineContent":[{"text":"The following example decodes the UTF-16 encoded bytes of a string into an","type":"text"},{"text":" ","type":"text"},{"text":"array of ","type":"text"},{"code":"Unicode.Scalar","type":"codeVoice"},{"text":" instances. This is a demonstration only—if","type":"text"},{"text":" ","type":"text"},{"text":"you need the Unicode scalar representation of a string, use its","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"unicodeScalars"},{"type":"text","text":" view."}]},{"type":"codeListing","syntax":"swift","code":["let str = \"✨Unicode✨\"","print(Array(str.utf16))","\/\/ Prints \"[10024, 85, 110, 105, 99, 111, 100, 101, 10024]\"","","var codeUnitIterator = str.utf16.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf16Decoder = UTF16()","Decode: while true {","    switch utf16Decoder.decode(&codeUnitIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","\/\/ Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/unicode\/utf16\/decode(_:)-swift.method"]}],"abstract":[{"type":"text","text":"Starts or continues decoding a UTF-16 sequence."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"symbolKind":"method","externalID":"s:s7UnicodeO5UTF16O6decodeys0A14DecodingResultOxzStRzs6UInt16V7ElementRtzlF","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"decode","kind":"identifier"},{"text":"<","kind":"text"},{"text":"I","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"keyword","text":"inout"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:s7UnicodeO5UTF16O6decodeys0A14DecodingResultOxzStRzs6UInt16V7ElementRtzlF1IL_xmfp","text":"I","kind":"typeI