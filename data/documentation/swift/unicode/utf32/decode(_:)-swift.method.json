{"abstract":[{"text":"Starts or continues decoding a UTF-32 sequence.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"mutating","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"decode","kind":"identifier"},{"text":"<","kind":"text"},{"text":"I","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"input","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"I","kind":"typeIdentifier","preciseIdentifier":"s:s7UnicodeO5UTF32O6decodeys0A14DecodingResultOxzStRzs6UInt32V7ElementRtzlF1IL_xmfp"},{"kind":"text","text":") -> "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UnicodeDecodingResult","kind":"typeIdentifier","text":"UnicodeDecodingResult","preciseIdentifier":"s:s21UnicodeDecodingResultO"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"I"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/IteratorProtocol","kind":"typeIdentifier","text":"IteratorProtocol","preciseIdentifier":"s:St"},{"kind":"text","text":", "},{"text":"I","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIdentifier":"s:St7ElementQa","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/IteratorProtocol\/Element"},{"text":" == ","kind":"text"},{"text":"UInt32","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UInt32","preciseIdentifier":"s:s6UInt32V"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"An iterator of code units to be decoded. ","type":"text"},{"type":"codeVoice","code":"input"},{"text":" must be","type":"text"},{"text":" ","type":"text"},{"text":"the same iterator instance in repeated calls to this method. Do not","type":"text"},{"text":" ","type":"text"},{"text":"advance the iterator or any copies of the iterator outside this","type":"text"},{"text":" ","type":"text"},{"text":"method.","type":"text"}]}],"name":"input"}]},{"kind":"content","content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"text":" instance, representing the next","type":"text"},{"text":" ","type":"text"},{"text":"Unicode scalar, an indication of an error, or an indication that the","type":"text"},{"text":" ","type":"text"},{"text":"UTF sequence has been fully decoded.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"To decode a code unit sequence completely, call this method repeatedly","type":"text"},{"text":" ","type":"text"},{"text":"until it returns ","type":"text"},{"type":"codeVoice","code":"UnicodeDecodingResult.emptyInput"},{"text":". Checking that the","type":"text"},{"text":" ","type":"text"},{"text":"iterator was exhausted is not sufficient, because the decoder can store","type":"text"},{"text":" ","type":"text"},{"text":"buffered data from the input iterator.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because of buffering, it is impossible to find the corresponding position","type":"text"},{"text":" ","type":"text"},{"text":"in the iterator for a given returned ","type":"text"},{"type":"codeVoice","code":"Unicode.Scalar"},{"text":" or an error.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example decodes the UTF-16 encoded bytes of a string","type":"text"},{"text":" ","type":"text"},{"text":"into an array of ","type":"text"},{"type":"codeVoice","code":"Unicode.Scalar"},{"text":" instances. This is a demonstration","type":"text"},{"text":" ","type":"text"},{"text":"only—if you need the Unicode scalar representation of a string, use","type":"text"},{"text":" ","type":"text"},{"text":"its ","type":"text"},{"type":"codeVoice","code":"unicodeScalars"},{"text":" view.","type":"text"}],"type":"paragraph"},{"code":["\/\/ UTF-32 representation of \"✨Unicode✨\"","let codeUnits: [UTF32.CodeUnit] =","        [10024, 85, 110, 105, 99, 111, 100, 101, 10024]","","var codeUnitIterator = codeUnits.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf32Decoder = UTF32()","Decode: while true {","    switch utf32Decoder.decode(&codeUnitIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","\/\/ Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""],"syntax":"swift","type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/unicode\/utf32\/decode(_:)-swift.method"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Unicode\/UTF32\/decode(_:)-swift.method"},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"decode","kind":"identifier"},{"text":"<","kind":"text"},{"text":"I","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"I","kind":"typeIdentifier","preciseIdentifier":"s:s7UnicodeO5UTF32O6decodeys0A14DecodingResultOxzStRzs6UInt32V7ElementRtzlF1IL_xmfp"},{"text":") -> ","kind":"text"},{"text":"UnicodeDecodingResult","kind":"typeIdentifier","preciseIdentifier":"s:s21UnicodeDecodingResultO"}],"modules":[{"name":"Swift"}],"externalID":"s:s7UnicodeO5UTF32O6decodeys0A14DecodingResultOxzStRzs6UInt32V7ElementRtzlF","extendedModule":"Swift","roleHeading":"Instance Me