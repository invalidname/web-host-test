oice"},{"text":") to the ","type":"text"},{"code":"sorted(by:)","type":"codeVoice"},{"text":" method.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","\/\/ Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""]},{"type":"paragraph","inlineContent":[{"text":"The sorting algorithm is guaranteed to be stable. A stable sort","type":"text"},{"text":" ","type":"text"},{"text":"preserves the relative order of elements that compare as equal.","type":"text"}]},{"content":[{"inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":" log ","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":" is the length of the sequence.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Complexity"}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Unicode\/Scalar\/UTF8View\/sorted()","interfaceLanguage":"swift"},"metadata":{"externalID":"s:STsSL7ElementRpzrlE6sortedSayABGyF::SYNTHESIZED::s:s7UnicodeO6ScalarV8UTF8ViewV","title":"sorted()","platforms":[{"introducedAt":"8.0","beta":false,"unavailable":false,"deprecated":false,"name":"iOS"},{"introducedAt":"8.0","beta":false,"unavailable":false,"deprecated":false,"name":"iPadOS"},{"introducedAt":"13.0","beta":false,"unavailable":false,"deprecated":false,"name":"Mac Catalyst"},{"introducedAt":"10.10","beta":false,"unavailable":false,"deprecated":false,"name":"macOS"},{"introducedAt":"9.0","beta":false,"unavailable":false,"deprecated":false,"name":"tvOS"},{"introducedAt":"1.0","beta":false,"unavailable":false,"deprecated":false,"name":"visionOS"},{"introducedAt":"2.0","beta":false,"unavailable":false,"deprecated":false,"name":"watchOS"}],"roleHeading":"Instance Method","fragments":[{"