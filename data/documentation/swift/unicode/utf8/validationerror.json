h","inlineContent":[{"text":"80..BF","type":"text"}]}]]],"header":"row"},{"text":"Classifying errors","level":3,"type":"heading","anchor":"Classifying-errors"},{"inlineContent":[{"text":"An ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"unexpected continuation","type":"text"}]},{"text":" is when a continuation byte (","type":"text"},{"type":"codeVoice","code":"10xxxxxx"},{"text":") occurs","type":"text"},{"text":" ","type":"text"},{"text":"in a position that should be the start of a new scalar value. Unexpected","type":"text"},{"text":" ","type":"text"},{"text":"continuations can often occur when the input contains arbitrary data","type":"text"},{"text":" ","type":"text"},{"text":"instead of textual content. An unexpected continuation at the start of","type":"text"},{"text":" ","type":"text"},{"text":"input might mean that the input was not correctly sliced along scalar","type":"text"},{"text":" ","type":"text"},{"text":"boundaries or that it does not contain UTF-8.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"truncated scalar","type":"text"}]},{"text":" is a multi-byte sequence that is the start of a valid","type":"text"},{"text":" ","type":"text"},{"text":"multi-byte scalar but is cut off before ending correctly. A truncated","type":"text"},{"text":" ","type":"text"},{"text":"scalar at the end of the input might mean that only part of the entire","type":"text"},{"text":" ","type":"text"},{"text":"input was received.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"surrogate code point","type":"text"}]},{"text":" (","type":"text"},{"code":"U+D800..U+DFFF","type":"codeVoice"},{"text":") is invalid UTF-8. Surrogate","type":"text"},{"text":" ","type":"text"},{"text":"code points are used by UTF-16 to encode scalars in the supplementary","type":"text"},{"text":" ","type":"text"},{"text":"planes. Their presence may mean the input was encoded in a different 8-bit","type":"text"},{"text":" ","type":"text"},{"text":"encoding, such as CESU-8, WTF-8, or Java’s Modified UTF-8.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"invalid non-surrogate code point","type":"text"}]},{"text":" is any code point higher than","type":"text"},{"text":" ","type":"text"},{"code":"U+10FFFF","type":"codeVoice"},{"text":". This can often occur when the input is arbitrary data instead","type":"text"},{"text":" ","type":"text"},{"text":"of textual content.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"overlong encoding","type":"text"}]},{"text":" occurs when a scalar value that could have been","type":"text"},{"text":" ","type":"text"},{"text":"encoded using fewer bytes is encoded in a longer byte sequence. Overlong","type":"text"},{"text":" ","type":"text"},{"text":"encodings are invalid UTF-8 and can lead to security issues if not","type":"text"},{"text":" ","type":"text"},{"text":"correctly detected:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/nvd.nist.gov\/vuln\/detail\/CVE-2008-2938","isActive":true}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"https:\/\/nvd.nist.gov\/vuln\/detail\/CVE-2000-0884","isActive":true}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"An overlong encoding of ","type":"text"},{"type":"codeVoice","code":"NUL"},{"text":", ","type":"text"},{"type":"codeVoice","code":"0xC0 0x80"},{"text":", is used in Java’s Modified","type":"text"},{"text":" ","type":"text"},{"text":"UTF-8 but is invalid UTF-8. Overlong encoding errors often catch attempts","type":"text"},{"text":" ","type":"text"},{"text":"to bypass security measures.","type":"text"}]},{"text":"Reporting the range of the error","type":"heading","level":3,"anchor":"Reporting-the-range-of-the-error"},{"type":"paragraph","inlineContent":[{"text":"The range of the error reported follows the ","type":"text"},{"inlineContent":[{"text":"Maximal subpart of an","type":"text"},{"text":" ","type":"text"},{"text":"ill-formed subsequence","type":"text"}],"type":"emphasis"},{"text":" algorithm in which each error is either one byte","type":"text"},{"text":" ","type":"text"},{"text":"long or ends before the first byte that is disallowed. See “U+FFFD","type":"text"},{"text":" ","type":"text"},{"text":"Substitution of Maximal Subparts” in the Unicode Standard. Unicode started","type":"text"},{"text":" ","type":"text"},{"text":"recommending this algorithm in version 6 and is adopted by the W3C.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The maximal subpart algorithm will produce a single multi-byte range for a","type":"text"},{"text":" ","type":"text"},{"text":"truncated scalar (a multi-byte sequence that is the start of a valid","type":"text"},{"text":" ","type":"text"},{"text":"multi-byte scalar but is cut off before ending correctly). For all other","type":"text"},{"text":" ","type":"text"},{"text":"errors (including overlong encodings, surrogates, and invalid code","type":"text"},{"text":" ","type":"text"},{"text":"points), it will produce an error per byte.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Since overlong encodings, surrogates, and invalid code points are erroneous","type":"text"},{"text":" ","type":"text"},{"text":"by the second byte (at the latest), the above definition produces the same","type":"text"},{"text":" ","type":"text"},{"text":"ranges as defining such a sequence as a truncated scalar error followed by","type":"text"},{"text":" ","type":"text"},{"text":"unexpected continuation byte errors. The more semantically-rich","type":"text"},{"text":" ","type":"text"},{"text":"classification is reported.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, a surrogate code point sequence ","type":"text"},{"type":"codeVoice","code":"ED A0 80"},{"text":" will be reported","type":"text"},{"text":" ","type":"text"},{"text":"as three ","type":"text"},{"type":"codeVoice","code":".surrogateCodePointByte"},{"text":" errors rather than a ","type":"text"},{"code":".truncatedScalar","type":"codeVoice"},{"text":" ","type":"text"},{"text":"followed by two ","type":"text"},{"code":".unexpectedContinuationByte","type":"codeVoice"},{"text":" errors.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Other commonly reported error ranges can be constructed from this result.","type":"text"},{"text":" ","type":"text"},{"text":"For example, PEP 383’s error-per-byte can be constructed by mapping over","type":"text"},{"text":" ","type":"text"},{"text":"the reported range. Similarly, constructing a single error for the longest","type":"text"},{"text":" ","type":"text"},{"text":"invalid byte range can be constructed by joining adjacent error ranges.","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Algorithm","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"61","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"F1","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"80","type":"text"}]}],[{"inlineContent":[{"text":"80","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"E1","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"80","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"C2","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"62","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Longest range","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"U+61","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"err","type":"text"}],"type":"paragraph"}],[{"type":"par