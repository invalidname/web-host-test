":" "},{"type":"text","text":"advance the iterator or any copies of the iterator outside this"},{"type":"text","text":" "},{"type":"text","text":"method."}]}]}]},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"codeVoice","code":"UnicodeDecodingResult"},{"type":"text","text":" instance, representing the next"},{"type":"text","text":" "},{"type":"text","text":"Unicode scalar, an indication of an error, or an indication that the"},{"type":"text","text":" "},{"type":"text","text":"UTF sequence has been fully decoded."}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To decode a code unit sequence completely, call this method repeatedly"},{"type":"text","text":" "},{"type":"text","text":"until it returns "},{"type":"codeVoice","code":"UnicodeDecodingResult.emptyInput"},{"type":"text","text":". Checking that the"},{"type":"text","text":" "},{"type":"text","text":"iterator was exhausted is not sufficient, because the decoder can store"},{"type":"text","text":" "},{"type":"text","text":"buffered data from the input iterator."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because of buffering, it is impossible to find the corresponding position"},{"type":"text","text":" "},{"type":"text","text":"in the iterator for a given returned "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" or an error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example decodes the UTF-8 encoded bytes of a string into an"},{"type":"text","text":" "},{"type":"text","text":"array of "},{"type":"codeVoice","code":"Unicode.Scalar"},{"type":"text","text":" instances. This is a demonstration only—if"},{"type":"text","text":" "},{"type":"text","text":"you need the Unicode scalar representation of a string, use its"},{"type":"text","text":" "},{"type":"codeVoice","code":"unicodeScalars"},{"type":"text","text":" view."}]},{"type":"codeListing","code":["let str = \"✨Unicode✨\"","print(Array(str.utf8))","\/\/ Prints \"[226, 156, 168, 85, 110, 105, 99, 111, 100, 101, 226, 156, 168]\"","","var bytesIterator = str.utf8.makeIterator()","var scalars: [Unicode.Scalar] = []","var utf8Decoder = UTF8()","Decode: while true {","    switch utf8Decoder.decode(&bytesIterator) {","    case .scalarValue(let v): scalars.append(v)","    case .emptyInput: break Decode","    case .error:","        print(\"Decoding error\")","        break Decode","    }","}","print(scalars)","\/\/ Prints \"[\"\\u{2728}\", \"U\", \"n\", \"i\", \"c\", \"o\", \"d\", \"e\", \"\\u{2728}\"]\""],"syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/unicode\/utf8\/decode(_:)-swift.method"]}],"references":{"doc://com.apple.Swift/documentation/Swift/UnicodeDecodingResult":{"fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnicodeDecodingResult"}],"url":"\/documentation\/swift\/unicodedecodingresult","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"UnicodeDecodingResult"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UnicodeDecodingResult","title":"UnicodeDecodingResult","abstract":[{"type":"text","text":"The result of one Unicode decoding step."}]},"doc://com.apple.Swift/documentation/Swift/UInt8":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UInt8","kind":"identifier"}],"url":"\/documentation\/swift\/uint8","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UInt8","navigatorTitle":[{"text":"UInt8","kind":"identifier"}],"type":"topic","title":"UInt8","kind":"symbol","abstract":[{"text":"An 8-bit unsigned integer value","type":"text"},{"text":" ","type":"text"},{"text":"type."