{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/cancel()"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"cancel","kind":"identifier"},{"text":"()","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Cancelling a task has three primary effects:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"It flags the task as canceled.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"It causes any active cancellation handlers on the task to run, once.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"It cancels any child tasks and task groups of the task, including","type":"text"},{"text":" ","type":"text"},{"text":"those created in the future. If those tasks have cancellation handlers,","type":"text"},{"text":" ","type":"text"},{"text":"they also are triggered.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"text":"Task cancellation is cooperative and idempotent.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Cancelling a task does not automatically cause arbitrary functions on the task","type":"text"},{"text":" ","type":"text"},{"text":"to stop running or throw errors. A function ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"may"}]},{"text":" choose to react","type":"text"},{"text":" ","type":"text"},{"text":"to cancellation by ending its work early, and it is conventional to","type":"text"},{"text":" ","type":"text"},{"text":"signal that to callers by throwing ","type":"text"},{"type":"codeVoice","code":"CancellationError"},{"text":". However,","type":"text"},{"text":" ","type":"text"},{"text":"a function that doesn’t specifically check for cancellation will","type":"text"},{"text":" ","type":"text"},{"text":"run to completion normally, even if the task it is running on is","type":"text"},{"text":" ","type":"text"},{"text":"canceled. However, that function might still end early if it calls","type":"text"},{"text":" ","type":"text"},{"text":"other code that handles cancellation by throwing and that function doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"handle the error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"It’s safe to cancel a task from any task or thread. It’s safe for","type":"text"},{"text":" ","type":"text"},{"text":"multiple tasks or threads to cancel the same task at the same","type":"text"},{"text":" ","type":"text"},{"text":"time. Cancelling a task that has already been canceled has no","type":"text"},{"text":" ","type":"text"},{"text":"additional effect.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"cancel"},{"text":" may need to acquire locks and synchronously run","type":"text"},{"text":" ","type":"text"},{"text":"arbitrary cancellation-handler code associated with the","type":"text"},{"text":" ","type":"text"},{"text":"canceled task. To reduce the risk of deadlock, it is","type":"text"},{"text":" ","type":"text"},{"text":"recommended that callers release any locks they might be","type":"text"},{"text":" ","type":"text"},{"text":"holding before they call cancel.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the task has already run past the last point where it could have","type":"text"},{"text":" ","type":"text"},{"text":"performed a cancellation check, cancelling it may have no observable effects.","type":"text"}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"Task.checkCancellation()","type":"codeVoice"}]}],"name":"See Also","style":"note"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"withTaskCancellationHandler(operation:onCancel:isolation:)","type":"codeVoice"}]}],"name":"See Also","style":"note"}]}],"seeAlsoSections":[{"title":"Canceling Tasks","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/CancellationError","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/isCancelled-swift.property","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/isCancelled-swift.type.property","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/checkCancellation()","doc:\/\/com.apple.Swift\/documentation\/Swift\/withTaskCancellationHandler(handler:operation:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/withTaskCancellationHandler(operation:onCancel:isolation:)"],"anchor":"Canceling-Tasks"}],"abstract":[{"type":"text","text":"Cancels this task."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/task\/cancel()"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"symbolKind":"method","externalID":"s:ScT6cancelyyF","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"cancel"},{"kind":"text","text":"()"}],"roleHeading":"Instance Method","title":"cancel()","conformance":{"constraints":[{"type":"codeVoice","code":"Success"},{"text":" conforms to ","type":"text"},{"type":"codeVoice","code":"Sendable"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Failure"},{"text":" conforms to ","type":"text"},{"type":"codeVoice","code":"Error"},{"text":".","type":"text"}],"availabilityPrefix":[{"text":"Available when","type":"text"}],"conformancePrefix":[{"text":"Conforms when","type":"text"}]},"extendedModule":"_Concurrency","modules":[{"relatedModules":[],"name":"Swift"}],"platforms":[{"introducedAt":"8.0","unavailable":false,"beta":fa