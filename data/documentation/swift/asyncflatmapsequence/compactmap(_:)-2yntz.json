r"},{"text":">","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"transform","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An error-throwing mapping closure. "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"accepts an element of this sequence as its parameter and returns a"},{"type":"text","text":" "},{"type":"text","text":"transformed value of the same or of a different type. If "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" "},{"type":"text","text":"throws an error, the sequence ends."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"inlineContent":[{"type":"text","text":"An asynchronous sequence that contains, in order, the"},{"type":"text","text":" "},{"type":"text","text":"non-"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" elements produced by the "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" closure. The sequence"},{"type":"text","text":" "},{"type":"text","text":"ends either when the base sequence ends or when "},{"type":"codeVoice","code":"transform"},{"type":"text","text":" throws an"},{"type":"text","text":" "},{"type":"text","text":"error."}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" method to transform every element received from"},{"type":"text","text":" "},{"type":"text","text":"a base asynchronous sequence, while also discarding any "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" results"},{"type":"text","text":" "},{"type":"text","text":"from the closure. Typically, you use this to transform from one type of"},{"type":"text","text":" "},{"type":"text","text":"element to another."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In this example, an asynchronous sequence called "},{"type":"codeVoice","code":"Counter"},{"type":"text","text":" produces "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" "},{"type":"text","text":"values from "},{"type":"codeVoice","code":"1"},{"type":"text","text":" to "},{"type":"codeVoice","code":"5"},{"type":"text","text":". The closure provided to the "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" "},{"type":"text","text":"method takes each "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and looks up a corresponding "},{"type":"codeVoice","code":"String"},{"type":"text","text":" from a"},{"type":"text","text":" "},{"type":"codeVoice","code":"romanNumeralDict"},{"type":"text","text":" dictionary. Since there is no key for "},{"type":"codeVoice","code":"4"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" in this case, which "},{"type":"codeVoice","code":"compactMap(_:)"},{"type":"text","text":" omits from the"},{"type":"text","text":" "},{"type":"text","text":"transformed asynchronous sequence. When the value is "},{"type":"codeVoice","code":"5"},{"type":"text","text":", the closure"},{"type":"text","text":" "},{"type":"text","text":"throws "},{"type":"codeVoice","code":"MyError"},{"type":"text","text":", terminating the sequence."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","\/\/ Prints \"I II III Error: MyError() \""]}],"kind":"content"}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"compactMap","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementOfResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:Sci7ElementQa","text":"Element","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp","text":"ElementOfResult"},{"kind":"text","text":"?) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency31AsyncThrowingCompactMapSequenceV","text":"AsyncThrowingCompactMapSequence"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF0H8OfResultL_qd__mfp","text":"ElementOfResult"},{"kind":"text","text":">"}],"symbolKind":"method","role":"symbol","extendedModule":"_Concurrency","roleHeading":"Instance Method","title":"compactMap(_:)","externalID":"s:Sci12_ConcurrencyE10compactMapyAA020AsyncThrowingCompactC8SequenceVyxqd__Gqd__Sg7ElementQzYaKclF::SYNTHESIZED::s:12_Concurrency20AsyncFlatMapSequenceV","modules":[{"name":"Swift","relatedModules":[]}],"platforms":[{"name":"iOS","introducedAt":"8.0","deprecated":false,"unavailable":false,"beta":false},{"name":"iPadOS","introducedAt":"8.0","deprecated":false,"unavailable":false,"beta":false},{"name":"Mac Catalyst","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"10.10","deprecated":false,"unavailable":false,"beta":false},{"introd