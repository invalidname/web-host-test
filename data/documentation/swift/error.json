{"seeAlsoSections":[{"anchor":"Errors","title":"Errors","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/Result"],"generated":true}],"metadata":{"title":"Error","externalID":"s:s5ErrorP","modules":[{"name":"Swift"}],"symbolKind":"protocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Error"}],"roleHeading":"Protocol","navigatorTitle":[{"kind":"identifier","text":"Error"}],"role":"symbol","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"8.0"},{"name":"iPadOS","introducedAt":"8.0","deprecated":false,"unavailable":false,"beta":false},{"unavailable":false,"beta":false,"name":"Mac Catalyst","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"10.10","deprecated":false},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"9.0","deprecated":false},{"unavailable":false,"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"2.0","deprecated":false}]},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Error"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"A type representing an error value that can be thrown."}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","doc:\/\/com.apple.Swift\/documentation\/Swift\/SendableMetatype"]},{"kind":"relationships","title":"Inherited By","type":"inheritedBy","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActorSystemError","doc:\/\/com.apple.Swift\/documentation\/_RegexParser\/LocatedErrorProtocol"]},{"kind":"relationships","title":"Conforming Types","type":"conformingTypes","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/CancellationError","doc:\/\/com.apple.Swift\/documentation\/Swift\/DecodingError","doc:\/\/com.apple.Swift\/documentation\/_RegexParser\/DelimiterLexError","doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActorCodingError","doc:\/\/com.apple.Swift\/documentation\/Swift\/EncodingError","doc:\/\/com.apple.Swift\/documentation\/Distributed\/ExecuteDistributedTargetError","doc:\/\/com.apple.Swift\/documentation\/Distributed\/LocalTestingDistributedActorSystemError","doc:\/\/com.apple.Swift\/documentation\/Swift\/Never","doc:\/\/com.apple.Swift\/documentation\/_RegexParser\/Source\/LocatedError","doc:\/\/com.apple.Swift\/documentation\/Swift\/Unicode\/UTF8\/ValidationError","doc:\/\/com.apple.Swift\/documentation\/Swift\/Unicode\/UTF8\/ValidationError\/Kind-swift.struct","doc:\/\/com.apple.Swift\/documentation\/_RegexParser\/Unreachable","doc:\/\/com.apple.Swift\/documentation\/_RegexParser\/Unsupported"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Error"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:s8SendableP","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","kind":"typeIdentifier","text":"Sendable"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any type that declares conformance to the "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" protocol can be used to"},{"type":"text","text":" "},{"type":"text","text":"represent an error in Swift’s error handling system. Because the "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" "},{"type":"text","text":"protocol has no requirements of its own, you can declare conformance on"},{"type":"text","text":" "},{"type":"text","text":"any custom type you create."}]},{"level":1,"type":"heading","text":"Using Enumerations as Errors","anchor":"Using-Enumerations-as-Errors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift’s enumerations are well suited to represent simple errors. Create an"},{"type":"text","text":" "},{"type":"text","text":"enumeration that conforms to the "},{"type":"codeVoice","code":"Error"},{"type":"text","text":" protocol with a case for each"},{"type":"text","text":" "},{"type":"text","text":"possible error. If there are additional details about the error that could"},{"type":"text","text":" "},{"type":"text","text":"be helpful for recovery, use associated values to include that"},{"type":"text","text":" "},{"type":"text","text":"information."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"code":"IntParsingError","type":"codeVoice"},{"type":"text","text":" enumeration that captures"},{"type":"text","text":" "},{"type":"text","text":"two different kinds of errors that can occur when parsing an integer from"},{"type":"text","text":" "},{"type":"text","text":"a string: overflow, where the value represented by the string is too large"},{"type":"text","text":" "},{"type":"text","text":"for the integer data type, and invalid input, where nonnumeric characters"},{"type":"text","text":" "},{"type":"text","text":"are found within the input."}]},{"type":"codeListing","syntax":"swift","code":["enum IntParsingError: Error {","    case overflow","    case invalidInput(Character)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"invalidInput","type":"codeVoice"},{"type":"text","text":" case includes the invalid character as an associated"},{"type":"text","text":" "},{"type":"text","text":"value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The next code sample shows a possible extension to the "},{"code":"Int","type":"codeVoice"},{"type":"text","text":" type that"},{"type":"text","text":" "},{"type":"text","text":"parses the integer value of a "},{"type":"codeVoice","code":"String"},{"type":"text","text":" instance, throwing an error when"},{"type":"text","text":" "},{"type":"text","text":"there is a problem during parsing."}]},{"type":"codeListing","code":["extension Int {","    init(validating input: String) throws {","        \/\/ ...","        let c = _nextCharacter(from: input)","        if !_isValid(c) {","            throw IntParsingError.invalidInput(c)","        }","        \/\/ ...","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling the new "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" initializer within a "},{"type":"codeVoice","code":"do"},{"type":"text","text":" statement, you can use"},{"type":"text","text":" "},{"type":"text","text":"pattern matching to match specific cases of your custom error type and"},{"type":"text","text":" "},{"type":"text","text":"access their associated values, as in the example below."}]},{"type":"codeListing","code":["do {","    let price = try Int(validating: \"$100\")","} catch IntParsingError.invalidInput(let invalid) {","    print(\"Invalid character: '\\(invalid)'\")","} catch IntParsingError.overflow {","    print(\"Overflow error\")","} catch {","    print(\"Other error\")","}","\/\/ Prints \"Invalid character: '$'\""],"syntax":"swift"},{"type":"heading","level":1,"anchor":"Including-More-Data-in-Errors","text":"Including More Data in Errors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sometimes you may want different error states to include the same common"},{"type":"text","text":" "},{"type":"text","text":"data, such as the position in a file or some of your application’s state."},{"type":"text","text":" "},{"type":"text","text":"When you do, use a structure to represent errors. The following example"},{"type":"text","text":" "},{"type":"text","text":"uses a structure to represent an error when parsing an XML document,"},{"type":"text","text":" "},{"type":"text","text":"including the line and column numbers where the error occurred:"}]},{"type":"codeListing","code":["struct XMLParsingError: Error {","    enum Kind {","        case invalidCharacter","        case mismatchedTag","        case internalError","    }","","    let line: Int","    let column: Int","    let kind: Kind","}","","func parse(_ source: String) throws -> XMLDoc {","    \/\/ ...","    throw XMLParsingError(line: 19, column: 5, kind: .mismatchedTag)","    \/\/ ...","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once again, use pattern matching to conditionally catch errors. Here’s how"},{"type":"text","text":" "},{"type":"text","text":"you can catch any "},{"type":"codeVoice","code":"XMLParsingError"},{"type":"text","text":" errors thrown by the "},{"type":"codeVoice","code":"parse(_:)"},{"type":"text","text":" "},{"type":"text","text":"function:"}]},{"type":"codeListing","code":["do {","    let xmlDoc = try parse(myXMLData)","} catch let e as XMLParsingError {","    print(\"Parsing error: \\(e.kind) [\\(e.line):\\(e.column)]\")","} catch {","    print(\"Other error: \\(error)\")","}","\/\/ Prints \"Parsing error: mismatchedTag [19:5]\""],"syntax":"swift"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/error"]}],"references":{"doc://com.apple.Swift/documentation/Distributed/DistributedActorCodingError":{"url":"\/documentation\/distributed\/distributedactorcodingerror","abstract":[{"type":"text","text":"Error thrown by distributed actor systems while encountering encoding\/decoding"},{"type":"text","text":" "},{"type":"text","text":"issues."}],"title":"DistributedActorCodingError","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Distributed\/DistributedActorCodingError","navigatorTitle":[{"text":"DistributedActorCodingError","kind":"identifier"}],"fr