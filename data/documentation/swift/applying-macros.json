{"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/applying-macros","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"inlineContent":[{"text":"Swift macros help you avoid writing repetitive code in Swift","type":"text"},{"text":" ","type":"text"},{"text":"by generating that part of your source code at compile time.","type":"text"},{"text":" ","type":"text"},{"text":"Calling a macro is always additive:","type":"text"},{"text":" ","type":"text"},{"text":"The macro adds new code alongside the code that you wrote,","type":"text"},{"text":" ","type":"text"},{"text":"but never modifies or deletes code that’s already part of your project.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Many libraries provide macros,","type":"text"},{"text":" ","type":"text"},{"text":"including the Swift standard library and many frameworks.","type":"text"},{"text":" ","type":"text"},{"text":"You can also write your own macros.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because macros generate Swift code,","type":"text"},{"text":" ","type":"text"},{"text":"you use the same tools for development and debugging,","type":"text"},{"text":" ","type":"text"},{"text":"regardless of whether your code uses macros.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"macro-expansion"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Call-a-Macro","text":"Call a Macro"},{"inlineContent":[{"text":"The syntax you use to call a macro varies slightly,","type":"text"},{"text":" ","type":"text"},{"text":"depending on whether you attach the macro to a declaration.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To attach a macro to a declaration,","type":"text"},{"text":" ","type":"text"},{"text":"write an at sign (","type":"text"},{"type":"codeVoice","code":"@"},{"text":") before the macro’s name","type":"text"},{"text":" ","type":"text"},{"text":"and write any macro arguments after its name.","type":"text"},{"text":" ","type":"text"},{"text":"This syntax is the same as writing an attribute.","type":"text"},{"text":" ","type":"text"},{"text":"For example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Observable","public final class MyObject {","    public var someProperty: String = \"\"","    public var someOtherProperty: Int = 0","    fileprivate var somePrivateProperty: Int = 1","}"]},{"inlineContent":[{"text":"A macro that’s attached to a declaration","type":"text"},{"text":" ","type":"text"},{"text":"generates code","type":"text"},{"text":" ","type":"text"},{"text":"and adds that code to the declaration.","type":"text"},{"text":" ","type":"text"},{"text":"For example,","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"Observation\/Observable()"},{"text":" macro in the code above","type":"text"},{"text":" ","type":"text"},{"text":"adds additional members to the ","type":"text"},{"type":"codeVoice","code":"MyObject"},{"text":" class","type":"text"},{"text":" ","type":"text"},{"text":"so it implements the ","type":"text"},{"type":"codeVoice","code":"Observation\/Observable"},{"text":" protocol,","type":"text"},{"text":" ","type":"text"},{"text":"and marks ","type":"text"},{"type":"codeVoice","code":"MyObject"},{"text":" as conforming to ","type":"text"},{"type":"codeVoice","code":"Observable"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To call a macro without attaching it to a declaration,","type":"text"},{"text":" ","type":"text"},{"text":"write a number sign (","type":"text"},{"type":"codeVoice","code":"#"},{"text":") before the macro’s name","type":"text"},{"text":" ","type":"text"},{"text":"and write any macro arguments after its name.","type":"text"},{"text":" ","type":"text"},{"text":"This syntax is the same as ","type":"text"},{"type":"codeVoice","code":"#if"},{"text":" and other compile-time operations.","type":"text"},{"text":" ","type":"text"},{"text":"For example:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let messagePredicate = #Predicate<Message> { message in","    message.recipient == \"John Appleseed\"","}"]},{"inlineContent":[{"text":"A macro that isn’t attached to a declaration","type":"text"},{"text":" ","type":"text"},{"text":"generates code and adds that code","type":"text"},{"text":" ","type":"text"},{"text":"in the location where where you call the macro.","type":"text"},{"text":" ","type":"text"},{"text":"For example,","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"codeVoice","code":"Predicate"},{"text":" macro in the code above creates an instance of the","type":"text"},{"text":" ","type":"text"},{"text":"Swift Foundation ","type":"text"},{"type":"codeVoice","code":"Predicate"},{"text":" structure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For more information,","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros"},{"text":" in ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language"},{"text":".","type":"text"}],"type":"paragraph"},{"level":3,"type":"heading","anchor":"Inspect-an-Expanded-Macro","text":"Inspect an Expanded Macro"},{"inlineContent":[{"text":"When you build your project,","type":"text"},{"text":" ","type":"text"},{"text":"Swift reads your code and finds the places where you call a macro.","type":"text"},{"text":" ","type":"text"},{"text":"Swift then calls the implementation of each macro,","type":"text"},{"text":" ","type":"text"},{"text":"to expand the code.","type":"text"},{"text":" ","type":"text"},{"text":"Finally, Swift builds your project as usual,","type":"text"},{"text":" ","type":"text"},{"text":"including the generated code.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To view the code that a macro generated,","type":"text"},{"text":" ","type":"text"},{"text":"click on the code where you call the macro in Xcode,","type":"text"},{"text":" ","type":"text"},{"text":"then choose Editor > Expand Macro.","type":"text"},{"text":" ","type":"text"},{"text":"You can read the expanded code","type":"text"},{"text":" ","type":"text"},{"text":"to help you understand details about the macro’s behavior,","type":"text"},{"text":" ","type":"text"},{"text":"and you can use the expanded code","type":"text"},{"text":" ","type":"text"},{"text":"to help you debug code that uses macros.","type":"text"},{"text":" ","type":"text"},{"text":"For example,","type":"text"},{"text":" ","type":"text"},{"text":"you can set breakpoints inside code generated by a macro.","type":"text"}],"type":"paragraph"}]}],"metadata":{"modules":[{"name":"Swift"}],"role":"article","roleHeading":"Article","title":"Applying Macros"},"abstract":[{"type":"text","text":"Use macros to generate repetitive code at compile time."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/applying-macros"]}],"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","doc:\/\/com.apple.Swift\/documentation\/Swift\/macros"]]},"references":{"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","type":"topic","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/macros":{"role":"collectionGroup","url":"\/documentation\/swift\/macros","type":"topic","abstract":[{"type":"text","text":"Generate boilerplate code and perform other compile-time operations."}],"title":"Macros","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/macros","kind":"article"},"Swift-PageImage-card.png":{"alt":"An orange Swift logo on a gradient background.","identifier":"Swift-PageImage-card.png","type":"image","variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png","traits":["2x","dark"]}]},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language":{"title":"The Swift Programming Language","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language","titleInlineContent":[{"type":"text","text":"The Swift Programming Language"}],"type":"link","url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language"},"macro-expansion":{"alt":"A diagram showing an overview of macro expansion. On the left, a stylized representation of Swift code. On the right, the same code with several lines added by the macro.","identifier":"macro-expansion","type":"image","variants":[{"url":"\/images\/com.apple.Swift\/macro-expansion@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/macro-expansion~dark@2x.png","traits":["2x","dark"]}]},"doc://com.apple.Swift/documentation/Swift/swift-standard-library":{"role":"collectionGroup","url":"\/documentation\/swift\/swift-standard-library","type":"topic","abstract":[{"type":"text","text":"Solve complex problems and write high-performance, readable code."}],"title":"Swift Standard Library","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","kind":"article"},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language/macros":{"title":"Macros","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros","titleInlineContent":[{"type":"text","text":"Macros"}],"type":"link","url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros"}}}