{"abstract":[{"type":"text","text":"Use macros to generate repetitive code at compile time."}],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Swift macros help you avoid writing repetitive code in Swift"},{"type":"text","text":" "},{"type":"text","text":"by generating that part of your source code at compile time."},{"type":"text","text":" "},{"type":"text","text":"Calling a macro is always additive:"},{"type":"text","text":" "},{"type":"text","text":"The macro adds new code alongside the code that you wrote,"},{"type":"text","text":" "},{"type":"text","text":"but never modifies or deletes code that’s already part of your project."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Many libraries provide macros,"},{"type":"text","text":" "},{"type":"text","text":"including the Swift standard library and many frameworks."},{"type":"text","text":" "},{"type":"text","text":"You can also write your own macros."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because macros generate Swift code,"},{"type":"text","text":" "},{"type":"text","text":"you use the same tools for development and debugging,"},{"type":"text","text":" "},{"type":"text","text":"regardless of whether your code uses macros."}]},{"type":"paragraph","inlineContent":[{"type":"image","identifier":"macro-expansion"}]},{"anchor":"Call-a-Macro","type":"heading","text":"Call a Macro","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The syntax you use to call a macro varies slightly,"},{"type":"text","text":" "},{"type":"text","text":"depending on whether you attach the macro to a declaration."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To attach a macro to a declaration,"},{"type":"text","text":" "},{"type":"text","text":"write an at sign ("},{"type":"codeVoice","code":"@"},{"type":"text","text":") before the macro’s name"},{"type":"text","text":" "},{"type":"text","text":"and write any macro arguments after its name."},{"type":"text","text":" "},{"type":"text","text":"This syntax is the same as writing an attribute."},{"type":"text","text":" "},{"type":"text","text":"For example:"}]},{"type":"codeListing","code":["@Observable","public final class MyObject {","    public var someProperty: String = \"\"","    public var someOtherProperty: Int = 0","    fileprivate var somePrivateProperty: Int = 1","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A macro that’s attached to a declaration"},{"type":"text","text":" "},{"type":"text","text":"generates code"},{"type":"text","text":" "},{"type":"text","text":"and adds that code to the declaration."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","isActive":true},{"type":"text","text":" macro in the code above"},{"type":"text","text":" "},{"type":"text","text":"adds additional members to the "},{"type":"codeVoice","code":"MyObject"},{"type":"text","text":" class"},{"type":"text","text":" "},{"type":"text","text":"so it implements the "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","isActive":true},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"and marks "},{"type":"codeVoice","code":"MyObject"},{"type":"text","text":" as conforming to "},{"type":"codeVoice","code":"Observable"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To call a macro without attaching it to a declaration,"},{"type":"text","text":" "},{"type":"text","text":"write a number sign ("},{"type":"codeVoice","code":"#"},{"type":"text","text":") before the macro’s name"},{"type":"text","text":" "},{"type":"text","text":"and write any macro arguments after its name."},{"type":"text","text":" "},{"type":"text","text":"This syntax is the same as "},{"type":"codeVoice","code":"#if"},{"type":"text","text":" and other compile-time operations."},{"type":"text","text":" "},{"type":"text","text":"For example:"}]},{"type":"codeListing","code":["let messagePredicate = #Predicate<Message> { message in","    message.recipient == \"John Appleseed\"","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A macro that isn’t attached to a declaration"},{"type":"text","text":" "},{"type":"text","text":"generates code and adds that code"},{"type":"text","text":" "},{"type":"text","text":"in the location where where you call the macro."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"Predicate"},{"type":"text","text":" macro in the code above creates an instance of the"},{"type":"text","text":" "},{"type":"text","text":"Swift Foundation "},{"type":"codeVoice","code":"Predicate"},{"type":"text","text":" structure."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more information,"},{"type":"text","text":" "},{"type":"text","text":"see "},{"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros","isActive":true},{"type":"text","text":" in "},{"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language","isActive":true},{"type":"text","text":"."}]},{"anchor":"Inspect-an-Expanded-Macro","type":"heading","text":"Inspect an Expanded Macro","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you build your project,"},{"type":"text","text":" "},{"type":"text","text":"Swift reads your code and finds the places where you call a macro."},{"type":"text","text":" "},{"type":"text","text":"Swift then calls the implementation of each macro,"},{"type":"text","text":" "},{"type":"text","text":"to expand the code."},{"type":"text","text":" "},{"type":"text","text":"Finally, Swift builds your project as usual,"},{"type":"text","text":" "},{"type":"text","text":"including the generated code."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To view the code that a macro generated,"},{"type":"text","text":" "},{"type":"text","text":"click on the code where you call the macro in Xcode,"},{"type":"text","text":" "},{"type":"text","text":"then choose Editor > Expand Macro."},{"type":"text","text":" "},{"type":"text","text":"You can read the expanded code"},{"type":"text","text":" "},{"type":"text","text":"to help you understand details about the macro’s behavior,"},{"type":"text","text":" "},{"type":"text","text":"and you can use the expanded code"},{"type":"text","text":" "},{"type":"text","text":"to help you debug code that uses macros."},{"type":"text","text":" "},{"type":"text","text":"For example,"},{"type":"text","text":" "},{"type":"text","text":"you can set breakpoints inside code generated by a macro."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/applying-macros"},"metadata":{"role":"article","modules":[{"name":"Swift"}],"title":"Applying Macros","roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","doc:\/\/com.apple.Swift\/documentation\/Swift\/macros"]]},"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"doc://com.apple.Swift/documentation/Swift/swift-standard-library":{"role":"collectionGroup","url":"\/documentation\/swift\/swift-standard-library","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/swift-standard-library","type":"topic","title":"Swift Standard Library","kind":"article","abstract":[{"text":"Solve complex problems and write high-performance, readable code.","type":"text"}]},"macro-expansion":{"type":"image","alt":"A diagram showing an overview of macro expansion. On the left, a stylized representation of Swift code. On the right, the same code with several lines added by the macro.","identifier":"macro-expansion","variants":[{"url":"\/images\/com.apple.Swift\/macro-expansion@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/macro-expansion~dark@2x.png","traits":["2x","dark"]}]},"doc://com.apple.Swift/documentation/Observation/Observable":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observable"}],"url":"\/documentation\/observation\/observable","identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable","navigatorTitle":[{"kind":"identifier","text":"Observable"}],"type":"topic","title":"Observable","kind":"symbol","abstract":[{"type":"text","text":"A type that emits notifications to observers when underlying data changes."}]},"doc://com.apple.Swift/documentation/Observation/Observable()":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Observation\/Observable()","title":"Observable()","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Defines and implements conformance of the Observable protocol."}],"fragments":[{"kind":"keyword","text":"macro"},{"kind":"text","text":" "},{"kind":"identifier","text":"Observable"},{"kind":"text","text":"()"}],"url":"\/documentation\/observation\/observable()","role":"symbol"},"Swift-PageImage-card.png":{"type":"image","alt":"An orange Swift logo on a gradient background.","identifier":"Swift-PageImage-card.png","variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png","traits":["2x","dark"]}]},"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language":{"type":"link","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language","title":"The Swift Programming Language","titleInlineContent":[{"type":"text","text":"The Swift Programming Language"}],"url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language"},"doc://com.apple.Swift/documentation/Swift/macros":{"url":"\/documentation\/swift\/macros","abstract":[{"text":"Generate boilerplate code and perform other compile-time operations.","type":"text"}],"title":"Macros","kind":"article","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/macros","type":"topic","role":"collectionGroup"},"https://docs.swift.org/swift-book/documentation/the-swift-programming-language/macros":{"type":"link","identifier":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros","title":"Macros","titleInlineContent":[{"text":"Macros","type":"text"}],"url":"https:\/\/docs.swift.org\/swift-book\/documentation\/the-swift-programming-language\/macros"}}}