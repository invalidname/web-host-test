oundedRange"]}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BitwiseCopyable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnboundedRange_","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"inlineContent":[{"text":"You can use the unbounded range operator (","type":"text"},{"type":"codeVoice","code":"..."},{"text":") to create a slice of a","type":"text"},{"text":" ","type":"text"},{"text":"collection that contains all of the collection’s elements. Slicing with an","type":"text"},{"text":" ","type":"text"},{"text":"unbounded range is essentially a conversion of a collection instance into","type":"text"},{"text":" ","type":"text"},{"text":"its slice type.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, the following code declares ","type":"text"},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"text":", a","type":"text"},{"text":" ","type":"text"},{"text":"function that finds the number of changes required to change one","type":"text"},{"text":" ","type":"text"},{"text":"word or phrase into another. The function uses a recursive approach to","type":"text"},{"text":" ","type":"text"},{"text":"perform the same comparisons on smaller and smaller pieces of the original","type":"text"},{"text":" ","type":"text"},{"text":"strings. In order to use recursion without making copies of the strings at","type":"text"},{"text":" ","type":"text"},{"text":"each step, ","type":"text"},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"text":" uses ","type":"text"},{"type":"codeVoice","code":"Substring"},{"text":", a string’s slice","type":"text"},{"text":" ","type":"text"},{"text":"type, for its parameters.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["func countLetterChanges(_ s1: Substring, _ s2: Substring) -> Int {","    if s1.isEmpty { return s2.count }","    if s2.isEmpty { return s1.count }","","    let cost = s1.first == s2.first ? 0 : 1","","    return min(","        countLetterChanges(s1.dropFirst(), s2) + 1,","        countLetterChanges(s1, s2.dropFirst()) + 1,","        countLetterChanges(s1.dropFirst(), s2.dropFirst()) + cost)","}"],"syntax":"swift"},{"inlineContent":[{"text":"To call ","type":"text"},{"type":"codeVoice","code":"countLetterChanges(_:_:)"},{"text":" with two strings, use an unbounded","type":"text"},{"text":" ","type":"text"},{"text":"range in each string’s subscript.","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["let word1 = \"grizzly\"","let word2 = \"grisly\"","let changes = countLetterChanges(word1[...], word2[...])","\/\/ changes == 2"],"syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/unboundedrange_"]}],"references":{"doc://com.apple.Swift/documentation/Swift/UnboundedRange":{"url":"\/documentation\/swift\/unboundedrange","abstract":[{"text":"The type of an unbounded range operator.","type":"text"}],"title":"UnboundedRange","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UnboundedRange","navigatorTitle":[{"text":"UnboundedRange","kind":"identifier"}],"fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnboundedRange","kind":"identifier"}],"type":"topic","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/PartialRangeUpTo":{"url":"\/documentation\/swift\/partialrangeupto","abstract":[{"text":"A partial half-open interval up to, but not including, an upper bound.","type":"text"}],"title":"PartialRangeUpTo","kind":"symbol","identifier":"doc:\/\/com.apple.Sw