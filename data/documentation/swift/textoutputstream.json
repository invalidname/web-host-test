{"abstract":[{"type":"text","text":"A type that can be the target of text-streaming operations."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TextOutputStream","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"You can send the output of the standard library’s ","type":"text"},{"type":"codeVoice","code":"print(_:to:)"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"dump(_:to:)"},{"text":" functions to an instance of a type that conforms to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TextOutputStream"},{"text":" protocol instead of to standard output. Swift’s","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" type conforms to ","type":"text"},{"type":"codeVoice","code":"TextOutputStream"},{"text":" already, so you can capture","type":"text"},{"text":" ","type":"text"},{"text":"the output from ","type":"text"},{"type":"codeVoice","code":"print(_:to:)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"dump(_:to:)"},{"text":" in a string instead of","type":"text"},{"text":" ","type":"text"},{"text":"logging it to standard output.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["var s = \"\"","for n in 1...5 {","    print(n, terminator: \"\", to: &s)","}","\/\/ s == \"12345\""]},{"type":"heading","text":"Conforming to the TextOutputStream Protocol","level":1,"anchor":"Conforming-to-the-TextOutputStream-Protocol"},{"type":"paragraph","inlineContent":[{"text":"To make your custom type conform to the ","type":"text"},{"type":"codeVoice","code":"TextOutputStream"},{"text":" protocol,","type":"text"},{"text":" ","type":"text"},{"text":"implement the required ","type":"text"},{"type":"codeVoice","code":"write(_:)"},{"text":" method. Functions that use a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"TextOutputStream"},{"text":" target may call ","type":"text"},{"type":"codeVoice","code":"write(_:)"},{"text":" multiple times per writing","type":"text"},{"text":" ","type":"text"},{"text":"operation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"As an example, here’s an implementation of an output stream that converts","type":"text"},{"text":" ","type":"text"},{"text":"any input to its plain ASCII representation before sending it to standard","type":"text"},{"text":" ","type":"text"},{"text":"output.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ASCIILogger: TextOutputStream {","    mutating func write(_ string: String) {","        let ascii = string.unicodeScalars.lazy.map { scalar in","            scalar == \"\\n\"","              ? \"\\n\"","              : scalar.escaped(asASCII: true)","        }","        print(ascii.joined(separator: \"\"), terminator: \"\")","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"ASCIILogger"},{"text":" type’s ","type":"text"},{"type":"codeVoice","code":"write(_:)"},{"text":" method processes its string input by","type":"text"},{"text":" ","type":"text"},{"text":"escaping each Unicode scalar, with the exception of ","type":"text"},{"type":"codeVoice","code":"\"\\n\""},{"text":" line returns.","type":"text"},{"text":" ","type":"text"},{"text":"By sending the output of the ","type":"text"},{"type":"codeVoice","code":"print(_:to:)"},{"text":" function to an instance of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"ASCIILogger"},{"text":", you invoke its ","type":"text"},{"type":"codeVoice","code":"write(_:)"},{"text":" method.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let s = \"Hearts ♡ and Diamonds ♢\"","print(s)","\/\/ Prints \"Hearts ♡ and Diamonds ♢\"","","var asciiLogger = ASCIILogger()","print(s, to: &asciiLogger)","\/\/ Prints \"Hearts \\u{2661} and Diamonds \\u{2662}\""]}],"kind":"content"}],"relationshipsSections":[{"title":"Inherited By","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/StringProtocol"],"type":"inheritedBy","kind":"relationships"},{"title":"Conforming Types","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/DefaultStringInterpolation","doc:\/\/com.apple.Swift\/documentation\/Swift\/String","doc:\/\/com.apple.Swift\/documentation\/Swift\/Substring"],"type":"conformingTypes","kind":"relationships"}],"variants":[{"paths":["\/documentation\/swift\/textoutputstream"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TextOutputStream"},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"TextOutputStream"}],"modules":[{"name":"Swift"}],"externalID":"s:s16TextOutputStreamP","navigatorTitle":[{"kind":"identifier","text":"TextOutputStream"}],"roleHeading":"Protocol","symbolKind":"protocol","title":"TextOutputStream","platforms":[{"introducedAt":"8.0","unavailable":false,"beta":false,"deprecated":false,"name":"iOS"},{"introducedAt":"8.0","unavailable":false,"beta":false,"deprecated":false,"name":"iPadOS"},{"introducedAt":"13.0","unavailable":false,"beta":false,"deprecated":false,"name":"Mac Catalyst"},{"introducedAt":"10.10","unavailable":false,"beta":false,"deprecated":false,"name":"macOS"},{"introducedAt":"9.0","unavailable":false,"beta":false,"deprecated":false,"name":"tvOS"},{"introducedAt":"1.0","unavailable":false,"beta":false,"deprecated":false,"name":"visionOS"},{"introducedAt":"2.0","unavailable":false,"beta":false,"deprecated":false,"name":"watchOS"}]},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"topicSections":[{"title":"Instance Methods","identifiers":["doc:\/\/com.app