osua\", \"Kofi\", \"Kweku\", \"Peter\"]\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"To sort the elements of your sequence in descending order, pass the","type":"text"},{"text":" ","type":"text"},{"text":"greater-than operator (","type":"text"},{"code":">","type":"codeVoice"},{"text":") to the ","type":"text"},{"code":"sorted(by:)","type":"codeVoice"},{"text":" method.","type":"text"}]},{"type":"codeListing","code":["let descendingStudents = students.sorted(by: >)","print(descendingStudents)","\/\/ Prints \"[\"Peter\", \"Kweku\", \"Kofi\", \"Akosua\", \"Abena\"]\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The sorting algorithm is guaranteed to be stable. A stable sort","type":"text"},{"text":" ","type":"text"},{"text":"preserves the relative order of elements that compare as equal.","type":"text"}]},{"name":"Complexity","content":[{"inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" log ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" is the length of the sequence.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/DiscontiguousSlice\/sorted()","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Instance Method","externalID":"s:STsSL7ElementRpzrlE6sortedSayABGyF::SYNTHESIZED::s:s18DiscontiguousSliceV","extendedModule":"Swift","platforms":[{"beta":false,"name":"iOS","introducedAt":"8.0","deprecated":false,"unavailable":false},{"beta":false,"name":"iPadOS","introducedAt":"8.0","deprecated":false,"unavailable":false},{"beta":false,"name":"Mac Catalyst","introducedAt":"13.0","deprecated":false,"unavailable":false},{"beta":false,"name":"macOS","introducedAt":"10.10","deprecated":false,"unavailable":false},{"be