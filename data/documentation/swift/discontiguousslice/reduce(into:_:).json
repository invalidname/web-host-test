t"},{"type":"text","text":" is the result of the call to"},{"type":"text","text":" "},{"type":"codeVoice","code":"reduce(into:_:)"},{"type":"text","text":"."}]},{"name":"Complexity","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":" is the length of the sequence."}]}],"type":"aside","style":"note"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/DiscontiguousSlice\/reduce(into:_:)"},"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reduce"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Result"},{"kind":"text","text":">("},{"kind":"externalParam","text":"into"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF6ResultL_qd__mfp"},{"kind":"text","text":", ("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"partialResult"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF6ResultL_qd__mfp"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:ST7ElementQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> ()) "},{"kind":"keyword","text":"rethrows"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Result","preciseIdentifier":"s:STsE6reduce4into_qd__qd__n_yqd__z_7ElementQztKXEtKlF6ResultL_qd__mfp"}],"symbolKind":"method","role":"symbol","extendedModule":"Swift","roleHeading":"Instance Method","title":"reduce(into:_:)","externalID":"s