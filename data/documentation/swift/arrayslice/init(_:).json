{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ArraySlice\/init(_:)"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/ArraySlice"]]},"abstract":[{"text":"Creates an array containing the elements of a sequence.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/arrayslice\/init(_:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"s"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s10ArraySliceVyAByxGqd__c7ElementQyd__RszSTRd__lufc1SL_qd__mfp","kind":"typeIdentifier","text":"S"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Element"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":"."},{"preciseIdentifier":"s:ST7ElementQa","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence\/Element","kind":"typeIdentifier","text":"Element"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:ST","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence","kind":"typeIdentifier","text":"Sequence"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"s","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The sequence of elements to turn into an array."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You