{"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ArraySlice\/capacity","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/ArraySlice"]]},"abstract":[{"text":"The total number of elements that the array can contain without","type":"text"},{"text":" ","type":"text"},{"text":"allocating new storage.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/swift\/arrayslice\/capacity"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"capacity","kind":"identifier"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Int","preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Every array reserves a specific amount of memory to hold its contents.","type":"text"},{"text":" ","type":"text"},{"text":"When you add elements to an array and that array begins to exceed its","type":"text"},{"text":" ","type":"text"},{"text":"reserved capacity, the array allocates a larger region of memory and","type":"text"},{"text":" ","type":"text"},{"text":"copies its elements into the new storage. The new storage is a multiple","type":"text"},{"text":" ","type":"text"},{"text":"of the old storage’s size. This exponential growth strategy means that","type":"text"},{"text":" ","type":"text"},{"text":"appending an element happens in constant time, averaging the performance","type":"text"},{"text":" ","type":"text"},{"text":"of many append operations. Append operations that trigger reallocation","type":"text"},{"text":" ","type":"text"},{"text":"have a performance cost, but they occur less and less often as the array","type":"text"},{"text":" ","type":"text"},{"text":"grows larger.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example creates an array of integers from an array literal,","type":"text"},{"text":" ","type":"text"},{"text":"then appends the elements of another collection. Before appending, the","type":"text"},{"text":" ","type":"text"},{"text":"array allocates new storage that is large enough store the resulting","type":"text"},{"text":" ","type":"text"},{"text":"elements.","type":"text"}]},{"code":["var numbers = [10, 20, 30, 40, 50]","\/\/ numbers.count == 5","\/\/ numbers.capacity == 5","","numbers.append(contentsOf: stride(from: 60, through: 100, by: 10))","\/\/ numbers.count == 10","\/\/ numbers.capacity == 10"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"modules":[{"name":"Swift"}],"role":"symbol","platforms":[{"beta":false,"name":"iOS","introducedAt":"8.0","deprecated":false,"unavailable":false},{"beta":false,"name":"iPadOS","introducedAt":"8.0","deprecated":false,"unavailable":false},{"beta":false,"name":"Mac Catalyst","introducedAt":"13.0","deprecated":false,"unavailable":false},{"beta":false,"name":"macOS","introducedAt":"10.10","deprecated":false,"unavailable":false},{"beta":false,"name":"tvOS","introducedAt":"9.0","deprecated":false,"unavailable":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false,"unavailable":false},{"beta":false,"name":"watchOS","introducedAt":"2.0","deprecated":false,"unavailable":false}],"roleHeading":"Instance Property","symbolKind":"property","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"capacity","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"}],"title":"capacity","externalID":"s:s10ArraySl