ple.Swift\/documentation\/Swift\/Void"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> sending "},{"kind":"typeIdentifier","text":"T","preciseIdentifier":"s:12_Concurrency31withCheckedThrowingContinuation9isolation8function_xScA_pSgYi_SSyScCyxs5Error_pGXEtYaKlF1TL_xmfp"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A string identifying the declaration that is the notional"},{"type":"text","text":" "},{"type":"text","text":"source for the continuation, used to identify the continuation in"},{"type":"text","text":" "},{"type":"text","text":"runtime diagnostics related to misuse of this continuation."}]}],"name":"function"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that takes a "},{"type":"codeVoice","code":"CheckedContinuation"},{"type":"text","text":" parameter."}]}],"name":"body"}],"kind":"parameters"},{"content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The value continuation is resumed with."}]}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The body of the closure executes synchronously on the calling task, and once it returns"},{"type":"text","text":" "},{"type":"text","text":"the calling task is suspended. It is possible to immediately resume the task, or escape the"},{"type":"text","text":" "},{"type":"text","text":"continuation in order to complete it afterwards, which will then resume the suspended task."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"resume(throwing:)"},{"type":"text","text":" is called on the continuation, this function throws that error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You must invoke the continuation’s "},{"type":"codeVoice","code":"resume"},{"type":"text","text":" method exactly once."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Missing to invoke it (eventually) will cause the calling task to remain suspended"},{"type":"text","text":" "},{"type":"text","text":"indefinitely which will result in the task “hanging” as well as being leaked with"},{"type":"text","text":" "},{"type":"text","text":"no possibility to destroy it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The checked continuation offers detection of misuse, and dropping the last reference"},{"type":"text","text":" "},{"type":"text","text":"to it, without having resumed it will trigger a warning. Resuming a continuation twice"},{"type":"text","text":" "},{"type":"text","text":"is also diagnosed and will cause a crash."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"withCheckedContinuation(function:_:)"}]}],"type":"aside","style":"note","name":"See Also"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"withUnsafeContinuation(function:_:)"}]}],"type":"aside","style":"note","name":"See Also"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"withUnsafeThrowingContinuation(function:_:)"}]}],"type":"aside","style":"note","name":"See Also"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/withcheckedthrowingcontinuation(isolation:function:_:)"]}],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/withCheckedThrowingContinuation(isolation:function:_:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"withCheckedThrowingContinuation"},{"kind":"text