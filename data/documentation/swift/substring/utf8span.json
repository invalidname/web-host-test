{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"UTF8Span"},{"text":" over the code units of this substring.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"content":[{"inlineContent":[{"text":"In the case of bridged UTF-16 string instances (on Apple","type":"text"},{"text":" ","type":"text"},{"text":"platforms) this property needs to transcode the code units every time","type":"text"},{"text":" ","type":"text"},{"text":"it’s called.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note","type":"aside"},{"inlineContent":[{"text":"For example, if ","type":"text"},{"type":"codeVoice","code":"string"},{"text":" has the bridged UTF-16 representation,","type":"text"},{"text":" ","type":"text"},{"text":"the following code is accidentally quadratic because of this issue:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["for word in string.split(separator: \" \") {","    useSpan(word.span)","}"],"type":"codeListing"},{"inlineContent":[{"text":"A workaround is to explicitly convert the string into its native UTF-8","type":"text"},{"text":" ","type":"text"},{"text":"representation:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var nativeString = consume string","nativeString.makeContiguousUTF8()","for word in nativeString.split(separator: \" \") {","    useSpan(word.span)","}"],"type":"codeListing"},{"inlineContent":[{"text":"This second option has linear time complexity, as expected.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"O(1) for native UTF-8 strings, O(n) for bridged UTF-16","type":"text"},{"text":" ","type":"text"},{"text":"strings.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Complexity","type":"aside"}]}],"variants":[{"paths":["\/documentation\/swift\/subst