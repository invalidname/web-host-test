ontent"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"If you call this function from the body of an asynchronous function,","type":"text"},{"text":" ","type":"text"},{"text":"the unsafe task handle passed to the closure is always non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" ","type":"text"},{"text":"because an asynchronous function always runs in the context of a task.","type":"text"},{"text":" ","type":"text"},{"text":"However, if you call this function from the body of a synchronous function,","type":"text"},{"text":" ","type":"text"},{"text":"and that function isn’t executing in the context of any task,","type":"text"},{"text":" ","type":"text"},{"text":"the unsafe task handle is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Don’t store an unsafe task reference","type":"text"},{"text":" ","type":"text"},{"text":"for use outside this method’s closure.","type":"text"},{"text":" ","type":"text"},{"text":"Storing an unsafe reference doesn’t affect the task’s actual life cycle,","type":"text"},{"text":" ","type":"text"},{"text":"and the behavior of accessing an unsafe task reference","type":"text"},{"text":" ","type":"text"},{"text":"outside of the ","type":"text"},{"code":"withUnsafeCurrentTask(body:)","type":"codeVoice"},{"text":" method’s closure isn’t defined.","type":"text"},{"text":" ","type":"text"},{"text":"There’s no safe way to retrieve a reference to the current task","type":"text"},{"text":" ","type":"text"},{"text":"and save it for long-term use.","type":"text"},{"text":" ","type":"text"},{"text":"To query the current task without saving a reference to it,","type":"text"},{"text":" ","type":"text"},{"text":"use properties like ","type":"text"},{"code":"currentPriority","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"If you need to store a reference to a task,","type":"text"},{"text":" ","type":"text"},{"text":"create an unstructured task using ","type":"text"},{"code":"Task.detached(priority:operation:)","type":"codeVoice"},{"text":" instead.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","abstract":[{"text":"Calls a closure with an unsafe reference to the current task.","type":"text"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/withUnsafeCurrentTask(body:)-2cbzn"],"anchor":"Getting-an-Unsafe-Reference-to-the-Current-Task","title":"Getting an Unsafe Reference to the Current Task"}],"references":{"doc://com.apple.Swift/documentation/Swift/withUnsafeCurrentTask(body:)-2cbzn":{"title":"withUnsafeCurrentTask(body:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withUnsafeCurrentTask","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"body","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"UnsafeCurrentTask","kind":"typeIdentifier","preciseIdentifier":"s:Sct"},{"text":"?) ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withUnsafeCurrentTask4bodyxxSctSgYaKXE_tYaKlF1TL_xmfp"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withUnsafeCurrentTask4bodyxxSctSgYaKXE_tYaKlF1TL_xmfp"}],"abstract":[],"url":"\/documentation\/swift\/withunsafecurrenttask(body:)-2cbzn","role":"symbol","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/withUnsafeCurrentTask(body:)-2cbzn"},"Swift-PageImage-card.png":{"alt":"An orange Swift logo on a gradient background.