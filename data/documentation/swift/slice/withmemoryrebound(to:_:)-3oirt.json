ult","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:s5SliceVsSwRszrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_Sryqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF1EL_qd_0_mfp","text":"E","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s5SliceVsSwRszrlE17withMemoryRebound2to_qd_1_qd__m_qd_1_Sryqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF6ResultL_qd_1_mfp","text":"Result","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"E","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:s5ErrorP","text":"Error","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Error","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":" : ~Copyable, ","kind":"text"},{"text":"Result","kind":"typeIdentifier"},{"text":" : ~Copyable","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"type","content":[{"inlineContent":[{"type":"text","text":"The type to temporarily bind the memory referenced by this"},{"type":"text","text":" "},{"type":"text","text":"buffer slice."}],"type":"paragraph"}]},{"name":"body","content":[{"inlineContent":[{"type":"text","text":"A closure that takes a typed pointer to the"},{"type":"text","text":" "},{"type":"text","text":"same memory as this pointer, only bound to type "},{"code":"T","type":"codeVoice"},{"type":"text","text":". The closure’s"},{"type":"text","text":" "},{"type":"text","text":"pointer argument is valid only for the duration of the closure’s"},{"type":"text","text":" "},{"type":"text","text":"execution. If "},{"code":"body","type":"codeVoice"},{"type":"text","text":" has a return value, that value is also used as"},{"type":"text","text":" "},{"type":"text","text":"the return value for the "},{"code":"withMemoryRebound(to:capacity:_:)","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"anchor":"return-value","text":"Return Value","type":"heading"},{"inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure parameter."}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Use this method when you have a buffer slice to raw memory and you need"},{"type":"text","text":" "},{"type":"text","text":"to access that memory as instances of a given type "},{"code":"T","type":"codeVoice"},{"type":"text","text":". Accessing"},{"type":"text","text":" "},{"type":"text","text":"memory as a type "},{"code":"T","type":"codeVoice"},{"type":"text","text":" requires that the memory be bound to that type."},{"type":"text","text":" "},{"type":"text","text":"A memory location may only be bound to one type at a time, so accessing"},{"type":"text","text":" "},{"type":"text","text":"the same memory as an unrelated type without first rebinding the memory"},{"type":"text","text":" "},{"type":"text","text":"is undefined."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Any instance of "},{"code":"T","type":"codeVoice"},{"type":"text","text":" within the re-bound region may be initialized or"},{"type":"text","text":" "},{"type":"text","text":"uninitialized. The memory underlying any individual instance of "},{"code":"T","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"must have the same initialization state (i.e.  initialized or"},{"type":"text","text":" "},{"type":"text","text":"uninitialized.) Accessing a "},{"code":"T","type":"codeVoice"},{"type":"text","text":" whose underlying memory"},{"type":"text","text":" "},{"type":"text","text":"is in a mixed initialization state shall be undefined behaviour."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the byte count of the original buffer slice is not a multiple of"},{"type":"text","text":" "},{"type":"text","text":"the stride of "},{"code":"T","type":"codeVoice"},{"type":"text","text":", then the re-bound buffer is shorter"},{"type":"text","text":" "},{"type":"text","text":"than the original buffer."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"After executing "},{"code":"body","type":"codeVoice"},{"type":"text","text":", this method rebinds memory back to its original"},{"type":"text","text":" "},{"type":"text","text":"binding state. This can be unbound memory, or bound to a different type."}],"type":"paragraph"},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"The buffer slice’s start address must match the"},{"type":"text","text":" "},{"type":"text","text":"alignment of "},{"code":"T","type":"codeVoice"},{"type":"text","text":" (as reported by "},{"code":"MemoryLayout<T>.alignment","type":"codeVoice"},{"type":"text","text":"). That is,"},{"type":"text","text":" "},{"code":"Int(bitPattern: base.baseAddress+startIndex) % MemoryLayout<T>.alignment","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"must equal zero."}],"type":"paragraph"}],"type":"aside"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"A raw buffer slice may represent memory that has been bound to","type":"text"},{"text":" ","type":"text"},{"text":"a type. If that is the case, then ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" must be layout compatible with the","type":"text"},{"text":" ","type":"text"},{"text":"type to which the memory has been bound. This requirement does not","type":"text"},{"text":" ","type":"text"},{"text":"apply if the raw buffer represents memory that has not been bound","type":"text"},{"text":" ","type":"text"},{"text":"to any type.","type":"text"}],"type":"paragraph"}],"type":"aside"}]}],"variants":[{"traits":[{"interfac