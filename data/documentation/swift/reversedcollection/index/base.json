{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/reversedcollection\/index\/base"]}],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/ReversedCollection","doc:\/\/com.apple.Swift\/documentation\/Swift\/ReversedCollection\/Index"]]},"kind":"symbol","sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"base","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp","text":"Base","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Collection\/Index","preciseIdentifier":"s:Sl5IndexQa","text":"Index","kind":"typeIdentifier"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"To find the position that corresponds with this index in the original,","type":"text"},{"text":" ","type":"text"},{"text":"underlying collection, use that collection’s ","type":"text"},{"code":"index(before:)","type":"codeVoice"},{"text":" method","type":"text"},{"text":" ","type":"text"},{"text":"with the ","type":"text"},{"code":"base","type":"codeVoice"},{"text":" property.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example declares a function that returns the index of the","type":"text"},{"text":" ","type":"text"},{"text":"last even number in the passed array, if one is found. First, the","type":"text"},{"text":" ","type":"text"},{"text":"function finds the position of the last even number as a ","type":"text"},{"code":"ReversedIndex","type":"codeVoice"},{"text":" ","type":"text"},{"text":"in a reversed view of the array of numbers. Next, the function calls the","type":"text"},{"text":" ","type":"text"},{"text":"array’s ","type":"text"},{"code":"index(before:)","type":"codeVoice"},{"text":" method to return the correct position in the","type":"text"},{"text":" ","type":"text"},{"text":"passed array.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["func indexOfLastEven(_ numbers: [Int]) -> Int? {","    let reversedNumbers = numbers.reversed()","    guard let i = reversedNumbers.firstIndex(where: { $0 % 2 == 0 })","        else { return nil }","","    return numbers.index(before: i.base)","}","","let numbers = [10, 20, 13, 19, 30, 52, 17, 40, 51]","if let lastEven = indexOfLastEven(numbers) {","    print(\"Last even number: \\(numbers[lastEven])\")","}","\/\/ Prints \"Last even number: 40\""]}]}],"metadata":{"fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"base","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Base","kind":"typeIdentifier","preciseIdentifier":"s:s18ReversedCollectionV4Basexmfp"},{"text":".","kind":"text"},{"text":"Index","kind":"typeIdentifier","preciseIdentifier":"s:Sl5IndexQa"}],"symbolKind":"property","role":"symbol","roleHeading":"Instance Property","externalID":"s:s18ReversedCollectionV5IndexV4baseACQzvp","title":"base","modules":[{"name":"Swift"}],"platforms":[{"name":"iOS","introducedAt":"8.0","beta":false,"deprecated":false,"unavailable":false},{"name":"iPadOS","introducedAt":"8.0","beta":false,"deprecated":false,"unavailable":false},{"name":"Mac Catalyst","introducedAt":"13.0","beta":false,"deprecated":false,"unavailable":false},{"name":"macOS","introducedAt":"10.10","beta":false,"deprecated":false,"unavailable":false},{"name":"tvOS","introducedAt":"9.0","beta":false,"deprecated":false,"unavailable":false},{"name":"visionOS","introducedAt":"1.0","beta":false,"deprecated":false,"unavailable":false},{"name":"watchOS","introducedAt":"2.0","beta":false,"deprecated":false,"unavailable":false}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/