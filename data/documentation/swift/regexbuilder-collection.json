{"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/regexbuilder-collection"]}],"metadata":{"modules":[{"name":"Swift"}],"role":"collectionGroup","title":"RegexBuilder"},"sections":[],"abstract":[{"text":"Use an expressive domain-specific language to build regular expressions,","type":"text"},{"text":" ","type":"text"},{"text":"for operations like searching and replacing in text.","type":"text"}],"kind":"article","identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/RegexBuilder-collection","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Regular expressions, also known as regexes,","type":"text"},{"text":" ","type":"text"},{"text":"are a powerful tool for matching patterns in text.","type":"text"},{"text":" ","type":"text"},{"text":"Swift supports several ways to create a regular expression,","type":"text"},{"text":" ","type":"text"},{"text":"including from a string, as a literal, and using this DSL.","type":"text"},{"text":" ","type":"text"},{"text":"For example:","type":"text"}],"type":"paragraph"},{"code":["let word = OneOrMore(.word)","let emailPattern = Regex {","    Capture {","        ZeroOrMore {","            word","            \".\"","        }","        word","    }","    \"@\"","    Capture {","        word","        OneOrMore {","            \".\"","            word","        }","    }","}","","let text = \"My email is my.name@example.com.\"","if let match = text.firstMatch(of: emailPattern) {","    let (wholeMatch, name, domain) = match.output","    \/\/ wholeMatch is \"my.name@example.com\"","    \/\/ name is \"my.name\"","    \/\/ domain is \"example.com\"","}"],"type":"codeListing","syntax":"swift"}]}],"references":{"Swift-PageImage-card.png":{"alt":"An orange Swift logo on a gradient background.","type":"image","identifier":"Swift-PageImage-card.png","variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png","traits":["2x","dark"]}]},"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","type":"topic","abstract":[{"type":"text","text":"Build apps using a powerful open language."}],"title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","kind":"symbol"}}}