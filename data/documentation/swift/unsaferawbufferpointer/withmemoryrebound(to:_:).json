:"text"},{"text":"Result","preciseIdentifier":"s:SW17withMemoryRebound2to_q0_xm_q0_SRyxGq_YKXEtq_YKs5ErrorR_Ri_zRi_0_r1_lF6ResultL_q0_mfp","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"E","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Error","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Error","preciseIdentifier":"s:s5ErrorP","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":" : ~Copyable, ","kind":"text"},{"text":"Result","kind":"typeIdentifier"},{"text":" : ~Copyable","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The type to temporarily bind the memory referenced by this"},{"type":"text","text":" "},{"type":"text","text":"buffer."}],"type":"paragraph"}],"name":"type"},{"name":"body","content":[{"inlineContent":[{"type":"text","text":"A closure that takes a typed pointer to the"},{"type":"text","text":" "},{"type":"text","text":"same memory as this pointer, only bound to type "},{"type":"codeVoice","code":"T"},{"type":"text","text":". The closure’s"},{"type":"text","text":" "},{"type":"text","text":"pointer argument is valid only for the duration of the closure’s"},{"type":"text","text":" "},{"text":"execution. If ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" has a return value, that value is also used as","type":"text"},{"type":"text","text":" "},{"text":"the return value for the ","type":"text"},{"code":"withMemoryRebound(to:capacity:_:)","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}]}]},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"The return value, if any, of the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure parameter."}],"type":"paragraph"}],"kind":"content"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method when you have a buffer to raw memory and you need"},{"text":" ","type":"text"},{"type":"text","text":"to access that memory as instances of a given type "},{"code":"T","type":"codeVoice"},{"type":"text","text":". Accessing"},{"text":" ","type":"text"},{"type":"text","text":"memory as a type "},{"code":"T","type":"codeVoice"},{"type":"text","text":" requires that the memory be bound to that type."},{"type":"text","text":" "},{"type":"text","text":"A memory location may only be bound to one type at a time, so accessing"},{"type":"text","text":" "},{"type":"text","text":"the same memory as an unrelated type without first rebinding the memory"},{"text":" ","type":"text"},{"type":"text","text":"is undefined."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" within the re-bound region may be initialized or"},{"type":"text","text":" "},{"text":"uninitialized. The memory underlying any individual instance of ","type":"text"},{"type":"codeVoice","code":"T"},{"text":" ","type":"text"},{"text":"must have the same initialization state (i.e.  initialized or","type":"text"},{"type":"text","text":" "},{"type":"text","text":"uninitialized.) Accessing a "},{"type":"codeVoice","code":"T"},{"type":"text","text":" whose underlying memory"},{"type":"text","text":" "},{"type":"text","text":"is in a mixed initialization state shall be undefined behaviour."}]},{"type":"paragraph","inlineContent":[{"text":"If the byte count of the original buffer is not a multiple of","type":"text"},{"type":"text","text":" "},{"text":"the stride of ","type":"text"},{"type":"codeVoice","code":"T"},{"type":"text","text":", then the re-bound buffer is shorter"},{"type":"text","text":" "},{"type":"text","text":"than the original buffer."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After executing "},{"type":"codeVoice","code":"body"},{"type":"text","text":", this method rebinds memory back to its original"},{"type":"text","text":" "},{"type":"text","text":"binding state. This can be unbound memory, or bound to a different type."}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The buffer’s base address must match the"},{"type":"text","text":" "},{"type":"text","text":"alignment of "},{"type":"codeVoice","code":"T"},{"text":" (as reported by ","type":"text"},{"type":"codeVoice","code":"MemoryLayout<T>.alignment"},{"text":").","type":"text"},{"type":"text","text":" "},{"type":"text","text":"That is, "},{"type":"codeVoice","code":"Int(bitPattern: self.baseAddress) % MemoryLayout<T>.alignment"},{"type":"text","text":" "},{"text":"must equal zero.","type":"text"}]}],"name":"Note","style":"note"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A raw buffer may represent memory that has been bound to a type."},{"type":"text","text":" "},{"type":"text","text":"If that is the case, then "},{"type":"codeVoice","code":"T"},{"type":"text","text":" must be layout compatible with the"},{"type":"text","text":" "},{"type":"text","text":"type to which the memory has been bound. This requirement does not"},{"type":"text","text":" "},{"type":"text","text":"apply if the raw buffer represents memory that has not been bound"},{"type":"text","text":" "},{"type":"text","text":"to any type."}]}],"name":"Note","style":"note"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UnsafeRawBufferPointer\/withMemoryRebound(to:_:)"},"metadata":{"modules":[{"name":"Swift"}],"roleHeading":"Instance Method","platforms":[{"beta":false,"deprecated":false,"name":"iOS","unavailable":false,"introducedAt":"8.0"},{"beta":false,"deprecated":false,"name":"iPadOS","unavailable":false,"introducedAt":"8.0"},{"be