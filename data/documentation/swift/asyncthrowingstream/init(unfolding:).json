e error from your closure."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"code":"AsyncThrowingStream","type":"codeVoice"},{"type":"text","text":" created with this"},{"type":"text","text":" "},{"type":"text","text":"initializer that produces random numbers on a one-second interval. If the"},{"type":"text","text":" "},{"type":"text","text":"random number is divisible by 5 with no remainder, the stream throws a"},{"type":"text","text":" "},{"code":"MyRandomNumberError","type":"codeVoice"},{"type":"text","text":"."}]},{"syntax":"swift","type":"codeListing","code":["let stream = AsyncThrowingStream<Int, Error> {","    await Task.sleep(1 * 1_000_000_000)","    let random = Int.random(in: 1...10)","    if random % 5 == 0 {","        throw MyRandomNumberError()","    }","    return random","}","","\/\/ Call point:","do {","    for try await random in stream {","        print(random)","    }","} catch {","    print(error)","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/asyncthrowingstream\/init(unfolding:)"]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/AsyncThrowingStream/init(unfolding:)":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"unfolding","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" () ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"Element","kind":"typeIdentifier","preciseIde