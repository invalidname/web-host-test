ngStream\/Continuation\/BufferingPolicy"},{"kind":"text","text":" = .unbounded, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"build"},{"kind":"text","text":": ("},{"preciseIdentifier":"s:Scs12ContinuationV","kind":"typeIdentifier","text":"Continuation","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/AsyncThrowingStream\/Continuation"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Void"},{"kind":"text","text":") "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Failure"},{"kind":"text","text":" == any "},{"preciseIdentifier":"s:s5ErrorP","kind":"typeIdentifier","text":"Error","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Error"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The type of element the "},{"type":"codeVoice","code":"AsyncThrowingStream"},{"type":"text","text":" "},{"type":"text","text":"produces."}]}],"name":"elementType"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The maximum number of elements to"},{"type":"text","text":" "},{"type":"text","text":"hold in the buffer. By default, this value is unlimited. Use a"},{"type":"text","text":" "},{"type":"codeVoice","code":"Continuation.BufferingPolicy"},{"type":"text","text":" to buffer a specified number of oldest"},{"type":"text","text":" "},{"type":"text","text":"or newest elements."}]}],"name":"limit"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A custom closure that yields values to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncThrowingStream"},{"type":"text","text":". This closure receives an"},{"type":"text","text":" "},{"type":"codeVoice","code":"AsyncThrowingStream.Continuation"},{"type":"text","text