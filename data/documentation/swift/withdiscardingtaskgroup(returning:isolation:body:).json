{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/withDiscardingTaskGroup(returning:isolation:body:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"withDiscardingTaskGroup","kind":"identifier"},{"text":"<","kind":"text"},{"text":"GroupResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"returning","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"returnType","kind":"internalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"GroupResult","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp"},{"kind":"text","text":".Type = GroupResult.self, "},{"kind":"externalParam","text":"isolation"},{"kind":"text","text":": "},{"text":"isolated","kind":"keyword"},{"text":" (","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Actor","kind":"typeIdentifier","text":"Actor","preciseIdentifier":"s:ScA"},{"text":")? = #isolation, ","kind":"text"},{"text":"body","kind":"externalParam"},{"text":": (","kind":"text"},{"text":"inout","kind":"keyword"},{"kind":"text","text":" "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/DiscardingTaskGroup","text":"DiscardingTaskGroup","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency19DiscardingTaskGroupV"},{"text":") ","kind":"text"},{"kind":"keyword","text":"async"},{"text":" -> ","kind":"text"},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency23withDiscardingTaskGroup9returning9isolation4bodyxxm_ScA_pSgYixAA0cdE0VzYaXEtYalF0E6ResultL_xmfp","text":"GroupResult"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Unlike a ","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup","isActive":true,"type":"reference"},{"text":", the child tasks as well as their results are","type":"text"},{"text":" ","type":"text"},{"text":"discarded as soon as the tasks complete. This prevents the discarding","type":"text"},{"text":" ","type":"text"},{"text":"task group from accumulating many results waiting to be consumed, and is","type":"text"},{"text":" ","type":"text"},{"text":"best applied in situations where the result of a child task is some form","type":"text"},{"text":" ","type":"text"},{"text":"of side-effect.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"A group ","type":"text"},{"inlineContent":[{"text":"always","type":"text"}],"type":"emphasis"},{"text":" waits for all of its child tasks","type":"text"},{"type":"text","text":" "},{"text":"to complete before it returns. Even canceled tasks must run until","type":"text"},{"type":"text","text":" "},{"text":"completion before this function returns.","type":"text"},{"text":" ","type":"text"},{"text":"Canceled child tasks cooperatively react to cancellation and attempt","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to return as early as possible."},{"text":" ","type":"text"},{"type":"text","text":"After this function returns, the task group is always empty."}]},{"inlineContent":[{"text":"It is not possible to explicitly await completion of child-tasks,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"however the group will automatically await "},{"type":"emphasis","inlineContent":[{"text":"all","type":"text"}]},{"text":" child task completions","type":"text"},{"text":" ","type":"text"},{"text":"before returning from this function:","type":"text"}],"type":"paragraph"},{"code":["await withDiscardingTaskGroup(...) { group in","  group.addTask { \/* slow-task *\/ }","  \/\/ slow-task executes...","}","\/\/ guaranteed that slow-task has completed and the group is empty & destroyed"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Refer to ","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup","isActive":true,"type":"reference"},{"text":" documentation for detailed discussion of semantics shared between all task groups.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Task Group Cancellation","level":1,"anchor":"Task-Group-Cancellation"},{"inlineContent":[{"text":"You can cancel a task group and all of its child tasks","type":"text"},{"text":" ","type":"text"},{"text":"by calling the ","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup\/cancelAll()","isActive":true,"type":"reference"},{"type":"text","text":" method on the task group,"},{"text":" ","type":"text"},{"text":"or by canceling the task in which the group is running.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you call ","type":"text"},{"code":"addTask(priority:operation:)","type":"codeVoice"},{"type":"text","text":" to create a new task in a canceled group,"},{"type":"text","text":" "},{"type":"text","text":"that task is immediately canceled after creation."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, you can call "},{"type":"codeVoice","code":"asyncUnlessCancelled(priority:operation:)"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which doesn’t create the task if the group has already been canceled."},{"type":"text","text":" "},{"type":"text","text":"Choosing between these two functions"},{"type":"text","text":" "},{"type":"text","text":"lets you control how to react to cancellation within a group:"},{"type":"text","text":" "},{"type":"text","text":"some child tasks need to run regardless of cancellation,"},{"type":"text","text":" "},{"type":"text","text":"but other tasks are better not even being created"},{"type":"text","text":" "},{"text":"when you know they can’t produce useful results.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Because the tasks you add to a group with this method are nonthrowing,","type":"text"},{"text":" ","type":"text"},{"text":"those tasks can’t respond to cancellation by throwing ","type":"text"},{"code":"CancellationError","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"The tasks must handle cancellation in some other way,","type":"text"},{"text":" ","type":"text"},{"text":"such as returning the work completed so far, returning an empty result, or returning ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"For tasks that need to handle cancellation by throwing an error,"},{"type":"text","text":" "},{"text":"use the ","type":"text"},{"code":"withThrowingDiscardingTaskGroup(returning:body:)","type":"codeVoice"},{"type":"text","text":" method instead."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup"}],"type":"paragraph"}],"style":"note","name":"See Also","type":"aside"},{"type":"aside","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"withThrowingDiscardingTaskGroup(returning:body:)","type":"codeVoice"}],"type":"paragraph"}],"style":"note","name":"See Also"}]}],"seeAlsoSections":[{"generated":true,"title":"Tasks","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/Tas