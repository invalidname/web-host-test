text":" ","type":"text"},{"text":"the caller.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"If the sequence has no elements, "},{"type":"codeVoice","code":"updateAccumulatingResult"},{"type":"text","text":" is never"},{"type":"text","text":" "},{"type":"text","text":"executed and "},{"type":"codeVoice","code":"initialResult"},{"type":"text","text":" is the result of the call to"},{"type":"text","text":" "},{"type":"codeVoice","code":"reduce(into:_:)"},{"type":"text","text":"."}],"type":"paragraph"},{"name":"Complexity","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" is the length of the sequence.","type":"text"}]}]}]}],"variants":[{"paths":["\/documentation\/swift\/enumeratedsequence\/reduce(into:_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"Swift-PageImage-card.png":{"variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png","traits":["2x","dark"]}],"type":"image","identifier":"Swift-PageImage-card.png","alt":"An orange Swift logo on a gradient background."},"doc://com.apple.Swift/documentation/Swift/EnumeratedSequence":{"role":"symbol","navigatorTitle":[{"text":"EnumeratedSequence","kind":"identifier"}],"abstract":[{"type":"text","text":"An enumeration of the elements of a sequence or collection."}],"url":"\/documentation\/swift\/enumeratedsequence","title":"EnumeratedSequence","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EnumeratedSequence","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/EnumeratedSequence","kind":"symbol"},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"title":"Element","