{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomPlaygroundDisplayConvertible"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CustomPlaygroundDisplayConvertible","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Playground logging can generate, at a minimum, a structured description","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"of any type. If you want to provide a custom description of your type to be"},{"type":"text","text":" "},{"type":"text","text":"logged in place of the default description, conform to the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"CustomPlaygroundDisplayConvertible"},{"type":"text","text":" protocol."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Playground logging generates a richer, more specialized description of core"},{"text":" ","type":"text"},{"type":"text","text":"types. For example, the contents of a "},{"type":"codeVoice","code":"String"},{"type":"text","text":" are logged, as are the"},{"type":"text","text":" "},{"type":"text","text":"components of an "},{"type":"codeVoice","code":"NSColor"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"UIColor"},{"text":". The current playground logging","type":"text"},{"text":" ","type":"text"},{"text":"implementation logs specialized descriptions of at least the following","type":"text"},{"text":" ","type":"text"},{"text":"types:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"String","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"NSString"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"Int"},{"type":"text","text":", "},{"type":"codeVoice","code":"UInt"},{"type":"text","text":", and the other standard library integer types"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Float","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Double"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Bool","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"code":"Date","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"NSDate","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSAttributedString"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSNumber"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"NSRange","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"URL"},{"type":"text","text":" and "},{"type":"codeVoice","code":"NSURL"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"CGPoint","type":"codeVoice"},{"type":"text","text":", "},{"code":"CGSize","type":"codeVoice"},{"type":"text","text":", and "},{"code":"CGRect","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"NSColor","type":"codeVoice"},{"text":", ","type":"text"},{"code":"UIColor","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"CGColor"},{"text":", and ","type":"text"},{"code":"CIColor","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSImage"},{"type":"text","text":", "},{"type":"codeVoice","code":"UIImage"},{"type":"text","text":", "},{"type":"codeVoice","code":"CGImage"},{"type":"text","text":", and "},{"type":"codeVoice","code":"CIImage"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSBezierPath"},{"type":"text","text":" and "},{"t