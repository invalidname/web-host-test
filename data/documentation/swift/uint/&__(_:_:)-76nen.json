":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/uint\/&__(_:_:)-76nen"]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/UInt/&__(_:_:)-76nen":{"url":"\/documentation\/swift\/uint\/&__(_:_:)-76nen","abstract":[{"text":"Returns the result of shifting a value’s binary representation the","type":"text"},{"text":" ","type":"text"},{"text":"specified number of digits to the right, masking the shift amount to the","type":"text"},{"text":" ","type":"text"},{"text":"type’s bit width.","type":"text"}],"title":"&>>(_:_:)","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UInt\/&__(_:_:)-76nen","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"&>>","kind":"identifier"},{"text":" ","kind":"text"},{"text":"<","kind":"text"},{"text":"Other","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Other","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"}],"type":"topic","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/BinaryInteger":{"url":"\/documentation\/swift\/binaryinteger","abstract":[{"type":"text","text":"An integer type with a binary representation."}],"title":"BinaryInteger","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/BinaryInteger","navigatorTitle":[{"kind":"identifier","text":"BinaryInteger"}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"id