{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyObject"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You use "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" when you need the flexibility of an untyped object or"},{"type":"text","text":" "},{"type":"text","text":"when you use bridged Objective-C methods and properties that return an"},{"type":"text","text":" "},{"type":"text","text":"untyped result. "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" can be used as the concrete type for an"},{"type":"text","text":" "},{"type":"text","text":"instance of any class, class type, or class-only protocol. For example:"}]},{"type":"codeListing","syntax":"swift","code":["class FloatRef {","    let value: Float","    init(_ value: Float) {","        self.value = value","    }","}","","let x = FloatRef(2.3)","let y: AnyObject = x","let z: AnyObject = FloatRef.self"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" can also be used as the concrete type for an instance of a type"},{"type":"text","text":" "},{"type":"text","text":"that bridges to an Objective-C class. Many value types in Swift bridge to"},{"type":"text","text":" "},{"type":"text","text":"Objective-C counterparts, like "},{"type":"codeVoice","code":"String"},{"type":"text","text":" and "},{"type":"codeVoice","code":"Int"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["let s: AnyObject = \"This is a bridged string.\" as NSString","print(s is NSString)","\/\/ Prints \"true\"","","let v: AnyObject = 100 as NSNumber","print(type(of: v))","\/\/ Prints \"__NSCFNumber\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The flexible behavior of the "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" protocol is similar to"},{"type":"text","text":" "},{"type":"text","text":"Objective-C’s "},{"type":"codeVoice","code":"id"},{"type":"text","text":" type. For this reason, imported Objective-C types"},{"type":"text","text":" "},{"type":"text","text":"frequently use "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" as the type for properties, method parameters,"},{"type":"text","text":" "},{"type":"text","text":"and return values."}]},{"type":"heading","text":"Casting AnyObject Instances to a Known Type","level":1,"anchor":"Casting-AnyObject-Instances-to-a-Known-Type"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Objects with a concrete type of "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" maintain a specific dynamic"},{"type":"text","text":" "},{"type":"text","text":"type and can be cast to that type using one of the type-cast operators"},{"type":"text","text":" "},{"type":"text","text":"("},{"type":"codeVoice","code":"as"},{"type":"text","text":", "},{"type":"codeVoice","code":"as?"},{"type":"text","text":", or "},{"type":"codeVoice","code":"as!"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses the conditional downcast operator ("},{"type":"codeVoice","code":"as?"},{"type":"text","text":") to"},{"type":"text","text":" "},{"type":"text","text":"conditionally cast the "},{"type":"codeVoice","code":"s"},{"type":"text","text":" constant declared above to an instance of"},{"type":"text","text":" "},{"type":"text","text":"Swift’s "},{"type":"codeVoice","code":"String"},{"type":"text","text":" type."}]},{"type":"codeListing","syntax":"swift","code":["if let message = s as? String {","    print(\"Successful cast to String: \\(message)\")","}","\/\/ Prints \"Successful cast to String: This is a bridged string.\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have prior knowledge that an "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" instance has a particular"},{"type":"text","text":" "},{"type":"text","text":"type, you can use the unconditional downcast operator ("},{"type":"codeVoice","code":"as!"},{"type":"text","text":"). Performing"},{"type":"text","text":" "},{"type":"text","text":"an invalid cast triggers a runtime error."}]},{"type":"codeListing","syntax":"swift","code":["let message = s as! String","print(\"Successful cast to String: \\(message)\")","\/\/ Prints \"Successful cast to String: This is a bridged string.\"","","let badCase = v as! String","\/\/ Runtime error"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Casting is always safe in the context of a "},{"type":"codeVoice","code":"switch"},{"type":"text","text":" statement."}]},{"type":"codeListing","syntax":"swift","code":["let mixedArray: [AnyObject] = [s, v]","for object in mixedArray {","    switch object {","    case let x as String:","        print(\"'\\(x)' is a String\")","    default:","        print(\"'\\(object)' is not a String\")","    }","}","\/\/ Prints \"'This is a bridged string.' is a String\"","\/\/ Prints \"'100' is not a String\""]},{"type":"heading","text":"Accessing Objective-C Methods and Properties","level":1,"anchor":"Accessing-Objective-C-Methods-and-Properties"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you use "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" as a concrete type, you have at your disposal"},{"type":"text","text":" "},{"type":"text","text":"every "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" method and property—that is, methods and properties"},{"type":"text","text":" "},{"type":"text","text":"imported from Objective-C or marked with the "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" attribute. Because"},{"type":"text","text":" "},{"type":"text","text":"Swift can’t guarantee at compile time that these methods and properties"},{"type":"text","text":" "},{"type":"text","text":"are actually available on an "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" instance’s underlying type, these"},{"type":"text","text":" "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" symbols are available as implicitly unwrapped optional methods and"},{"type":"text","text":" "},{"type":"text","text":"properties, respectively."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example defines an "},{"type":"codeVoice","code":"IntegerRef"},{"type":"text","text":" type with an "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" method named"},{"type":"text","text":" "},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["class IntegerRef {","    let value: Int","    init(_ value: Int) {","        self.value = value","    }","","    @objc func getIntegerValue() -> Int {","        return value","    }","}","","func getObject() -> AnyObject {","    return IntegerRef(100)","}","","let obj: AnyObject = getObject()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the example, "},{"type":"codeVoice","code":"obj"},{"type":"text","text":" has a static type of "},{"type":"codeVoice","code":"AnyObject"},{"type":"text","text":" and a dynamic type"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"codeVoice","code":"IntegerRef"},{"type":"text","text":". You can use optional chaining to call the "},{"type":"codeVoice","code":"@objc"},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":" on "},{"type":"codeVoice","code":"obj"},{"type":"text","text":" safely. If you’re sure of the dynamic type of"},{"type":"text","text":" "},{"type":"codeVoice","code":"obj"},{"type":"text","text":", you can call "},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":" directly."}]},{"type":"codeListing","syntax":"swift","code":["let possibleValue = obj.getIntegerValue?()","print(possibleValue)","\/\/ Prints \"Optional(100)\"","","let certainValue = obj.getIntegerValue()","print(certainValue)","\/\/ Prints \"100\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the dynamic type of "},{"type":"codeVoice","code":"obj"},{"type":"text","text":" doesn’t implement a "},{"type":"codeVoice","code":"getIntegerValue()"},{"type":"text","text":" "},{"type":"text","text":"method, the system returns a runtime error when you initialize"},{"type":"text","text":" "},{"type":"codeVoice","code":"certainValue"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, if you need to test whether "},{"type":"codeVoice","code":"obj.getIntegerValue()"},{"type":"text","text":" exists,"},{"type":"text","text":" "},{"type":"text","text":"use optional binding before calling the method."}]},{"type":"codeListing","syntax":"swift","code":["if let f = obj.getIntegerValue {","    print(\"The value of 'obj' is \\(f())\")","} else {","    print(\"'obj' does not have a 'getIntegerValue()' method\")","}","\/\/ Prints \"The value of 'obj' is 100\""]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/AnyObject"},"metadata":{"title":"AnyObject","role":"symbol","externalID":"s:s9AnyObjecta","platforms":[{"deprecated":false,"unavailable":false,"beta":false,"name":"iOS","introducedAt":"8.0"},{"deprecated":false,"unavailable":false,"beta":false,"name":"iPadOS","introducedAt":"8.0"},{"deprecated":false,"unavailable":false,"beta":false,"name":"Mac Catalyst","introducedAt":"13.0"},{"deprecated":false,"unavailable":false,"beta":false,"name":"macOS","introducedAt":"10.10"},{"deprecated":false,"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"9.0"},{"deprecated":false,"unavailable":false,"beta":false,"name":"visionOS","introducedAt"