xt","text":" "},{"type":"codeVoice","code":"x \/ y"},{"type":"text","text":" computed in"},{"type":"text","text":" "},{"type":"text","text":"floating-point arithmetic, and that "},{"type":"codeVoice","code":"q"},{"type":"text","text":" may not be representable in any"},{"type":"text","text":" "},{"type":"text","text":"available integer type."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example calculates the remainder of dividing 8.625 by 0.75:"}]},{"syntax":"swift","type":"codeListing","code":["let x = 8.625","print(x \/ 0.75)","\/\/ Prints \"11.5\"","","let q = (x \/ 0.75).rounded(.toNearestOrEven)","\/\/ q == 12.0","let r = x.remainder(dividingBy: 0.75)","\/\/ r == -0.375","","let x1 = 0.75 * q + r","\/\/ x1 == 8.625"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this value and "},{"type":"codeVoice","code":"other"},{"type":"text","text":" are finite numbers, the remainder is in the"},{"type":"text","text":" "},{"type":"text","text":"closed range "},{"type":"codeVoice","code":"-abs(other \/ 2)...abs(other \/ 2)"},{"type":"text","text":". The"},{"type":"text","text":" "},{"type":"codeVoice","code":"remainder(dividingBy:)"},{"type":"text","text":" method is always exact. This method implements"},{"type":"text","text":" "},{"type":"text","text":"the remainder operation defined by the "},{"type":"reference","identifier":"http:\/\/ieeexplore.ieee.org\/servlet\/opac?punumber=4610933","isActive":true},{"type":"text","text":"."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/floatingpoint\/remainder(dividingby:)"]}],"references":{"Swift-PageImage-card.png":{"identifier":"Swift-PageImage-card.png","alt":"An orange Swift logo on a gradient background.","variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png","traits":["2x","dark"]}],"type":"image"},