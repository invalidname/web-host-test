{"metadata":{"title":"signalingNaN","externalID":"s:SF12signalingNaNxvpZ","modules":[{"name":"Swift"}],"required":true,"symbolKind":"property","roleHeading":"Type Property","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"signalingNaN","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"}],"role":"symbol","platforms":[{"deprecated":false,"unavailable":false,"name":"iOS","introducedAt":"8.0","beta":false},{"deprecated":false,"unavailable":false,"name":"iPadOS","introducedAt":"8.0","beta":false},{"deprecated":false,"unavailable":false,"name":"Mac Catalyst","introducedAt":"13.0","beta":false},{"deprecated":false,"unavailable":false,"name":"macOS","introducedAt":"10.10","beta":false},{"deprecated":false,"unavailable":false,"name":"tvOS","introducedAt":"9.0","beta":false},{"deprecated":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0","beta":false},{"deprecated":false,"unavailable":false,"name":"watchOS","introducedAt":"2.0","beta":false}]},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/FloatingPoint"]]},"kind":"symbol","identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/FloatingPoint\/signalingNaN","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"A signaling NaN (“not a number”).","type":"text"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"signalingNaN"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default IEEE 754 behavior of operations involving a signaling NaN is"},{"type":"text","text":" "},{"type":"text","text":"to raise the Invalid flag in the floating-point environment and return a"},{"type":"text","text":" "},{"type":"text","text":"quiet NaN."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Operations on types conforming to the "},{"type":"codeVoice","code":"FloatingPoint"},{"type":"text","text":" protocol should"},{"type":"text","text":" "},{"type":"text","text":"support this behavior, but they might also support other options. For"},{"type":"text","text":" "},{"type":"text","text":"example, it would be reasonable to implement alternative operations in"},{"type":"text","text":" "},{"type":"text","text":"which operating on a signaling NaN triggers a runtime error or results"},{"type":"text","text":" "},{"type":"text","text":"in a diagnostic for debugging purposes. Types that implement alternative"},{"type":"text","text":" "},{"type":"text","text":"behaviors for a signaling NaN must document the departure."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Other than these signaling operations, a signaling NaN behaves in the"},{"type":"text","text":" "},{"type":"text","text":"same manner as a quiet NaN."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/floatingpoint\/signalingnan"]}],"references":{"doc://com.apple.Swift/documentation/Swift/FloatingPoint/signalingNaN":{"url":"\/documentation\/swift\/floatingpoint\/signalingnan","abstract":[{"text":"A signaling NaN (“not a number”).","type":"text"}],"title":"signalingNaN","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/FloatingPoint\/signalingNaN","required":true,"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"te