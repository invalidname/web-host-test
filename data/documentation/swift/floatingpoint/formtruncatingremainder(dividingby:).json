idingBy","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"other","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"other","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The value to use when dividing this value."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Performing truncating division with floating-point values results in a"},{"type":"text","text":" "},{"type":"text","text":"truncated integer quotient and a remainder. For values "},{"type":"codeVoice","code":"x"},{"type":"text","text":" and "},{"type":"codeVoice","code":"y"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"text","text":"their truncated integer quotient "},{"type":"codeVoice","code":"q"},{"type":"text","text":", the remainder "},{"type":"codeVoice","code":"r"},{"type":"text","text":" satisfies"},{"type":"text","text":" "},{"type":"codeVoice","code":"x == y * q + r"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example calculates the truncating remainder of dividing"},{"type":"text","text":" "},{"type":"text","text":"8.625 by 0.75:"}]},{"type":"codeListing","code":["var x = 8.625","print(x \/ 0.75)","\/\/ Prints \"11.5\"","","let q = (x \/ 0.75).rounded(.towardZero)","\/\/ q == 11.0","x.formTruncatingRemainder(dividingBy: 0.75)","\/\/ x == 0.375","","let x1 = 0.75 * q + x","\/\/ x1 == 8.625"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If this value and "},{"type":"codeVoice","code":"other"},{"type":"text","text":" are both finite numbers, the truncating"},{"type":"text","text":" "},{"type":"text","text":"remainder has the same sign as this value and is strictly smaller in"},{"type":"text","text":" "},{"type":"text","text":"magnitude than "},{"type":"codeVoice","code":"other"},{"type":"text","text":". The "},{"type":"codeVoice","code":"formTruncatingRemainder(dividingBy:)"},{"type":"text","text":" "},{"type":"text","text":"method is always exact."}]}]}],"kind":"symbol","abstract":[{"type":"text","text":"Replaces this value with the remainder of itself divided by the given"},{"type":"text","text":" "},{"type":"text","text":"value using truncating division."}],"references":{"Swift-PageImage-card.png":{"variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png","traits":["2x","dark"]}],"type":"image","identifier":"Swift-PageImage-card.png","alt":"An orange Swift logo on a gradient background."},"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/FloatingPoint/formTruncatingRemainder(dividingBy:)":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/FloatingPoint\/formTruncatingRemainder(dividingBy:)","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Replaces this value with the remainder of itself divided by the given"},{"type":"text","text":" "},{"type":"text","text":"value using truncating division."}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"formTruncatingRemainder","kind":"identifier"},{"text":"(","kind":"text"},{"text":"dividingBy","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/swift\/floatingpoint\/formtruncatingremainder(dividingby:)","r