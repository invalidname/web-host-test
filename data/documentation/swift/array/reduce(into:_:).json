","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The closure is called again repeatedly with the updated accumulating"},{"type":"text","text":" "},{"type":"text","text":"value and each element of the sequence."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"When the sequence is exhausted, the accumulating value is returned to"},{"type":"text","text":" "},{"type":"text","text":"the caller."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the sequence has no elements, "},{"type":"codeVoice","code":"updateAccumulatingResult"},{"type":"text","text":" is never"},{"type":"text","text":" "},{"type":"text","text":"executed and "},{"type":"codeVoice","code":"initialResult"},{"type":"text","text":" is the result of the call to"},{"type":"text","text":" "},{"type":"codeVoice","code":"reduce(into:_:)"},{"type":"text","text":"."}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"type":"text","text":"n"}],"type":"emphasis"},{"text":" is the length of the sequence.","type":"text"}]}],"type":"aside","name":"Complexity","style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/array\/reduce(into:_:)"]}],"references":{"doc://com.apple.Swift/documentation/Swift/Array":{"title":"Array","url":"\/documentation\/swift\/array","type":"topic","abstract":[{"type":"text","text":"An ordered, random-access collection."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Array","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"Array","kind":"identifier"}],"navigatorTitle":[{"text":"Array","kind":"identifier"}]},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"title":"Element","url":"\/documentation\/sw