{"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/KeyValuePairs","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"relationshipsSections":[{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BidirectionalCollection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Collection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Copyable","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomDebugStringConvertible","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomStringConvertible","doc:\/\/com.apple.Swift\/documentation\/Swift\/Escapable","doc:\/\/com.apple.Swift\/documentation\/Swift\/ExpressibleByDictionaryLiteral","doc:\/\/com.apple.Swift\/documentation\/Swift\/RandomAccessCollection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","doc:\/\/com.apple.Swift\/documentation\/Swift\/SendableMetatype","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence"],"title":"Conforms To"}],"sections":[],"metadata":{"modules":[{"name":"Swift"}],"roleHeading":"Structure","platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"8.0","deprecated":false},{"unavailable":false,"beta":false,"name":"iPadOS","introducedAt":"8.0","deprecated":false},{"unavailable":false,"beta":false,"name":"Mac Catalyst","introducedAt":"13.0","deprecated":false},{"unavailable":false,"deprecated":false,"name":"macOS","beta":false,"introducedAt":"10.10"},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"9.0","deprecated":false},{"unavailable":false,"deprecated":false,"name":"visionOS","beta":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"2.0","deprecated":false}],"role":"symbol","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"KeyValuePairs","kind":"identifier"}],"title":"KeyValuePairs","externalID":"s:s13KeyValuePairsV","navigatorTitle":[{"text":"KeyValuePairs","kind":"identifier"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/keyvaluepairs"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"KeyValuePairs"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Key"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"Value"},{"kind":"text","text":">"}]}]},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"Use a "},{"code":"KeyValuePairs","type":"codeVoice"},{"type":"text","text":" instance when you need an ordered collection of"},{"type":"text","text":" "},{"type":"text","text":"key-value pairs and don’t require the fast key lookup that the"},{"type":"text","text":" "},{"code":"Dictionary","type":"codeVoice"},{"type":"text","text":" type provides. Unlike key-value pairs in a true dictionary,"},{"type":"text","text":" "},{"type":"text","text":"neither the key nor the value of a "},{"code":"KeyValuePairs","type":"codeVoice"},{"type":"text","text":" instance must"},{"type":"text","text":" "},{"type":"text","text":"conform to the "},{"code":"Hashable","type":"codeVoice"},{"type":"text","text":" protocol."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You initialize a "},{"code":"KeyValuePairs","type":"codeVoice"},{"type":"text","text":" instance using a Swift dictionary"},{"type":"text","text":" "},{"type":"text","text":"literal. Besides maintaining the order of the original dictionary literal,"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" also allows duplicates keys. For example:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let recordTimes: KeyValuePairs = [\"Florence Griffith-Joyner\": 10.49,","                                      \"Evelyn Ashford\": 10.76,","                                      \"Evelyn Ashford\": 10.79,","                                      \"Marlies Gohr\": 10.81]","print(recordTimes.first!)","\/\/ Prints \"(key: \"Florence Griffith-Joyner\", value: 10.49)\""]},{"inlineContent":[{"type":"text","text":"Some operations that are efficient on a dictionary are slower when using"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":". In particular, to find the value matching a key, you"},{"type":"text","text":" "},{"type":"text","text":"must search through every element of the collection. The call to"},{"type":"text","text":" "},{"type":"codeVoice","code":"firstIndex(where:)"},{"type":"text","text":" in the following example must traverse the whole"},{"type":"text","text":" "},{"type":"text","text":"collection to find the element that matches the predicate:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let runner = \"Marlies Gohr\"","if let index = recordTimes.firstIndex(where: { $0.0 == runner }) {","    let time = recordTimes[index].1","    print(\"\\(runner) set a 100m record of \\(time) seconds.\")","} else {","    print(\"\\(runner) couldn't be found in the records.\")","}","\/\/ Prints \"Marlies Gohr set a 100m record of 10.81 seconds.\""]},{"type":"heading","level":2,"anchor":"Key-Value-Pairs-as-a-Function-Parameter","text":"Key-Value Pairs as a Function Parameter"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When calling a function with a "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" parameter, you can pass"},{"type":"text","text":" "},{"type":"text","text":"a Swift dictionary literal without causing a "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":" to be created."},{"type":"text","text":" "},{"type":"text","text":"This capability can be especially important when the order of elements in"},{"type":"text","text":" "},{"type":"text","text":"the literal is significant."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, you could create an "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" structure that holds a list of"},{"type":"text","text":" "},{"type":"text","text":"two-integer tuples and use an initializer that accepts a"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance."}]},{"code":["struct IntPairs {","    var elements: [(Int, Int)]","","    init(_ elements: KeyValuePairs<Int, Int>) {","        self.elements = Array(elements)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you’re ready to create a new "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" instance, use a dictionary"},{"type":"text","text":" "},{"type":"text","text":"literal as the parameter to the "},{"type":"codeVoice","code":"IntPairs"},{"type":"text","text":" initializer. The"},{"type":"text","text":" "},{"type":"codeVoice","code":"KeyValuePairs"},{"type":"text","text":" instance preserves the order of the elements as"},{"type":"text","text":" "},{"type":"text","text":"passed."}]},{"code":["let pairs = IntPairs([1: 2, 1: 1, 3: 4, 2: 1])","print(pairs.elements)","\/\/ Prints \"[(1, 2), (1, 1), (3, 4), (2, 1)]\""],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/KeyValuePairs\/init(dictionaryLiteral:)"],"generated":true,"anchor":"Initializers"},{"anchor":"Instance-Properties","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/KeyValuePairs\/span"],"title":"Instance Properties"},{"anchor":"Default-Implementations","generated":true,"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swi