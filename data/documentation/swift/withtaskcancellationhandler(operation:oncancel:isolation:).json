{"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/withTaskCancellationHandler(operation:onCancel:isolation:)","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"abstract":[{"type":"text","text":"Execute an operation with a cancellation handler that’s immediately"},{"type":"text","text":" "},{"type":"text","text":"invoked if the current task is canceled."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/withtaskcancellationhandler(operation:oncancel:isolation:)"]}],"seeAlsoSections":[{"anchor":"Canceling-Tasks","generated":true,"title":"Canceling Tasks","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/CancellationError","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/cancel()","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/isCancelled-swift.property","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/isCancelled-swift.type.property","doc:\/\/com.apple.Swift\/documentation\/Swift\/Task\/checkCancellation()","doc:\/\/com.apple.Swift\/documentation\/Swift\/withTaskCancellationHandler(handler:operation:)"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@backDeployed(before: macOS 15.0, iOS 18.0, watchOS 11.0, tvOS 18.0, visionOS 2.0)\n","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withTaskCancellationHandler","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"text":": () ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp"},{"text":", ","kind":"text"},{"text":"onCancel","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"handler","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" () -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Void"},{"text":", ","kind":"text"},{"text":"isolation","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"isolated","kind":"keyword"},{"text":" (","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Actor","kind":"typeIdentifier","preciseIdentifier":"s:ScA","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Actor"},{"text":")? = #isolation) ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"operation","content":[{"inlineContent":[{"text":"The operation to perform.","type":"text"}],"type":"paragraph"}]},{"name":"handler","content":[{"inlineContent":[{"text":"A closure to execute on cancellation.","type":"text"},{"text":" ","type":"text"},{"text":"If the task is canceled, this closure is called at most once;","type":"text"},{"text":" ","type":"text"},{"text":"otherwise, it isn’t called.","type":"text"}],"type":"paragraph"}]},{"name":"isolation","content":[{"inlineContent":[{"text":"The actor that the operation and cancellation handler are isolated to.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"This differs from the operation cooperatively checking for cancellation","type":"text"},{"text":" ","type":"text"},{"text":"and reacting to it in that the cancellation handler is ","type":"text"},{"inlineContent":[{"text":"always","type":"text"}],"type":"emphasis"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"inlineContent":[{"text":"immediately","type":"text"}],"type":"emphasis"},{"text":" invoked when the task is canceled. For example, even if the","type":"text"},{"text":" ","type":"text"},{"text":"operation is running code that never checks for cancellation, a cancellation","type":"text"},{"text":" ","type":"text"},{"text":"handler still runs and provides a chance to run some cleanup code:","type":"text"}]},{"type":"codeListing","code":["await withTaskCancellationHandler {","  var sum = 0","  while condition {","    sum += 1","  }","  return sum","} onCancel: {","  \/\/ This onCancel closure might execute concurrently with the operation.","  condition.cancel()","}"],"syntax":"swift"},{"anchor":"Execution-order-and-semantics","type":"heading","text":"Execution order and semantics","level":3},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"operation"},{"text":" closure is always invoked, even when the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"text":" method is called from a task","type":"text"},{"text":" ","type":"text"},{"text":"that was already canceled.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When ","type":"text"},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"text":" is used in a task that has already been","type":"text"},{"text":" ","type":"text"},{"text":"canceled, the cancellation handler will be executed","type":"text"},{"text":" ","type":"text"},{"text":"immediately before the ","type":"text"},{"type":"codeVoice","code":"operation"},{"text":" closure gets to execute.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This allows the cancellation handler to set some external “canceled” flag","type":"text"},{"text":" ","type":"text"},{"text":"that the operation may be ","type":"text"},{"inlineContent":[{"text":"atomically","type":"text"}],"type":"emphasis"},{"text":" checking for in order to avoid","type":"text"},{"text":" ","type":"text"},{"text":"performing any actual work once the operation gets to run.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"operation"},{"text":" closure executes on the calling execution context, and doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"suspend or change execution context unless code contained within the closure","type":"text"},{"text":" ","type":"text"},{"text":"does so. In other words, the potential suspension point of the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"withTaskCancellationHandler(operation:onCancel:)"},{"text":" never suspends by itself before","type":"text"},{"text":" ","type":"text"},{"text":"executing the operation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If cancellation occurs while the operation is running, the cancellation","type":"text"},{"text":" ","type":"text"},{"text":"handler executes ","type":"text"},{"inlineContent":[{"text":"concurrently","type":"text"}],"type":"emphasis"},{"text":" with the operation.","type":"text"}]},{"anchor":"Cancellation-handlers-and-locks","type":"heading","text":"Cancellation handlers and locks","level":3},{"type":"paragraph","inlineContent":[{"text":"Cancellation handlers which acquire locks must take care to avoid deadlock.","type":"text"},{"text":" ","type":"text"},{"text":"The cancellation handler may be invoked while holding internal locks","type":"text"},{"text":" ","type":"text"},{"text":"associated with the task or other tasks.  Other operations on the task, such","type":"text"},{"text":" ","type":"text"},{"text":"as resuming a continuation, may acquire these same internal locks.","type":"text"},{"text":" ","type":"text"},{"text":"Therefore, if a cancellation handler must acquire a lock, other code should","type":"text"},{"text":" ","type":"text"},{"text":"not cancel tasks or resume continuations while holding that lock.","type":"text"}]}],"kind":"content"}],"metadata":{"modules":[{"name":"Swift","relatedModules":[]}],"role":"symbol","platforms":[{"name":"iOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"8.0"},{"name":"iPadOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"8.0"},{"name":"Mac Catalyst","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"13.0"},{"introducedAt":"10.10","name":"macOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"9.0","name":"tvOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"2.0","name":"watchOS","deprecated":false,"unavailable":false,"beta":false}],"roleHeading":"Function","symbolKind":"func","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withTaskCancellationHandler","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"operation","kind":"externalParam"},{"text":": () ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"T","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency27withTaskCancellationHandler9operation8onCancel9isolationxxyYaKXE_yyYbXEScA_pSgYitYaKlF1TL_xmfp"},{"text":", ","kind":"text"},{"text":"onCancel","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" () -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":", ","kind":"text"},{"text":"isolation","kind":"externalP