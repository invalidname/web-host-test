{"abstract":[{"type":"text","text":"Returns a regular expression that matches with the specified semantic"},{"type":"text","text":" "},{"type":"text","text":"level."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"matchingSemantics"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"semanticLevel"},{"kind":"text","text":": "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/RegexSemanticLevel","kind":"typeIdentifier","text":"RegexSemanticLevel","preciseIdentifier":"s:17_StringProcessing18RegexSemanticLevelV"},{"text":") -> ","kind":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Regex","preciseIdentifier":"s:17_StringProcessing5RegexV","text":"Regex","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"preciseIdentifier":"s:17_StringProcessing5RegexV0C6Outputa","text":"RegexOutput","kind":"typeIdentifier"},{"text":">","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The semantics to use during matching.","type":"text"}],"type":"paragraph"}],"name":"semanticLevel"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modified regular expression."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When matching with grapheme cluster semantics (the default),"},{"type":"text","text":" "},{"type":"text","text":"metacharacters like "},{"type":"codeVoice","code":"."},{"type":"text","text":" and "},{"type":"codeVoice","code":"\\w"},{"type":"text","text":", custom character classes, and character"},{"type":"text","text":" "},{"type":"text","text":"class instances like "},{"type":"codeVoice","code":".any"},{"type":"text","text":" match a grapheme cluster when possible,"},{"type":"text","text":" "},{"type":"text","text":"corresponding with the default string representation. In addition,"},{"text":" ","type":"text"},{"type":"text","text":"matching with grapheme cluster semantics compares characters using their"},{"text":" ","type":"text"},{"text":"canonical representation, corresponding with how strings comparison works.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When matching with Unicode scalar semantics, metacharacters and character","type":"text"},{"type":"text","text":" "},{"type":"text","text":"classes always match a single Unicode scalar value, even if that scalar"},{"type":"text","text":" "},{"type":"text","text":"comprises part of a grapheme cluster."}]},{"type":"paragraph","inlineContent":[{"text":"These semantic levels can lead to different results, especially when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"working with strings that have decomposed characters. In the following"},{"type":"text","text":" "},{"type":"text","text":"example, "},{"type":"codeVoice","code":"queRegex"},{"type":"text","text":" matches any 3-character string that begins with "},{"type":"codeVoice","code":"\"q\""},{"type":"text","text":"."}]},{"type":"codeListing","code":["let composed = \"qué\"","let decomposed = \"que\\u{301}\"","","let queRegex = \/^q..$\/","","print(composed.contains(queRegex))","\/\/ Prints \"true\"","print(decomposed.contains(queRegex))","\/\/ Prints \"true\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When using Unicode scalar semantics, however, the regular expression only"},{"type":"text","text":" "},{"type":"text","text":"matches the composed version of the string, because each "},{"type":"codeVoice","code":"."},{"type":"text","text":" matches a"},{"type":"text","text":" "},{"type":"text","text":"single Unicode scalar value."}]},{"type":"codeListing","code":["let queRegexScalar = queRegex.matchingSemantics(.unicodeScalar)","print(composed.contains(queRegexScalar))","\/\/ Prints \"true\"","print(decomposed.contains(queRegexScalar))","\/\/ Prints \"false\""],"syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/swift\/regex\/matchingsemantics(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Regex\/matchingSemantics(_:)","interfaceLanguage":"swift"},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"matchingSemantics"},{"kind":"text","text":"("},{"preciseIdentifier":"s:17_StringProcessing18RegexSemanticLevelV","kind":"typeIdentifier","text":"RegexSemanticLevel"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:17_StringProcessing5RegexV","kind":"typeIdentifier","text":"Regex"},{"kind":"text","text":"<"},{"preciseIdentifier":"s:17_StringProcessing5RegexV0C6Outputa","kind":"typeIdentifier","text":"RegexOutput"},{"kind":"text","text":">"}],"modules":[{"relatedModules":[],"name":"Swift"}],"externalID":"s:17_StringProcessing5RegexV17matchingSemanticsyACyxGAA0C13SemanticLevelVF","roleHeading":"Instance Method","extendedModule":"_StringProcessing","symbolKind":"method","title":"matchingSemantics(_:)","platforms":[{"introducedAt":"8.0","deprecated":false,"beta":false,"unavailable":false,"name":"iOS"},{"introducedAt":"8.0","deprecated":false,"beta":false,"unavailable":false,"name":"iPadOS"},{"introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false,"name":"Mac Catalyst"},{"introducedAt":"10.10","deprecated":false,"beta":false,"unavailable":false,"name":"macOS"},{"introducedAt":"9.0","deprecated":false,"beta":false,"unavailable":false,"name":"tvOS"},{"introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false,"name":"visionOS"},{"introducedAt":"2.0","deprecated":false,"beta":false,"unavailable":false,"n