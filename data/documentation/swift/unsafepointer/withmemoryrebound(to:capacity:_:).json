"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The type to temporarily bind the memory referenced by this"},{"type":"text","text":" "},{"type":"text","text":"pointer. The type "},{"code":"T","type":"codeVoice"},{"text":" must be layout compatible","type":"text"},{"type":"text","text":" "},{"text":"with the pointer’s ","type":"text"},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" type."}],"type":"paragraph"}],"name":"type"},{"content":[{"inlineContent":[{"text":"The number of instances of ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" in the re-bound region.","type":"text"}],"type":"paragraph"}],"name":"count"},{"content":[{"inlineContent":[{"text":"A closure that takes a typed pointer to the","type":"text"},{"text":" ","type":"text"},{"text":"same memory as this pointer, only bound to type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":". The closure’s","type":"text"},{"text":" ","type":"text"},{"text":"pointer argument is valid only for the duration of the closure’s","type":"text"},{"type":"text","text":" "},{"type":"text","text":"execution. If "},{"code":"body","type":"codeVoice"},{"text":" has a return value, that value is also used as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the return value for the "},{"code":"withMemoryRebound(to:capacity:_:)","type":"codeVoice"},{"type":"text","text":" method."}],"type":"paragraph"}],"name":"body"}]},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure parameter.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this method when you have a pointer to memory bound to one type and","type":"text"},{"text":" ","type":"text"},{"text":"you need to access that memory as instances of another type. Accessing","type":"text"},{"text":" ","type":"text"},{"text":"memory as a type ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" requires that the memory be bound to that type. A","type":"text"},{"text":" ","type":"text"},{"text":"memory location may only be bound to one type at a time, so accessing","type":"text"},{"text":" ","type":"text"},{"text":"the same memory as an unrelated type without first rebinding the memory","type":"text"},{"text":" ","type":"text"},{"text":"is undefined.","type":"text"}]},{"inlineContent":[{"type":"text","text":"The region of memory that starts at this pointer and covers "},{"type":"codeVoice","code":"count"},{"text":" ","type":"text"},{"type":"text","text":"strides of "},{"code":"T","type":"codeVoice"},{"type":"text","text":" instances must be bound to "},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":"."},{"type":"text","text":" "},{"text":"Any instance of ","type":"text"},{"code":"T","type":"codeVoice"},{"text":" within the re-bound region may be initialized or","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"uninitialized. Every instance of "},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" overlapping with a given"},{"type":"text","text":" "},{"type":"text","text":"instance of "},{"type":"codeVoice","code":"T"},{"type":"text","text":" should have the same initialization state (i.e."},{"type":"text","text":" "},{"type":"text","text":"initialized or uninitialized.) Accessing a "},{"code":"T","type":"codeVoice"},{"type":"text","text":" whose underlying"},{"type":"text","text":" "},{"type":"codeVoice","code":"Pointee"},{"type":"text","text":" storage is in a mixed initialization state shall be"},{"text":" ","type":"text"},{"type":"text","text":"undefined behaviour."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following example temporarily rebinds the memory of a ","type":"text"},{"code":"UInt64","type":"codeVoice"},{"text":" ","type":"text"},{"text":"pointer to ","type":"text"},{"type":"codeVoice","code":"Int64"},{"type":"text","text":", then accesses a property on the signed integer."}]},{"code":["let uint64Pointer: UnsafePointer<UInt64> = fetchValue()","let isNegative = uint64Pointer.withMemoryRebound(","    to: Int64.self, capacity: 1",") {","    return $0.pointee < 0","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Because this pointer’s memory is no longer bound to its "},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" type"},{"type":"text","text":" "},{"type":"text","text":"while the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure executes, do not access memory using the"},{"type":"text","text":" "},{"type":"text","text":"original pointer from within "},{"type":"codeVoice","code":"body"},{"type":"text","text":". Instead, use the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure’s"},{"type":"text","text":" "},{"type":"text","text":"pointer argument to access the values in memory as instances of type"},{"type":"text","text":" "},{"type":"codeVoice","code":"T"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"After executing ","type":"text"},{"code":"body","type":"codeVoice"},{"text":", this method rebinds memory back to the original","type":"text"},{"type":"text","text":" "},{"code":"Pointee","type":"codeVoice"},{"type":"text","text":" type."}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Only use this method to rebind the pointer’s memory to a type","type":"text"},{"text":" ","type":"text"},{"text":"that is layout compatible with the ","type":"text"},{"type":"codeVoice","code":"Pointee"},{"text":" type. The stride of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"temporary type ("},{"code":"T","type":"codeVoice"},{"text":") may be an integer multiple or a whole fraction","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"type":"codeVoice","code":"Pointee"},{"text":"’s stride, for example to point to one element of","type":"text"},{"text":" ","type":"text"},{"text":"an aggregate.","type":"text"},{"text":" ","type":"text"},{"text":"To bind a region of memory to a type that does not match these","type":"text"},{"text":" ","type":"text"},{"text":"requirements, convert the pointer to a raw pointer and use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"bindMemory(to:)"},{"text":" method.","type":"text"},{"text":" ","type":"text"},{"text":"If ","type":"text"},{"type":"codeVoice","code":"T"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"Pointee"},{"text":" have different alignments, this pointer","type":"text"},{"text":" ","type":"text"},{"text":"must be aligned with the larger of the two alignments.","type":"text"}]}],"name":"Note"}],"kind":"content"}],"metadata":{"title":"withMemoryRebound(to:capacity:_:)","role":"symbol","extendedModule":"Swift","roleHeading":"Instance Method","platforms":[{"name":"iOS","unavailable":false,"deprecated":false,"beta":false,"introducedAt":"8.0"},{"introducedAt":"8.0","name":"iPadOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"13.0","name":"Mac Catalyst","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"10.10","name":"macOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"9.0","name":"tvOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"2.0","name":"watchOS","deprecated":false,"unavailable":false,"beta":false}],"externalID":"s:SPsRi_zrlE17withMemoryRebound2to8capacity_qd_1_qd__m_Siqd_1_SPyqd__Gqd_0_YKXEtqd_0_YKs5ErrorRd_0_Ri_d__Ri_d_1_r1_lF","modules":[{"name":"Swift"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":