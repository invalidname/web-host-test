":" argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" alters the contents of"},{"type":"text","text":" "},{"type":"text","text":"the array:"}]},{"code":["var numbers = [1, 2, 3, 4, 5]","numbers.withUnsafeMutableBufferPointer { buffer in","    for i in stride(from: buffer.startIndex, to: buffer.endIndex - 1, by: 2) {","        buffer.swapAt(i, i + 1)","    }","}","print(numbers)","\/\/ Prints \"[2, 1, 4, 3, 5]\""],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is valid only during the"},{"type":"text","text":" "},{"type":"text","text":"execution of "},{"type":"codeVoice","code":"withUnsafeMutableBufferPointer(_:)"},{"type":"text","text":". Do not store or"},{"type":"text","text":" "},{"type":"text","text":"return the pointer for later use."}]},{"type":"aside","name":"Warning","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Do not rely on anything about the array that is the target of"},{"type":"text","text":" "},{"type":"text","text":"this method during execution of the "},{"type":"codeVoice","code":"body"},{"type":"text","text":" closure; it might not"},{"type":"text","text":" "},{"type":"text","text":"appear to have its correct value. Instead, use only the"},{"type":"text","text":" "},{"type":"codeVoice","code":"UnsafeMutableBufferPointer"},{"type":"text","text":" argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":"."}]}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ContiguousArray\/withUnsafeMutableBufferPointer(_:)"},"metadata":{"title":"withUnsafeMutableBufferPointer(_:)","role":"symbol","extendedModule":"Swift","roleHeading":"Instance Method","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"8.0"},{"name":"iPadOS","deprecated":fal