roperty of"},{"type":"text","text":" "},{"type":"text","text":"a dictionary isn’t an array with its own storage, it’s a collection"},{"type":"text","text":" "},{"type":"text","text":"that maps its elements from the dictionary only when they’re"},{"type":"text","text":" "},{"text":"accessed, saving the time and space needed to allocate an array. If","type":"text"},{"text":" ","type":"text"},{"text":"you need to pass those keys to a method that takes an array, however,","type":"text"},{"text":" ","type":"text"},{"text":"use this initializer to convert that list from its type of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"LazyMapCollection<Dictionary<String, Int>, Int>"},{"type":"text","text":" to a simple"},{"type":"text","text":" "},{"type":"codeVoice","code":"[String]"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["func cacheImagesWithNames(names: [String]) {","    \/\/ custom image loading and caching"," }","","let namedHues: [String: Int] = [\"Vermillion\": 18, \"Magenta\": 302,","        \"Gold\": 50, \"Cerise\": 320]","let colorNames = Array(namedHues.keys)","cacheImagesWithNames(colorNames)","","print(colorNames)","\/\/ Prints \"[\"Gold\", \"Cerise\", \"Magenta\", \"Vermillion\"]\""]}],"kind":"content"}],"kind":"symbol","abstract":[{"text":"Creates an array containing the elements of a sequence.","type":"text"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/Sequence/Element":{"title":"Element","url":"\/documentation\/swift\/sequence\/element","type":"topic","required":true,"abstract":[{"type":"text","text":"A type representing the sequence’s eleme