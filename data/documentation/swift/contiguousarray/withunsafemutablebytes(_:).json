on.","type":"text"}]}],"name":"body"}]},{"content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The return value, if any, of the ","type":"text"},{"type":"codeVoice","code":"body"},{"text":" closure parameter.","type":"text"}]}],"kind":"content"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The array’s "},{"type":"codeVoice","code":"Element"},{"type":"text","text":" type must be a "},{"type":"emphasis","inlineContent":[{"text":"trivial type","type":"text"}]},{"type":"text","text":", which can be copied"},{"text":" ","type":"text"},{"type":"text","text":"with just a bit-for-bit copy without any indirection or"},{"type":"text","text":" "},{"type":"text","text":"reference-counting operations. Generally, native Swift types that do not"},{"type":"text","text":" "},{"type":"text","text":"contain strong or weak references are trivial, as are imported C structs"},{"type":"text","text":" "},{"type":"text","text":"and enums."}]},{"inlineContent":[{"type":"text","text":"The following example copies bytes from the "},{"type":"codeVoice","code":"byteValues"},{"type":"text","text":" array into"},{"type":"text","text":" "},{"code":"numbers","type":"codeVoice"},{"text":", an array of ","type":"text"},{"type":"codeVoice","code":"Int32"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["var numbers: [Int32] = [0, 0]","var byteValues: [UInt8] = [0x01, 0x00, 0x00, 0x00, 0x02, 0x00, 0x00, 0x00]","","numbers.withUnsafeMutableBytes { destBytes in","    byteValues.withUnsafeBytes { srcBytes in","        destBytes.copyBytes(from: srcBytes)","    }","}","\/\/ numbers == [1, 2]"],"type":"codeListing"},{"content":[{"inlineContent":[{"text":"This example shows the behavior on a little-endian platform.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"inlineContent":[{"type":"text","text":"The pointer passed as an argument to "},{"type":"codeVoice","code":"body"},{"type":"text","text":" is valid only for the"},{"type":"text","text":" "},{"type":"text","text":"lifetime of the closure. Do not escape it from the closure for later"},{"type":"text","text":" "},{"type":"text","text":"use."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"Do not rely on anything about the array that is the target of"},{"type":"text","text":" "},{"type":"text","text":"this method during execution of the "},{"code":"body","type":"codeVoice"},{"type":"text","text":" closure; it might not"},{"type":"text","text":" "},{"type":"text","text":"appear to have its correct value. Instead, use only the"},{"type":"text","text":" "},{"code":"UnsafeMutableRawBufferPointer","type":"codeVoice"},{"type":"text","text":" argument to "},{"code":"body","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside","name":"Warning","style":"warning"}]}],"sections":[],"metadata":{"externalID":"s:s15ContiguousArrayV22withUnsafeMutableBytesyqd__qd__SwKXEKlF","platforms":[{"unavailable":false,"deprecated":false,"name":"iOS","beta":false,"introducedAt":"8.0"},{"unavailable":false,"deprecated":false,"name":"iPadOS","beta":false,"introducedAt":"8.0"},{"unavailable":false,"deprecated":false,"name":"Mac Catalyst","beta":false,"introducedAt":"13.0"},{"unavailable":false,"deprecated":false,"name":"macOS","beta":false,"introducedAt":"10.10"},{"unavailable":false,"deprecated":false,"name":"tvOS","beta":false,"introducedAt":"9.0"},{"unavailable":false,"deprecated":false,"name":"visionOS","beta":false,"introducedAt":"1.0"},{"unavailable":false,"deprecated":false,"name":"watchOS","beta":false,"introducedAt":"2.0"}],"roleHeading":"Instance Method","title":"withUnsafeMutableBytes(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"withUnsafeMutableBytes","kind":"identifier"},{"text":"<","kind