{"sections":[],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ContiguousArray\/reserveCapacity(_:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/ContiguousArray"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"mutating"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reserveCapacity"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"minimumCapacity"},{"kind":"text","text":": "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Int","kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}]}]},{"kind":"parameters","parameters":[{"name":"minimumCapacity","content":[{"inlineContent":[{"text":"The requested number of elements to store.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"If you are adding a known number of elements to an array, use this method","type":"text"},{"text":" ","type":"text"},{"text":"to avoid multiple reallocations. This method ensures that the array has","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"unique, mutable, contiguous storage, with space allocated for at least"},{"text":" ","type":"text"},{"type":"text","text":"the requested number of elements."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For performance reasons, the size of the newly allocated storage might be"},{"text":" ","type":"text"},{"type":"text","text":"greater than the requested capacity. Use the array’s "},{"type":"codeVoice","code":"capacity"},{"type":"text","text":" property"},{"type":"text","text":" "},{"type":"text","text":"to determine the size of the new storage."}],"type":"paragraph"},{"text":"Preserving an Array’s Geometric Growth Strategy","level":1,"anchor":"Preserving-an-Arrays-Geometric-Growth-Strategy","type":"heading"},{"inlineContent":[{"text":"If you implement a custom data structure backed by an array that grows","type":"text"},{"text":" ","type":"text"},{"text":"dynamically, naively calling the ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"text":" method can lead","type":"text"},{"text":" ","type":"text"},{"text":"to worse than expected performance. Arrays need to follow a geometric","type":"text"},{"text":" ","type":"text"},{"text":"allocation pattern for appending elements to achieve amortized","type":"text"},{"text":" ","type":"text"},{"text":"constant-time performance. The ","type":"text"},{"type":"codeVoice","code":"Array"},{"text":" type’s ","type":"text"},{"type":"codeVoice","code":"append(_:)"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"append(contentsOf:)"},{"text":" methods take care of this detail for you, but","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":" allocates only as much space as you tell it to"},{"type":"text","text":" "},{"type":"text","text":"(padded to a round value), and no more. This avoids over-allocation, but"},{"type":"text","text":" "},{"type":"text","text":"can result in insertion not having amortized constant-time performance."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code declares "},{"code":"values","type":"codeVoice"},{"text":", an array of integers, and the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"addTenQuadratic()"},{"type":"text","text":" function, which adds ten more values to the "},{"type":"codeVoice","code":"values"},{"text":" ","type":"text"},{"text":"array on each call.","type":"text"}]},{"type":"codeListing","code":["  var values: [Int] = [0, 1, 2, 3]","","  \/\/ Don't use 'reserveCapacity(_:)' like this","  func addTenQuadratic() {","      let newCount = values.count + 10","      values.reserveCapacity(newCount)","      for n in values.count..<newCount {","          values.append(n)","      }","  }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The call to ","type":"text"},{"code":"reserveCapacity(_:)","type":"codeVoice"},{"text":" increases the ","type":"text"},{"code":"values","type":"codeVoice"},{"text":" array’s capacity","type":"text"},{"text":" ","type":"text"},{"text":"by exactly 10 elements on each pass through ","type":"text"},{"type":"codeVoice","code":"addTenQuadratic()"},{"text":", which","type":"text"},{"text":" ","type":"text"},{"text":"is linear growth. Instead of having constant time when averaged over","type":"text"},{"text":" ","type":"text"},{"text":"many calls, the function may decay to performance that is linear in","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"values.count"},{"text":". This is almost certainly not what you want.","type":"text"}]},{"inlineContent":[{"type":"text","text":"In cases like this, the simplest fix is often to simply remove the call"},{"text":" ","type":"text"},{"type":"text","text":"to "},{"type":"codeVoice","code":"reserveCapacity(_:)"},{"type":"text","text":", and let the "},{"type":"codeVoice","code":"append(_:)"},{"type":"text","text":" method grow the array"},{"text":" ","type":"text"},{"type":"text","text":"for you."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["  func addTen() {","      let newCount = values.count + 10","      for n in values.count..<newCount {","          values.append(n)","      }","  }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need more control over the capacity of your array, implement your"},{"text":" ","type":"text"},{"type":"text","text":"own geometric growth strategy, passing the size you compute to"},{"type":"text","text":" "},{"code":"reserveCapacity(_:)","type":"codeVoice"},{"text":".","type":"text"}]},{"name":"Complexity","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":" is the number of elements in the array."}]}],"style":"note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swift\/contiguousarray\/reservecapacity(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Reserves enough space to store the specified number of elements."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"reserveCapacity","kind":"identifier"},{"kind":"text","text":"("},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":")"}],"symbolKind":"method","role":"symbol","extendedModule":"Swift","title":"reserveCapacity(_:)","roleHeading":"Instance Method","externalID":"s:s15ContiguousArrayV15reserveCapacityyySiF","modules":[{"name":"Swift"}],"platforms":[{"name":"iOS","introducedAt":"8.0","beta":false,"deprecated":false,"unavailable":false},{"introducedAt":"8.0","deprecated":false,"beta":false,"unavailable":false,"name":"iPadOS"},{"name":"Mac Catalyst","introducedAt":"13.0","beta":false,"deprecated":false,"unavailable":false},{"introducedAt":"10.10","deprecated":false,"beta":false,"unavailable":false,"name":"macOS"},{"name":"tvOS","introducedAt":"9.0","beta":false,"deprecated":false,"unavailable":false},{"introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false,"name":"visionOS"},{"name":"watchOS","introducedAt":"2.0","beta":false,"deprecated":false,"unavailable":false}]},"kind":"symbol","references":{"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/ContiguousArray/reserveCapacity(_:)":{"url":"\/documentation\/swift\/contiguousarray\/reservecapacity(_:)","abstract":[{"type":"text","text":"Reserves enough space to store the specified number of elements."}],"title":"reserveCapacity(_:)","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ContiguousArray\/reserveCapacity(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"reserveCapacity"},{"kind":"text","text":"("},{"preciseIdentifier":"s:Si","kind":"typeIdentifier","text":"Int"},{"kind":"text","text":")"}],"type":"topic","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/ContiguousArray":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ContiguousArray","kind":"identifier"}],"url":"\/documentation\/swift\/contiguousarray","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ContiguousArray","navigatorTitle":[{"text":"ContiguousArray","kind":"identifier"}],"type":"topic","title":"ContiguousArray","kind":"symbol","abstract":[{"type":"text","text":"A contiguously stored array."}]},"doc://com.apple.Swift/documentation/Swift/Int":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Int","kind":"identifier"}],"url":"\/documentation\/swift\/int","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Int","navigatorTitle":[{"text":"Int","kind":"identifier"}],"type":"topic","title":"Int","kind":"symbol","abstract":[{"type":"text","text":"A signed integer value type."}]},"Swift-PageImage-card.png":{"alt":"An orange Swift logo on a gradient background.","identifier":"Swift-PageImage-card.png","type":"image","variants":[{"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png","traits":["2x","light"]},{"traits":["2x","dark"],"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png"}]}}}