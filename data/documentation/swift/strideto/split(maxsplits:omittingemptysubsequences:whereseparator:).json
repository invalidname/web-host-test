":"paragraph","inlineContent":[{"type":"text","text":"The second example passes "},{"type":"codeVoice","code":"1"},{"type":"text","text":" for the "},{"type":"codeVoice","code":"maxSplits"},{"type":"text","text":" parameter, so the"},{"type":"text","text":" "},{"type":"text","text":"original string is split just once, into two new strings."}]},{"syntax":"swift","type":"codeListing","code":["print(","   line.split(maxSplits: 1, whereSeparator: { $0 == \" \" })","                  .map(String.init))","\/\/ Prints \"[\"BLANCHE:\", \"  I don\\'t want realism. I want magic!\"]\""]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The final example passes "},{"type":"codeVoice","code":"true"},{"type":"text","text":" for the "},{"type":"codeVoice","code":"allowEmptySlices"},{"type":"text","text":" parameter, so"},{"type":"text","text":" "},{"type":"text","text":"the returned array contains empty strings where spaces were repeated."}]},{"syntax":"swift","type":"codeListing","code":["print(","    line.split(","        omittingEmptySubsequences: false,","        whereSeparator: { $0 == \" \" }","    ).map(String.init))","\/\/ Prints \"[\"BLANCHE:\", \"\", \"\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"O("},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":"), where "},{"type":"emphasis","inlineContent":[{"text":"n","type":"text"}]},{"type":"text","text":" is the length of the sequence."}]}],"type":"aside","name":"Complexity","style":"note"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/strideto\/split(maxsplits:omittingemptysubsequences:whereseparator:)"]}],"references":{"doc://com.apple.Swift/documentation/Swift/ArraySlice":{"url":"\/documentation\/swift\/arrayslice","abstract":[{"text":"A slice of an ","type":"text"},{"code":"Array","type":"codeVoice"},{"text