/element","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/OptionSet\/Element","type":"topic","title":"Element","kind":"symbol","required":true,"abstract":[{"type":"text","text":"The element type of the option set."}]},"Swift-PageImage-card.png":{"type":"image","alt":"An orange Swift logo on a gradient background.","identifier":"Swift-PageImage-card.png","variants":[{"traits":["2x","light"],"url":"\/images\/com.apple.Swift\/Swift-PageImage-card@2x.png"},{"traits":["2x","dark"],"url":"\/images\/com.apple.Swift\/Swift-PageImage-card~dark@2x.png"}]},"doc://com.apple.Swift/documentation/Runtime/Backtrace/SymbolicationOptions":{"url":"\/documentation\/runtime\/backtrace\/symbolicationoptions","identifier":"doc:\/\/com.apple.Swift\/documentation\/Runtime\/Backtrace\/SymbolicationOptions","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SymbolicationOptions","kind":"identifier"}],"abstract":[{"type":"text","text":"Specifies options for the "},{"type":"codeVoice","code":"symbolicated"},{"type":"text","text":" method."}],"title":"Backtrace.SymbolicationOptions","type":"topic","navigatorTitle":[{"text":"SymbolicationOptions","kind":"identifier"}],"kind":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/OptionSet/init(rawValue:)":{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/OptionSet\/init(rawValue:)","kind":"symbol","type":"topic","abstract":[{"text":"Creates a new option set from the given raw value.","type":"text"}],"role":"symbol","fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"rawValue