ype":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Immediately canceled child tasks should therefore cooperatively check for and","type":"text"},{"text":" ","type":"text"},{"text":"react  to cancellation, e.g. by throwing an ","type":"text"},{"code":"CancellationError","type":"codeVoice"},{"text":" at their","type":"text"},{"text":" ","type":"text"},{"text":"earliest convenience, or otherwise handling the cancellation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"There are no restrictions on where you can call this method.","type":"text"},{"text":" ","type":"text"},{"text":"Code inside a child task or even another task can cancel a group,","type":"text"},{"text":" ","type":"text"},{"text":"however one should be very careful to not keep a reference to the","type":"text"},{"text":" ","type":"text"},{"text":"group longer than the ","type":"text"},{"code":"with...TaskGroup(...) { ... }","type":"codeVoice"},{"text":" method body is executing.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"Task.isCancelled","type":"codeVoice"}],"type":"paragraph"}]},{"style":"note","type":"aside","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"DiscardingTaskGroup.isCancelled","type":"codeVoice"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swift\/discardingtaskgroup\/cancelall()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift/DiscardingTaskGroup":{"url":"\/documentation\/swift\/discardingtaskgroup","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/DiscardingTaskGroup","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiscardingTaskGroup"}],"abstract":[{"text":"A discarding group that contains dynamically created child tasks.","type":"text"}],"title":"Disca