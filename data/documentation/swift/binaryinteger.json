 "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Numeric\/Magnitude-swift.associatedtype","kind":"typeIdentifier","text":"Magnitude"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:Sz","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/BinaryInteger","kind":"typeIdentifier","text":"BinaryInteger"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Numeric\/Magnitude-swift.associatedtype","kind":"typeIdentifier","text":"Magnitude"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Numeric\/Magnitude-swift.associatedtype","kind":"typeIdentifier","text":"Magnitude"},{"kind":"text","text":"."},{"preciseIdentifier":"s:Sj9MagnitudeQa","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Numeric\/Magnitude-swift.associatedtype","kind":"typeIdentifier","text":"Magnitude"}]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":" protocol is the basis for all the integer types"},{"type":"text","text":" "},{"type":"text","text":"provided by the standard library. All of the standard library’s integer"},{"type":"text","text":" "},{"type":"text","text":"types, such as "},{"type":"codeVoice","code":"Int"},{"type":"text","text":" and "},{"type":"codeVoice","code":"UInt32"},{"type":"text","text":", conform to "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":"."}]},{"level":1,"type":"heading","text":"Converting Between Numeric Types","anchor":"Converting-Between-Numeric-Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create new instances of a type that conforms to the "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":" "},{"type":"text","text":"protocol from a floating-point number or another binary integer of any"},{"type":"text","text":" "},{"type":"text","text":"type. The "},{"type":"codeVoice","code":"BinaryInteger"},{"type":"text","text":" protocol provides initializers for four"},{"text":" ","type":"text"},{"text":"different kinds of conversion.","type":"text"}]},{"text":"Range-Checked Conversion","level":2,"anchor":"Range-Checked-Conversion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You use the default "},{"type":"codeVoice","code":"init(_:)"},{"text":" initializer to create a new instance when","type":"text"},{"type":"text","text":" "},{"text":"you’re sure that the value passed is representable in the new type. For","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"example, an instance of "},{"type":"codeVoice","code":"Int16"},{"text":" can represent the value ","type":"text"},{"type":"codeVoice","code":"500"},{"text":", so the","type":"text"},{"type":"text","text":" "},{"text":"first conversion in the code sample below succeeds. That same value is too","type":"text"},{"type":"text","text":" "},{"type":"text","text":"large to represent as an "},{"type":"codeVoice","code":"Int8"},{"text":" instance, so the second conversion fails,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"triggering a runtime error."}]},{"syntax":"swift","type":"codeListing","code":["let x: Int = 500","let y = Int16(x)","\/\/ y == 500","","let z = Int8(x)","\/\/ Error: Not enough bits to represent..."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you create a binary integer from a floating-point value using the"},{"type":"text","text":" "},{"type":"text","text":"default initializer, the value is rounded toward zero before the range is"},{"text":" ","type":"text"},{"type":"text","text":"checked. In the following example, the value "},{"type":"codeVoice","code":"127.75"},{"text":" is rounded to ","type":"text"},{"type":"codeVoice","code":"127"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"which is representable by the "},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" type.  "},{"type":"codeVoice","code":"128.25"},{"text":" is rounded to ","type":"text"},{"type":"codeVoice","code":"128"},{"text":",","type":"text"},{"type":"text","text":" "},{"text":"which is not representable as an ","type":"text"},{"type":"codeVoice","code":"Int8"},{"type":"text","text":" instance, triggering a runtime"},{"type":"text","text":" "},{"type":"text","text":"error."}]},{"type":"codeListing","code":["let e = Int8(127.75)","\/\/ e == 127","","let f = Int8(128.25)","\/\/ Error: Double value cannot be converted..."],"syntax":"swift"},{"text":"Exact Conversion","anchor":"Exact-Conversion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"init?(exactly:)"},{"type":"text","text":" initializer to create a new instance after"},{"text":" ","type":"text"},{"text":"checking whether the passed value is representable. Instead of trapping on","type":"text"},{"text":" ","type":"text"},{"text":"out-of-range values, using the failable ","type":"text"},{"code":"init?(exactly:)","type":"codeVoice"},{"type":"text","text":" "},{"text":"initializer results in ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":".","type":"text"}]},{"syntax":"swift","code":["let x = Int16(exactly: 500)","\/\/ x == Optional(500)","","let y = Int8(exactly: 500)","\/\/ y == nil"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"When converting floating-point values, the ","type":"text"},{"type":"codeVoice","code":"init?(exactly:)"},{"text":" initializer","type":"text"},{"type":"text","text":" "},{"type":"text","text":"checks both that the passed value has no fractional part and that the"},{"type":"text","text":" "},{"text":"value is representable in the resulting type.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let e = Int8(exactly: 23.0)       \/\/ integral value, representable","\/\/ e == Optional(23)","","let f = Int8(exactly: 23.75)      \/\/ fractional value, representable","\/\/ f == nil","","let g = Int8(exactly: 500.0)      \/\/ integral value, nonrepresentable","\/\/ g == nil"]},{"type":"heading","level":2,"text":"Clamping Conversion","anchor":"Clamping-Conversion"},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"init(clamping:)"},{"type":"text","text":" initializer to create a new instance of a binary"},{"type":"text","text":" "},{"type":"text","text":"integer type where out-of-range values are clamped to the representable"},{"type":"text","text":" "},{"text":"range of the type. For a type ","type":"text"},{"type":"codeVoice","code":"T"},{"type":"text","text":", the resulting value is in the range"},{"type":"text","text":" "},{"type":"codeVoice","code":"T.min...T.max"},{"text":".","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let x = Int16(clamping: 500)","\/\/ x == 500","","let y = Int8(clamping: 500)","\/\/ y == 127","","let z = UInt8(clamping: -500)","\/\/ z == 0"]},{"type":"heading","level":2,"text":"Bit Pattern Conversion","anchor":"Bit-Pattern-Conversion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"code":"init(truncatingIfNeeded:)","type":"codeVoice"},{"text":" initializer to create a new instance","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with the same bit pattern as the passed value, extending or truncating the"},{"text":" ","type":"text"},{"type":"text","text":"value’s representation as necessary. Note that the value may not be"},{"type":"text","text":" "},{"type":"text","text":"preserved, particularly when converting between signed to unsigned integer"},{"type":"text","text":" "},{"type":"text","text":"types or when the destination type has a smaller bit width than the source"},{"text":" ","type":"text"},{"text":"type. The following example shows how extending and truncating work for","type":"text"},{"text":" ","type":"text"},{"text":"nonnegative integers:","type":"text"}]},{"type":"codeListing","code":["let q: Int16 = 850","\/\/ q == 0b00000011_01010010","","let r = Int8(truncatingIfNeeded: q)      \/\/ truncate 'q' to fit in 8 bits","\/\/ r == 82","\/\/   == 0b01010010","","let s = Int16(truncatingIfNeeded: r)     \/\/ extend 'r' to fill 16 bits","\/\/ s == 82","\/\/   == 0b00000000_01010010"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any padding is performed by "},{"type":"emphasis","inlineContent":[{"type":"text","text":"sign-extending"}]},{"text":" the passed value. When","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"nonnegative integers are extended, the result is padded with zeroes. When"},{"type":"text","text":" "},{"type":"text","text":"negative integers are extended, the result is padded with ones. This"},{"type":"text","text":" "},{"type":"text","text":"example shows several extending conversions of a negative value—note"},{"type":"text","text":" "},{"type":"text","text":"that negative values are sign-extended even when converting to an unsigned"},{"type":"text","text":" "},{"type":"text","text":"type."}]},{"type":"codeListing","code":["let t: Int8 = -100","\/\/ t == -100","\/\/ t's binary representation == 0b10011100","","let u = UInt8(truncatingIfNeeded: t)","\/\/ u == 156","\/\/ u's binary representation == 0b10011100","","let v = Int16(truncatingIfNeeded: t)","\/\/ v == -100","\/\/ v's binary representation == 0b11111111_10011100","","let w = UInt16(truncatingIfNeeded: t)","\/\/ w == 65436","\/\/ w's binary representation == 0b11111111_10011100"],"syntax":"swift"},{"type":"heading","anchor":"Comparing-Across-Integer-Types","level":1,"text":"Comparing Across Integer Types"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use relational operators, such as the less-than and equal-to"},{"type":"text","text":" "},{"type":"text","text":"operators ("},{"type":"codeVoice","code":"<"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"=="},{"text":"), to compare instances of different binary integer","type":"text"},{"text":" ","type":"text"},{"text":"types. The following example compares instances of the ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":", ","type":"text"},{"type":"codeVoice","code":"UInt"},{"type":"text","text":", and"},{"text":" ","type":"text"},{"type":"codeVoice","code":"UInt8"},{"text":" types:","type":"text"}]},{"type":"codeListing","code":["let x: Int = -23","let y: UInt = 1_000","let z: UInt8 = 23","","if x < y {","    print(\"\\(x) is less than \\(y).\")","}","\/\/ Prints \"-23 is less than 1000.\"","","if z > x {","    print(\"\\(z) is greater than \\(x).\")","}","\/\/ Prints \"23 is greater than -23.\""],"syntax":"swift"}]}],"topicSections":[{"title":"Creating a Binary Integer","anchor":"Creating-a-Binary-Integer","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BinaryInteger\/init()"]},{"title":"Converting Integers","anchor":"Converting-Integers","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BinaryInteger\/init(_:)-8gmdl","doc:\/\/com.apple.Swift\/documentation\/Swift\/BinaryInteger\/init(clamping:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/BinaryInteger\/init(truncatingIfNeeded:)"]},{"title":"Converting Floating-Point Values","anchor":"Converting-Floating-Point-Values","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BinaryInteger\/init(_:)-2ln0u"]},{"title":"Converting with No Loss of Precision","anchor":"Converting-with-No-Loss-of-Precision","identifiers":["doc:\/\/com.