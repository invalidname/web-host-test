pe":"text"},{"type":"codeVoice","code":"false"},{"text":" for the ","type":"text"},{"type":"codeVoice","code":"omittingEmptySubsequences"},{"text":" ","type":"text"},{"text":"parameter, so the returned array contains empty strings where spaces","type":"text"},{"text":" ","type":"text"},{"text":"were repeated.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["print(line.split(separator: \" \", omittingEmptySubsequences: false))","\/\/ Prints \"[\"BLANCHE:\", \"\", \"\", \"I\", \"don\\'t\", \"want\", \"realism.\", \"I\", \"want\", \"magic!\"]\""],"type":"codeListing"},{"content":[{"inlineContent":[{"text":"O(","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":"), where ","type":"text"},{"inlineContent":[{"text":"n","type":"text"}],"type":"emphasis"},{"text":" is the length of the collection.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Complexity","type":"aside"}],"kind":"content"}],"metadata":{"modules":[{"name":"Swift"}],"role":"symbol","platforms":[{"name":"iOS","unavailable":false,"introducedAt":"8.0","beta":false,"deprecated":false},{"name":"iPadOS","unavailable":false,"introducedAt":"8.0","beta":false,"deprecated":false},{"name":"Mac Catalyst","unavailable":false,"introducedAt":"13.0","beta":false,"deprecated":false},{"name":"macOS","unavailable":false,"introducedAt":"10.10","beta":false,"deprecated":false},{"name":"tvOS","unavailable":false,"introducedAt":"9.0","beta":false,"deprecated":false},{"name":"visionOS","unavailable":false,"introducedAt":"1.0","beta":false,"deprecated":false},{"name":"watchOS","unavailable":false,"introducedAt":"2.0","beta":false,"deprecated":false}],"roleHeading":"Instance Method","symbolKind":"method","conformance":{"availabilityPrefix":[{"text":"Available when","type":"text"}],"constraints":[{"type":"codeVoice","code":"Element"},{"text":" conforms to ","type":"text"},{"type":"codeVoice","code":"Equatable"},{"text":".","type":"text"}],"conformancePrefix":[{"text":"Co