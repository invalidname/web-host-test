{"metadata":{"role":"collectionGroup","title":"Distributed","modules":[{"name":"Swift"}]},"sections":[],"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Distributed-collection","interfaceLanguage":"swift"},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Distributed actors share many characteristics with Swift actors,","type":"text"},{"text":" ","type":"text"},{"text":"and include additional isolation checks to ensure","type":"text"},{"text":" ","type":"text"},{"text":"location transparency and safety in a distributed environment.","type":"text"},{"text":" ","type":"text"},{"text":"Similar to how actors make it easier to write concurrent code","type":"text"},{"text":" ","type":"text"},{"text":"that’s safe and correct to run on a single computer,","type":"text"},{"text":" ","type":"text"},{"text":"distributed actors make it easier to write code","type":"text"},{"text":" ","type":"text"},{"text":"that runs across multiple computers.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"distributed-module"}],"type":"paragraph"},{"inlineContent":[{"text":"You use three main parts when writing code with distributed actors:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Swift language support for actors and distributed actors.","type":"text"},{"text":" ","type":"text"},{"text":"For more information,","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/LanguageGuide\/Concurrency.html"},{"text":" in ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The Distributed module, which includes the types and protocols you need","type":"text"},{"text":" ","type":"text"},{"text":"to declare and use distribute actors.","type":"text"},{"text":" ","type":"text"},{"text":"For example, it has","type":"text"},{"text":" ","type":"text"},{"text":"protocols to which distributed actors and distributed actor systems conform,","type":"text"},{"text":" ","type":"text"},{"text":"and structures that encapsulate information about calls to a distributed actor.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"distributed actor system","type":"text"}]},{"text":", also called a cluster runtime,","type":"text"},{"text":" ","type":"text"},{"text":"provides an implementation of the ","type":"text"},{"type":"codeVoice","code":"Distributed\/DistributedActorSystem"},{"text":" protocol","type":"text"},{"text":" ","type":"text"},{"text":"and coordinates between the cluster’s nodes.","type":"text"},{"text":" ","type":"text"},{"text":"A distributed actor is always part of some distributed actor system;","type":"text"},{"text":" ","type":"text"},{"text":"that distributed actor system handles the serialization and networking","type":"text"},{"text":" ","type":"text"},{"text":"necessary to perform remote method calls.","type":"text"},{"text":" ","type":"text"},{"text":"For local testing, you can use ","type":"text"},{"type":"codeVoice","code":"Distributed\/LocalTestingDistributedActorSystem"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"For production,","type":"text"},{"text":" ","type":"text"},{"text":"you can use the distributed actor system","type":"text"},{"text":" ","type":"text"},{"text":"from the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/apple\/swift-distributed-actors\/"},{"text":" library,","type":"text"},{"text":" ","type":"text"},{"text":"use another library,","type":"text"},{"text":" ","type":"text"},{"text":"or write your own distributed actor system.","typ