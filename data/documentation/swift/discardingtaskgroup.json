{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift"]]},"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/DiscardingTaskGroup","interfaceLanguage":"swift"},"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BitwiseCopyable"],"type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"DiscardingTaskGroup"}],"languages":["swift"]}]},{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"To create a discarding task group,","type":"text"},{"text":" ","type":"text"},{"text":"call the ","type":"text"},{"type":"codeVoice","code":"withDiscardingTaskGroup(returning:body:)"},{"text":" method.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Don’t use a task group from outside the task where you created it.","type":"text"},{"text":" ","type":"text"},{"text":"In most cases,","type":"text"},{"text":" ","type":"text"},{"text":"the Swift type system prevents a task group from escaping like that","type":"text"},{"text":" ","type":"text"},{"text":"because adding a child task to a task group is a mutating operation,","type":"text"},{"text":" ","type":"text"},{"text":"and mutation operations can’t be performed","type":"text"},{"text":" ","type":"text"},{"text":"from a concurrent execution context like a child task.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Refer to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup"},{"text":" documentation for detailed discussion of semantics shared between all task groups.","type":"text"}]},{"text":"Discarding behavior","type":"heading","level":3,"anchor":"Discarding-behavior"},{"inlineContent":[{"type":"text","text":"A discarding task group eagerly discards and releases its child tasks as"},{"type":"text","text":" "},{"type":"text","text":"soon as they complete. This allows for the efficient releasing of memory used"},{"type":"text","text":" "},{"text":"by those tasks, which are not retained for future ","type":"text"},{"type":"codeVoice","code":"next()"},{"text":" calls, as would","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"be the case with a "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Cancellation behavior","type":"heading","level":3,"anchor":"Cancellation-behavior"},{"inlineContent":[{"text":"A discarding task group becomes canceled in one of the following ways:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"when "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/DiscardingTaskGroup\/cancelAll()","isActive":true,"type":"reference"},{"text":" is invoked on it,","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"when the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Task","isActive":true},{"type":"text","text":" running this task group is canceled."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Since a ","type":"text"},{"code":"DiscardingTaskGroup","type":"codeVoice"},{"text":" is a structured concurrency primitive, cancellation is","type":"text"},{"text":" ","type":"text"},{"text":"automatically propagated through all of its child-tasks (and their child","type":"text"},{"text":" ","type":"text"},{"text":"tasks).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A canceled task group can still keep adding tasks, however they will start","type":"text"},{"text":" ","type":"text"},{"text":"being immediately canceled, and may act accordingly to this. To avoid adding","type":"text"},{"text":" ","type":"text"},{"text":"new tasks to an already canceled task group, use ","type":"text"},{"code":"addTaskUnlessCancelled(priority:body:)","type":"codeVoice"},{"type":"text","text":" "},{"text":"rather than the plain ","type":"text"},{"code":"addTask(priority:body:)","type":"codeVoice"},{"text":" which adds tasks unconditionally.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"For information about the language-level concurrency model that ","type":"text"},{"code":"DiscardingTaskGroup","type":"codeVoice"},{"text":" is part of,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"see "},{"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/LanguageGuide\/Concurrency.html","isActive":true},{"type":"text","text":" in "},{"type":"reference","identifier":"https:\/\/docs.swift.org\/swift-book\/","isActive":true},{"type":"text","text":"."}]},{"content":[{"inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup","isActive":true}],"type":"paragraph"}],"type":"aside","style":"note","name":"See Also"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ThrowingTaskGroup","isActive":true,"type":"reference"}],"type":"paragraph"}],"type":"aside","style":"note","name":"See Also"},{"content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ThrowingDiscardingTaskGroup","isActive":true,"type":"reference"}],"type":"paragraph"}],"type":"aside","style":"note","name":"See Also"}],"kind":"content"}],"topicSections":[{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/DiscardingTaskGroup\/isCancelled","doc:\/\/com.apple.Swift\/documentatio