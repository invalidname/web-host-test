{"abstract":[{"text":"A view of a string’s contents as a collection of UTF-8 code units.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UTF8View","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"inlineContent":[{"type":"text","text":"You can access a string’s view of UTF-8 code units by using its "},{"code":"utf8","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"property. A string’s UTF-8 view encodes the string’s Unicode scalar"},{"type":"text","text":" "},{"type":"text","text":"values as 8-bit integers."}],"type":"paragraph"},{"type":"codeListing","code":["let flowers = \"Flowers 💐\"","for v in flowers.utf8 {","    print(v)","}","\/\/ 70","\/\/ 108","\/\/ 111","\/\/ 119","\/\/ 101","\/\/ 114","\/\/ 115","\/\/ 32","\/\/ 240","\/\/ 159","\/\/ 146","\/\/ 144"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"A string’s Unicode scalar values can be up to 21 bits in length. To"},{"type":"text","text":" "},{"type":"text","text":"represent those scalar values using 8-bit integers, more than one UTF-8"},{"type":"text","text":" "},{"type":"text","text":"code unit is often required."}],"type":"paragraph"},{"type":"codeListing","code":["let flowermoji = \"💐\"","for v in flowermoji.unicodeScalars {","    print(v, v.value)","}","\/\/ 💐 128144","","for v in flowermoji.utf8 {","    print(v)","}","\/\/ 240","\/\/ 159","\/\/ 146","\/\/ 144"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"In the encoded representation of a Unicode scalar value, each UTF-8 code"},{"type":"text","text":" "},{"type":"text","text":"unit after the first is called a "},{"inlineContent":[{"text":"continuation byte","type":"text"}],"type":"emphasis"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"UTF8View Elements Match Encoded C Strings","level":1,"type":"heading","anchor":"UTF8View-Elements-Match-Encoded-C-Strings"},{"inlineContent":[{"type":"text","text":"Swift streamlines interoperation with C string APIs by letting you pass a"},{"type":"text","text":" "},{"code":"String","type":"codeVoice"},{"type":"text","text":" instance to a function as an "},{"code":"Int8","type":"codeVoice"},{"type":"text","text":" or "},{"code":"UInt8","type":"codeVoice"},{"type":"text","text":" pointer. When you"},{"type":"text","text":" "},{"type":"text","text":"call a C function using a "},{"code":"String","type":"codeVoice"},{"type":"text","text":", Swift automatically creates a buffer"},{"type":"text","text":" "},{"type":"text","text":"of UTF-8 code units and passes a pointer to that buffer. The code units"},{"type":"text","text":" "},{"type":"text","text":"of that buffer match the code units in the string’s "},{"code":"utf8","type":"codeVoice"},{"type":"text","text":" view."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example uses the C "},{"code":"strncmp","type":"codeVoice"},{"type":"text","text":" function to compare the"},{"type":"text","text":" "},{"type":"text","text":"beginning of two Swift strings. The "},{"code":"strncmp","type":"codeVoice"},{"type":"text","text":" function takes two"},{"type":"text","text":" "},{"code":"const char*","type":"codeVoice"},{"type":"text","text":" pointers and an integer specifying the number of characters"},{"type":"text","text":" "},{"type":"text","text":"to compare. Because the strings are identical up to the 14th character,"},{"type":"text","text":" "},{"type":"text","text":"comparing only those characters results in a return value of "},{"code":"0","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"codeListing","code":["let s1 = \"They call me 'Bell'\"","let s2 = \"They call me 'Stacey'\"","","print(strncmp(s1, s2, 14))","\/\/ Prints \"0\"","print(String(s1.utf8.prefix(14))!)","\/\/ Prints \"They call me '\""],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Extending the compared character count to 15 includes the differing"},{"type":"text","text":" "},{"type":"text","text":"characters, so a nonzero result is returned."}],"type":"paragraph"},{"type":"codeListing","code":["print(strncmp(s1, s2, 15))","\/\/ Prints \"-17\"","print(String(s1.utf8.prefix(15))!)","\/\/ Prints \"They call me 'B\""],"syntax":"swift"}]}],"relationshipsSections":[{"identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BidirectionalCollection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Collection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Copyable","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomDebugStringConvertible","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomReflectable","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomStringConvertible","doc:\/\/com.apple.Swift\/documentation\/Swift\/Escapable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","doc:\/\/com.apple.Swift\/documentation\/Swift\/SendableMetatype","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence"],"title":"Conforms To","kind":"relationships","type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/string\/utf8view"]}],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/String"]]},"metadata":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UTF8View","kind":"identifier"}],"modules":[{"name":"Swift"}],"externalID":"s:SS8UTF8ViewV","navigatorTitle":[{"text":"UTF8View","kind":"identifier"}],"extendedModule":"Swift","roleHeading":"Structure","symbolKind":"struct","title":"String.UTF8View","platforms":[{"deprecated":false,"introducedAt":"8.0","unavailable":false,"beta":false,"name":"iOS"},{"deprecated":false,"introducedAt":"8.0","u