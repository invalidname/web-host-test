{"abstract":[{"type":"text","text":"A view of a string’s contents as a collection of UTF-16 code units."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"UTF16View"}]}]},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can access a string’s view of UTF-16 code units by using its "},{"type":"codeVoice","code":"utf16"},{"type":"text","text":" "},{"type":"text","text":"property. A string’s UTF-16 view encodes the string’s Unicode scalar"},{"type":"text","text":" "},{"type":"text","text":"values as 16-bit integers."}]},{"type":"codeListing","code":["let flowers = \"Flowers 💐\"","for v in flowers.utf16 {","    print(v)","}","\/\/ 70","\/\/ 108","\/\/ 111","\/\/ 119","\/\/ 101","\/\/ 114","\/\/ 115","\/\/ 32","\/\/ 55357","\/\/ 56464"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unicode scalar values that make up a string’s contents can be up to 21"},{"type":"text","text":" "},{"type":"text","text":"bits long. The longer scalar values may need two "},{"type":"codeVoice","code":"UInt16"},{"type":"text","text":" values for"},{"type":"text","text":" "},{"type":"text","text":"storage. Those “pairs” of code units are called "},{"type":"emphasis","inlineContent":[{"text":"surrogate pairs","type":"text"}]},{"type":"text","text":"."}]},{"type":"codeListing","code":["let flowermoji = \"💐\"","for v in flowermoji.unicodeScalars {","    print(v, v.value)","}","\/\/ 💐 128144","","for v in flowermoji.utf16 {","    print(v)","}","\/\/ 55357","\/\/ 56464"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To convert a "},{"type":"codeVoice","code":"String.UTF16View"},{"type":"text","text":" instance back into a string, use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"String"},{"type":"text","text":" type’s "},{"type":"codeVoice","code":"init(_:)"},{"type":"text","text":" initializer."}]},{"type":"codeListing","code":["let favemoji = \"My favorite emoji is 🎉\"","if let i = favemoji.utf16.firstIndex(where: { $0 >= 128 }) {","    let asciiPrefix = String(favemoji.utf16[..<i])!","    print(asciiPrefix)","}","\/\/ Prints \"My favorite emoji is \""],"syntax":"swift"},{"type":"heading","level":1,"anchor":"UTF16View-Elements-Match-NSString-Characters","text":"UTF16View Elements Match NSString Characters"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The UTF-16 code units of a string’s "},{"type":"codeVoice","code":"utf16"},{"type":"text","text":" view match the elements"},{"type":"text","text":" "},{"type":"text","text":"accessed through indexed "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":" APIs."}]},{"type":"codeListing","code":["print(flowers.utf16.count)","\/\/ Prints \"10\"","","let nsflowers = flowers as NSString","print(nsflowers.length)","\/\/ Prints \"10\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unlike "},{"type":"codeVoice","code":"NSString"},{"type":"text","text":", however, "},{"type":"codeVoice","code":"String.UTF16View"},{"type":"text","text":" does not use integer"},{"type":"text","text":" "},{"type":"text","text":"indices. If you need to access a specific position in a UTF-16 view, use"},{"type":"text","text":" "},{"type":"text","text":"Swift’s index manipulation methods. The following example accesses the"},{"type":"text","text":" "},{"type":"text","text":"fourth code unit in both the "},{"type":"codeVoice","code":"flowers"},{"type":"text","text":" and "},{"type":"codeVoice","code":"nsflowers"},{"type":"text","text":" strings:"}]},{"type":"codeListing","code":["print(nsflowers.character(at: 3))","\/\/ Prints \"119\"","","let i = flowers.utf16.index(flowers.utf16.startIndex, offsetBy: 3)","print(flowers.utf16[i])","\/\/ Prints \"119\""],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Although the Swift overlay updates many Objective-C methods to return"},{"type":"text","text":" "},{"type":"text","text":"native Swift indices and index ranges, some still return instances of"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRange"},{"type":"text","text":". To convert an "},{"type":"codeVoice","code":"NSRange"},{"type":"text","text":" instance to a range of"},{"type":"text","text":" "},{"type":"codeVoice","code":"String.Index"},{"type":"text","text":", use the "},{"type":"codeVoice","code":"Range(_:in:)"},{"type":"text","text":" initializer, which takes an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSRange"},{"type":"text","text":" and a string as arguments."}]},{"type":"codeListing","code":["let snowy = \"❄️ Let it snow! ☃️\"","let nsrange = NSRange(location: 3, length: 12)","if let range = Range(nsrange, in: snowy) {","    print(snowy[range])","}","\/\/ Prints \"Let it snow!\""],"syntax":"swift"}],"kind":"content"}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/BidirectionalCollection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Collection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Copyable","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomDebugStringConvertible","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomReflectable","doc:\/\/com.apple.Swift\/documentation\/Swift\/CustomStringConvertible","doc:\/\/com.apple.Swift\/documentation\/Swift\/Escapable","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","doc:\/\/com.apple.Swift\/documentation\/Swift\/SendableMetatype","doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/string\/utf16view"]}],"identifier":{"ur