{"abstract":[{"type":"text","text":"Creates an index in the given string that corresponds exactly to the"},{"type":"text","text":" "},{"type":"text","text":"specified position."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"?("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"sourcePosition"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/String"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Index","preciseIdentifier":"s:SS5IndexV","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/String\/Index"},{"kind":"text","text":", "},{"kind":"externalParam","text":"within"},{"kind":"text","text":" "},{"kind":"internalParam","text":"target"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/String"},{"kind":"text","text":")"}],"languages":["swift"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A position in a view of the ","type":"text"},{"code":"target","type":"codeVoice"},{"text":" parameter.","type":"text"},{"text":" ","type":"text"},{"code":"sourcePosition","type":"codeVoice"},{"text":" must be a valid index of at least one of the views","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"code":"target","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"sourcePosition"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The string referenced by the resulting index.","type":"text"}]}],"name":"target"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If the index passed as "},{"type":"codeVoice","code":"sourcePosition"},{"type":"text","text":" represents the start of an"},{"type":"text","text":" "},{"type":"text","text":"extended grapheme cluster—the element type of a string—then the"},{"type":"text","text":" "},{"type":"text","text":"initializer succeeds."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example converts the position of the Unicode scalar "},{"type":"codeVoice","code":"\"e\""},{"type":"text","text":" "},{"type":"text","text":"into its corresponding position in the string. The character at that"},{"type":"text","text":" "},{"type":"text","text":"position is the composed "},{"type":"codeVoice","code":"\"é\""},{"type":"text","text":" character."}],"type":"paragraph"},{"code":["let cafe = \"Cafe\\u{0301}\"","print(cafe)","\/\/ Prints \"Café\"","","let scalarsIndex = cafe.unicodeScalars.firstIndex(of: \"e\")!","let stringIndex = String.Index(scalarsIndex, within: cafe)!","","print(cafe[...stringIndex])","\/\/ Prints \"Café\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If the index passed as "},{"type":"codeVoice","code":"sourcePosition"},{"type":"text","text":" doesn’t have an exact"},{"type":"text","text":" "},{"type":"text","text":"corresponding position in "},{"type":"codeVoice","code":"target"},{"type":"text","text":", the result of the initializer is"},{"type":"text","text":" "},{"type":"codeVoice","code":"nil"},{"type":"text","text":". For example, an attempt to convert the position of the combining"},{"type":"text","text":" "},{"type":"text","text":"acute accent ("},{"type":"codeVoice","code":"\"\\u{0301}\""},{"type":"text","text":") fails. Combining Unicode scalars do not have"},{"type":"text","text":" "},{"type":"text","text":"their own position in a string."}],"type":"paragraph"},{"code":["let nextScalarsIndex = cafe.unicodeScalars.index(after: scalarsIndex)","let nextStringIndex = String.Index(nextScalarsIndex, within: cafe)","","print(nextStringIndex)","\/\/ Prints \"nil\""],"type":"codeListing","syntax":"swift"}]}],"variants":[{"paths":["\/documentation\/swift\/string\/index\/init(_:within:)-2u3iq"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/String","doc:\/\/com.apple.Swift\/documentation\/Swift\/String\/Index"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/String\/Index\/init(_:within:)-2u3iq"},"metadata":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"?(","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:SS5IndexV","text":"Index","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"within","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":")","kind":"text"}],"modules":[{"name":"Swift"}],"externalID":"s:SS5IndexV_6withinABSgAB_SStcfc","extendedModule":"Swift","roleHeading":"Initializer","symbolKind":"init","title":"init(_:within:)","platforms":[{"deprecated":false,"unavailable":false,"name":"iOS","introducedAt":"8.0","beta":false},{"deprecated":false,"unavailable":false,"name":"iPadOS","introducedAt":"8.0","beta":false},{"deprecated":false,"unavailable":false,"name":"Mac Catalyst","introducedAt":"13.0","beta":false},{"deprecated":false,"unavailable":false,"name":"macOS","introducedAt":"10.10","beta":false},{"deprecated":false,"unavailable":false,"name":"tvOS","introducedAt":"9.0","beta":false},{"deprecated":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0","beta":false},{"deprecated":false,"unavailable":false,"name":"watchOS","introducedAt":"2.0","beta":false}]},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"references":{"doc://com.apple.Swift/documentation/Swift/String/Index/init(_:within:)-2u3iq":{"role":"symbol","fragments":