 canceled immediately after being added to the group."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Immediately canceled child tasks should therefore cooperatively check for and"},{"type":"text","text":" "},{"type":"text","text":"react  to cancellation, e.g. by throwing an "},{"type":"codeVoice","code":"CancellationError"},{"type":"text","text":" at their"},{"type":"text","text":" "},{"type":"text","text":"earliest convenience, or otherwise handling the cancellation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are no restrictions on where you can call this method."},{"type":"text","text":" "},{"type":"text","text":"Code inside a child task or even another task can cancel a group,"},{"type":"text","text":" "},{"type":"text","text":"however one should be very careful to not keep a reference to the"},{"type":"text","text":" "},{"type":"text","text":"group longer than the "},{"type":"codeVoice","code":"with...TaskGroup(...) { ... }"},{"type":"text","text":" method body is executing."}]},{"type":"aside","name":"See Also","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"Task.isCancelled","type":"codeVoice"}]}],"style":"note"},{"type":"aside","name":"See Also","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"ThrowingDiscardingTaskGroup.isCancelled","type":"codeVoice"}]}],"style":"note"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swift\/throwingdiscardingtaskgroup\/cancelall()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/ThrowingDiscardingTaskGr