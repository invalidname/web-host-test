text":" ","type":"text"},{"text":"a base asynchronous sequence, while also discarding any ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" results","type":"text"},{"text":" ","type":"text"},{"text":"from the closure. Typically, you use this to transform from one type of","type":"text"},{"text":" ","type":"text"},{"text":"element to another.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" produces ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"5"},{"text":". The closure provided to the ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" ","type":"text"},{"text":"method takes each ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" and looks up a corresponding ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"romanNumeralDict"},{"text":" dictionary. Since there is no key for ","type":"text"},{"type":"codeVoice","code":"4"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"returns ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":" in this case, which ","type":"text"},{"type":"codeVoice","code":"compactMap(_:)"},{"text":" omits from the","type":"text"},{"text":" ","type":"text"},{"text":"transformed asynchronous sequence. When the value is ","type":"text"},{"type":"codeVoice","code":"5"},{"text":", the closure","type":"text"},{"text":" ","type":"text"},{"text":"throws ","type":"text"},{"type":"codeVoice","code":"MyError"},{"text":", terminating the sequence.","type":"text"}]},{"code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .compactMap { (value) throws -> String? in","            if value == 5 {","                throw MyError()","            }","            return romanNumeralDict[value]","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","\/\/ Prints \"I II III Error: MyError() \""],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"symbol","abstract":[{"text":"Creates an asynchronous sequence that maps an error-throwing closure over","type":"text"},{"text":" ","type":"text"},{"text":"the base sequence’s elements, omitting results that don’t return a value.","type":"text"}],"references":{"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]},"doc://com.apple.Swift/documentation/Swift/AsyncPrefixSequence/compactMap(_:)-7mqjp":{"title":"compactMap(_:)","role":"symbol","type":"topic","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/AsyncPrefixSequence\/compactMap(_:)-7mqjp","url":"\/documentation\/swift\/asyncprefixsequence\/compactmap(_:)-7mqjp","abstract":[{"text":"Creates an asynchronous sequence that maps an error-throwing closure over","type":"text"},{"text":" ","type":"text"},{"text":"the base sequence’s elements, omitting results that don’t return a value.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"compactMap","kind":"identifier"},{"text":"<","kind":"text"},{"text":"ElementOfResult","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"@Sendable","kind":"attribute"},{"text":" (","kind":"text"},{"preciseIdentifier":"s:Sci7ElementQa","text":"Element","kind":"typeIdentifier"},{"text":") "