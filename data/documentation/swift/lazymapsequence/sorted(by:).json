 ","type":"text"},{"code":"Element","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"These elements are computed lazily, each time they’re read, by","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"calling the transform function on a base element."}],"title":"LazyMapSequence","type":"topic","navigatorTitle":[{"text":"LazyMapSequence","kind":"identifier"}],"kind":"symbol"},"doc://com.apple.Swift/documentation/Swift":{"role":"collection","url":"\/documentation\/swift","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift","type":"topic","title":"Swift","images":[{"identifier":"Swift-PageImage-card.png","type":"card"}],"kind":"symbol","abstract":[{"type":"text","text":"Build apps using a powerful open language."}]}}}