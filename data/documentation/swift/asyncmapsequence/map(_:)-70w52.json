gMapSequenceV","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp","kind":"typeIdentifier"},{"text":">","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A mapping closure. ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" accepts an element","type":"text"},{"text":" ","type":"text"},{"text":"of this sequence as its parameter and returns a transformed value of the","type":"text"},{"text":" ","type":"text"},{"text":"same or of a different type. ","type":"text"},{"code":"transform","type":"codeVoice"},{"text":" can also throw an error, which","type":"text"},{"text":" ","type":"text"},{"text":"ends the transformed sequence.","type":"text"}]}],"name":"transform"}],"kind":"parameters"},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"inlineContent":[{"text":"An asynchronous sequence that contains, in order, the elements","type":"text"},{"text":" ","type":"text"},{"text":"produced by the ","type":"text"},{"type":"codeVoice","code":"transform"},{"text":" closure.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"text":"Use the ","type":"text"},{"type":"codeVoice","code":"map(_:)"},{"text":" method to transform every element received from a base","type":"text"},{"text":" ","type":"text"},{"text":"asynchronous sequence. Typically, you use this to transform from one type","type":"text"},{"text":" ","type":"text"},{"text":"of element to another.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"In this example, an asynchronous sequence called ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" produces ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" ","type":"text"},{"text":"values from ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"5"},{"text":". The closure provided to the ","type":"text"},{"type":"codeVoice","code":"map(_:)"},{"text":" method","type":"text"},{"text":" ","type":"text"},{"text":"takes each ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" and looks up a corresponding ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" from a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"romanNumeralDict"},{"text":" dictionary. This means the outer ","type":"text"},{"type":"codeVoice","code":"for await in"},{"text":" loop","type":"text"},{"text":" ","type":"text"},{"text":"iterates over ","type":"text"},{"type":"codeVoice","code":"String"},{"text":" instances instead of the underlying ","type":"text"},{"type":"codeVoice","code":"Int"},{"text":" values","type":"text"},{"text":" ","type":"text"},{"text":"that ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" produces. Also, the dictionary doesn’t provide a key for","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"4"},{"text":", and the closure throws an error for any key it can’t look up, so","type":"text"},{"text":" ","type":"text"},{"text":"receiving this value from ","type":"text"},{"type":"codeVoice","code":"Counter"},{"text":" ends the modified sequence with an","type":"text"},{"text":" ","type":"text"},{"text":"error.","type":"text"}],"type":"paragraph"},{"code":["let romanNumeralDict: [Int: String] =","    [1: \"I\", 2: \"II\", 3: \"III\", 5: \"V\"]","","do {","    let stream = Counter(howHigh: 5)","        .map { (value) throws -> String in","            guard let roman = romanNumeralDict[value] else {","                throw MyError()","            }","            return roman","        }","    for try await numeral in stream {","        print(numeral, terminator: \" \")","    }","} catch {","    print(\"Error: \\(error)\")","}","\/\/ Prints \"I II III Error: MyError() \""],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/asyncmapsequence\/map(_:)-70w52"]}],"references":{"doc://com.apple.Swift/documentation/Swift/AsyncMapSequence":{"url":"\/documentation\/swift\/asyncmapsequence","abstract":[{"text":"An asynchronous sequence that maps the given closure over the asynchronous","type":"text"},{"text":" ","type":"text"},{"text":"sequence’s elements.","type":"text"}],"title":"AsyncMapSequence","kind":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/AsyncMapSequence","navigatorTitle":[{"kind":"identifier","text":"AsyncMapSequence"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncMapSequence"}],"type":"topic","role":"symbol"},"doc://com.apple.Swift/documentation/Swift/AsyncMapSequence/map(_:)-70w52":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"map"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Transformed"},{"kind":"text","text":">("},{"kind":"attribute","text":"@Sendable"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"Element","preciseIdentifier":"s:Sci7ElementQa"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Transformed","preciseIdentifier":"s:Sci12_ConcurrencyE3mapyAA24AsyncThrowingMapSequenceVyxqd__Gqd__7ElementQzYaKclF11TransformedL_qd__mfp"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"AsyncThrowingMapSequence","preciseIdentifier":"s:12_Concurrency24AsyncThrowingMapSequenceV"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":", "},{"kind":"