{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"CaseIterable"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Types that conform to the "},{"type":"codeVoice","code":"CaseIterable"},{"type":"text","text":" protocol are typically"},{"type":"text","text":" "},{"type":"text","text":"enumerations without associated values. When using a "},{"type":"codeVoice","code":"CaseIterable"},{"type":"text","text":" type,"},{"type":"text","text":" "},{"type":"text","text":"you can access a collection of all of the type’s cases by using the type’s"},{"type":"text","text":" "},{"type":"codeVoice","code":"allCases"},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, the "},{"type":"codeVoice","code":"CompassDirection"},{"type":"text","text":" enumeration declared in this example"},{"type":"text","text":" "},{"type":"text","text":"conforms to "},{"type":"codeVoice","code":"CaseIterable"},{"type":"text","text":". You access the number of cases and the cases"},{"type":"text","text":" "},{"type":"text","text":"themselves through "},{"type":"codeVoice","code":"CompassDirection.allCases"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["enum CompassDirection: CaseIterable {","    case north, south, east, west","}","","print(\"There are \\(CompassDirection.allCases.count) directions.\")","\/\/ Prints \"There are 4 directions.\"","let caseList = CompassDirection.allCases","                               .map({ \"\\($0)\" })","                               .joined(separator: \", \")","\/\/ caseList == \"north, south, east, west\""]},{"level":1,"type":"heading","text":"Conforming to the CaseIterable Protocol","anchor":"Conforming-to-the-CaseIterable-Protocol"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The compiler can automatically provide an implementation of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"CaseIterable"},{"type":"text","text":" requirements for any enumeration without associated values"},{"type":"text","text":" "},{"type":"text","text":"or "},{"type":"codeVoice","code":"@available"},{"type":"text","text":" attributes on its cases. The synthesized "},{"type":"codeVoice","code":"allCases"},{"type":"text","text":" "},{"type":"text","text":"collection provides the cases in order of their declaration."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can take advantage of this compiler support when defining your own"},{"type":"text","text":" "},{"type":"text","text":"custom enumeration by declaring conformance to "},{"type":"codeVoice","code":"CaseIterable"},{"type":"text","text":" in the"},{"type":"text","text":" "},{"type":"text","text":"enumeration’s original declaration. The "},{"type":"codeVoice","code":"CompassDirection"},{"type":"text","text":" example above"},{"type":"text","text":" "},{"type":"text","text":"demonstrates this automatic implementation."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/CaseIterable"},"metadata":{"title":"CaseIterable","role":"symbol","externalID":"s:s12CaseIterableP","roleHeading":"Protocol","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"8.0"},{"name":"iPadOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"8.0"},{"name":"Mac Catalyst","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"13.0"},{"name":"macOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"10.10"},{"name":"tvOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"9.0"},{"name":"visionOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"1.0