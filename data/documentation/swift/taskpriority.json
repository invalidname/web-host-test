or":"Tasks"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TaskPriority","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The executor determines how priority information affects the way tasks are scheduled.","type":"text"},{"type":"text","text":" "},{"text":"The behavior varies depending on the executor currently being used.","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Typically, executors attempt to run tasks with a higher priority"},{"text":" ","type":"text"},{"text":"before tasks with a lower priority.","type":"text"},{"text":" ","type":"text"},{"text":"However, the semantics of how priority is treated are left up to each","type":"text"},{"text":" ","type":"text"},{"text":"platform and ","type":"text"},{"type":"codeVoice","code":"Executor"},{"text":" implementation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Child tasks automatically inherit their parent task’s priority.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Detached tasks created by "},{"type":"codeVoice","code":"detach(priority:operation:)"},{"text":" don’t inherit task priority","type":"text"},{"text":" ","type":"text"},{"text":"because they aren’t attached to the current task.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In some situations the priority of a task is elevated —","type":"text"},{"text":" ","type":"text"},{"text":"that is, the task is treated as it if had a higher priority,","type":"text"},{"text":" ","type":"text"},{"text":"without actually changing the priority of the task:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"If a task runs on behalf of an actor,","type":"text"},{"text":" ","type":"text"},{"text":"and a new higher-priority task is enqueued to the actor,","type":"text"},{"text":" ","type":"text"},{"text":"then the actor’s current task is temporarily elevated","type":"text"},{"text":" ","type":"text"},{"text":"to the priority of the enqueued task.","type":"text"},{"text":" ","type":"text"},{"text":"This priority elevation allows the new task","type":"text"},{"text":" ","type":"text"},{"text":"to be processed at the priority it was enqueued with.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If a higher-priority task calls the ","type":"text"},{"code":"get()","type":"codeVoice"},{"text":" method,","type":"text"},{"text":" ","type":"text"},{"text":"then the priority of this task increases until the task completes.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"In both cases, priority elevation helps you prevent a low-priority task"},{"type":"text","text":" "},{"type":"text","text":"from blocking the execution of a high priority task,"},{"type":"text","text":" "},{"text":"which is also known as ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"priority inversion","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]}],"metadata":{"modules":[{"relatedModules":[],"name":"Swift"}],"roleHeading":"Structure","role":"symbol","platforms":[{"unavailable":false,"beta":false,"introducedAt":"8.0","deprecated":false,"name":"iOS"},{"unavailable":false,"beta":false,"introducedAt":"8.0","deprecated":false,"name":"iPadOS"},{"unavailable":false,"beta":false,"introducedAt":"13.0","deprecated":false,"name":"Mac Catalyst"},{"unavailable":false,"beta":false,"introducedAt":"10.10","deprecated":false,"name":"macOS"},{"unavailable":false,"beta":false,"introducedAt":"9.0","deprecated":false,"name":"tvOS"},{"unavailable":false,"beta":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS"},{"unavailable":false,"beta":false,"introducedAt":"2.0","deprecated":false,"name":"watchOS"}],"symbol