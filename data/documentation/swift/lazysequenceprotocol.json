quenceProtocol\/elements-6570c","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/lazy-2u2ey","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/lazy-4q4ln"],"generated":true},{"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/compactMap(_:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/drop(while:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/filter(_:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/flatMap(_:)-11y2e","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/flatMap(_:)-9blrr","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/joined()","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/map(_:)","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequenceProtocol\/prefix(while:)"],"generated":true}],"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence"]},{"kind":"relationships","type":"inheritedBy","title":"Inherited By","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/LazyCollectionProtocol"]},{"kind":"relationships","type":"conformingTypes","title":"Conforming Types","identifiers":["doc:\/\/com.apple.Swift\/documentation\/Swift\/LazyDropWhileSequence","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazyFilterSequence","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazyMapSequence","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazyPrefixWhileSequence","doc:\/\/com.apple.Swift\/documentation\/Swift\/LazySequence","doc:\/\/com.apple.Swift\/documentation\/Swift\/ReversedCollection","doc:\/\/com.apple.Swift\/documentation\/Swift\/Slice"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"LazySequenceProtocol"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence","kind":"typeIdentifier","preciseIdentifier":"s:ST","text":"Sequence"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lazy sequences can be used to avoid needless storage allocation"},{"type":"text","text":" "},{"type":"text","text":"and computation, because they use an underlying sequence for"},{"type":"text","text":" "},{"type":"text","text":"storage and compute their elements on demand. For example, "},{"type":"codeVoice","code":"doubled"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"this code sample is a sequence containing the values "},{"type":"codeVoice","code":"2"},{"type":"text","text":", "},{"type":"codeVoice","code":"4"},{"type":"text","text":", and "},{"type":"codeVoice","code":"6"},{"type":"text","text":"."}]},{"code":["let doubled = [1, 2, 3].lazy.map { $0 * 2 }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each time an element of the lazy sequence "},{"type":"codeVoice","code":"doubled"},{"type":"text","text":" is accessed, the"},{"type":"text","text":" "},{"type":"text","text":"closure accesses and transforms an element of the underlying array."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Sequence operations that take closure arguments, such as "},{"type":"codeVoice","code":"map(_:)"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"filter(_:)"},{"type":"text","text":", are normally eager: They use the closure immediately and"},{"type":"text","text":" "},{"type":"text","text":"return a new array. When you use the "},{"type":"codeVoice","code":"lazy"},{"type":"text","text":" property, you give the standard"},{"type":"text","text":" "},{"type":"text","text":"library explicit permission to store the closure and the sequence"},{"type":"text","text":" "},{"type":"text","text":"in the result, and defer computation until it is needed."}]},{"type":"heading","text":"Adding New Lazy Operations","anchor":"Adding-New-Lazy-Operations","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"To add a new lazy sequence operation, extend this protocol with"},{"type":"text","text":" "},{"type":"text","text":"a method that returns a lazy wrapper that itself conforms to"},{"type":"text","text":" "},{"type":"codeVoice","code":"LazySequenceProtocol"},{"type":"text","text":".  For example, an eager "},{"type":"codeVoice","code":"scan(_:_:)"},{"type":"text","text":" "},{"type":"text","text":"method is defined as follows:"}]},{"code":["extension Sequence {","    \/\/\/ Returns an array containing the results of","    \/\/\/","    \/\/\/   p.reduce(initial, nextPartialResult)","    \/\/\/","    \/\/\/ for each prefix `p` of `self`, in order from shortest to","    \/\/\/ longest. For example:","    \/\/\/","    \/\/\/     (1..<6).scan(0, +) \/\/ [0, 1, 3, 6, 10, 15]","    \/\/\/","    \/\/\/ - Complexity: O(n)","    func scan<Result>(","        _ initial: Result,","        _ nextPartialResult: (Result, Element) -> Result","    ) -> [Result] {","        var result = [initial]","        for x in self {","            result.append(nextPartialResult(result.last!, x))","        }","        return result","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can build a sequence type that lazily computes the elements in the"},{"type":"text","text":" "},{"type":"text","text":"result of a scan:"}]},{"code":["struct LazyScanSequence<Base: Sequence, Result>","    : LazySequenceProtocol","{","    let initial: Result","    let base: Base","    let nextPartialResult:","        (Result, Base.Element) -> Result","","    struct Iterator: IteratorProtocol {","        var base: Base.Iterator","        var nextElement: Result?","        let nextPartialResult:","            (Result, Base.Element) -> Result","        ","        mutating func next() -> Result? {","            return nextElement.map { result in","                nextElement = base.next().map {","                    nextPartialResult(result, $0)","                }","                return result","            }","        }","    }","    ","    func makeIterator() -> Iterator {","        return Iterator(","            base: base.makeIterator(),","            nextElement: initial as Result?,","            nextPartialResult: nextPartialResult)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, you can give all lazy sequences a lazy "},{"type":"codeVoice","code":"scan(_:_:)"},{"type":"text","text":" method:"}]},{"code":["extension LazySequenceProtocol {","    func scan<Result>(","        _ initial: Result,","        _ nextPartialResult: @escaping (Result, Element) -> Result","    ) -> LazyScanSequence<Self, Result> {","        return LazyScanSequence(","            initial: initial, base: self, nextPartialResult: nextPartialResult)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"With this type and extension method, you can call "},{"type":"codeVoice","code":".lazy.scan(_:_:)"},{"type":"text","text":" on any"},{"type":"text","text":" "},{"type":"text","text":"sequence to create a lazily computed scan. The resulting "},{"type":"codeVoice","code":"LazyScanSequence"},{"type":"text","text":" "},{"type":"text","text":"is itself lazy, too, so further sequence operations also defer computation."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The explicit permission to implement operations lazily applies"},{"type":"text","text":" "},{"type":"text","text":"only in contexts where the sequence is statically known to conform to"},{"type":"text","text":" "},{"type":"codeVoice","code":"LazySequenceProtocol"},{"type":"text","text":". In the following example, because the extension"},{"type":"text","text":" "},{"type":"text","text":"applies only to "},{"type":"codeVoice","code":"Sequence"},{"type":"text","text":", side-effects such as the accumulation of"},{"type":"text","text":" "},{"type":"codeVoice","code":"result"},{"type":"text","text":" are never unexpectedly dropped or deferred:"}]},{"code":["extension Sequence where Element == Int {","    func sum() -> Int {","        var result = 0","        _ = self.map { result += $0 }","        return result","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Don’t actually use "},{"type":"codeVoice","code":"map"},{"type":"text","text":" for this purpose, however, because it creates"},{"type":"text","text":" "},{"type":"text","text":"and discards the resulting array. Instead, use "},{"type":"codeVoice","code":"reduce"},{"type":"text","text":" for summing"},{"type":"text","text":" "},{"type":"text","text":"operations, or "},{"type":"codeVoice","code":"forEach"},{"type":"text","text":" or a "},{"type":"codeVoice","code":"for"},{"type":"text","text":"-"},{"type":"codeVoice","code":"in"},{"type":"text","text":" loop for operations with side"},{"type":"text","text":" "},{"type":"text","text":"effects."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swift\/lazysequenceprotocol"]}],"references":{"doc://com.apple.Swift/documentation/Swift/Sequence":{"title":"Sequence","url":"\/documentation\/swift\/sequence","type":"topic","abstract":[{"type":"text","text":"A type that provides sequential, iterated access to its elements."}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Sequence","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","tex