{"identifier":{"url":"doc:\/\/com.apple.Swift\/documentation\/Swift\/ExecutorJob\/runSynchronously(on:)-6e565","interfaceLanguage":"swift"},"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/com.apple.Swift\/documentation\/Swift","doc:\/\/com.apple.Swift\/documentation\/Swift\/ExecutorJob"]]},"abstract":[{"type":"text","text":"Run this job on the passed in task executor."}],"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/swift\/executorjob\/runsynchronously(on:)-6e565"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"runSynchronously"},{"kind":"text","text":"("},{"kind":"externalParam","text":"on"},{"kind":"text","text":" "},{"kind":"internalParam","text":"executor"},{"kind":"text","text":": "},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/UnownedTaskExecutor","kind":"typeIdentifier","text":"UnownedTaskExecutor","preciseIdentifier":"s:12_Concurrency19UnownedTaskExecutorV"},{"kind":"text","text":")"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The executor this job will be run on.","type":"text"}]}],"name":"executor"}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This operation runs the job on the calling thread and "},{"type":"emphasis","inlineContent":[{"text":"blocks","type":"text"}]},{"type":"text","text":" until the job completes."},{"type":"text","text":" "},{"type":"text","text":"The intended use of this method is for an executor to determine when and where it"},{"type":"text","text":" "},{"type":"text","text":"wants to run the job and then call this method on it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The passed in exec