{"abstract":[{"text":"Accesses the contiguous subrange of the collection’s elements specified","type":"text"},{"text":" ","type":"text"},{"text":"by a range expression.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"subscript","kind":"keyword"},{"text":"<","kind":"text"},{"text":"R","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"r","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"R","kind":"typeIdentifier","preciseIdentifier":"s:SlsEy11SubSequenceQzqd__cSXRd__5BoundQyd__5IndexRtzluip1RL_qd__mfp"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:Sl11SubSequenceQa","text":"SubSequence","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Collection\/SubSequence"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"R","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:SX","text":"RangeExpression","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/RangeExpression"},{"text":", ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:Sl5IndexQa","text":"Index","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Collection\/Index"},{"text":" == ","kind":"text"},{"text":"R","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:SX5BoundQa","text":"Bound","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/RangeExpression\/Bound"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"The range expression is converted to a concrete subrange relative to this","type":"text"},{"text":" ","type":"text"},{"text":"collection. For example, using a ","type":"text"},{"code":"PartialRangeFrom","type":"codeVoice"},{"text":" range expression","type":"text"},{"text":" ","type":"text"},{"text":"with an array accesses the subrange from the start of the range","type":"text"},{"text":" ","type":"text"},{"text":"expression until the end of the array.","type":"text"}],"type":"paragraph"},{"code":["let streets = [\"Adams\", \"Bryant\", \"Channing\", \"Douglas\", \"Evarts\"]","let streetsSlice = streets[2...]","print(streetsSlice)","\/\/ [\"Channing\", \"Douglas\", \"Evarts\"]"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The accessed slice uses the same indices for the same elements as the","type":"text"},{"text":" ","type":"text"},{"text":"original collection uses. This example searches ","type":"text"},{"code":"streetsSlice","type":"codeVoice"},{"text":" for one","type":"text"},{"text":" ","type":"text"},{"text":"of the strings in the slice, and then uses that index in the original","type":"text"},{"text":" ","type":"text"},{"text":"array.","type":"text"}],"type":"paragraph"},{"code":["let index = streetsSlice.firstIndex(of: \"Evarts\")    \/\/ 4","print(streets[index!])","\/\/ \"Evarts\""],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Always use the slice’s ","type":"text"},{"code":"startIndex","type":"codeVoice"},{"text":" property instead of assuming that its","type":"text"},{"text":" ","type":"text"},{"text":"indices start at a particular value. Attempting to access an element by","type":"text"},{"text":" ","type":"text"},{"text":"using an index outside the bounds of the slice’s indices may result in a","type":"text"},{"text":" ","type":"text"},{"text":"runtime error, even if that index is valid for the original collection.","type":"text"}],"type":"paragraph"},{"code":["print(streetsSlice.startIndex)","\/\/ 2","print(streetsSlice[2])","\/\/ \"Channing\"","","print(streetsSlice[0])","\/\/ error: Index out of bounds"],"type":"codeListing","syntax":"s