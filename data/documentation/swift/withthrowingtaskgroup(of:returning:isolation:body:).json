t","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF05ChildD6ResultL_xmfp"},{"text":", ","kind":"text"},{"text":"Error","kind":"typeIdentifier","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Error","preciseIdentifier":"s:s5ErrorP"},{"text":">) ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throws","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF0E6ResultL_q_mfp"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" ","kind":"text"},{"text":"rethrows","kind":"keyword"},{"text":" -> ","kind":"text"},{"text":"GroupResult","kind":"typeIdentifier","preciseIdentifier":"s:12_Concurrency21withThrowingTaskGroup2of9returning9isolation4bodyq_xm_q_mScA_pSgYiq_Scgyxs5Error_pGzYaKXEtYaKs8SendableRzr0_lF0E6ResultL_q_mfp"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ChildTaskResult","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/Sendable","text":"Sendable","kind":"typeIdentifier","preciseIdentifier":"s:s8SendableP"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"A group "},{"type":"emphasis","inlineContent":[{"text":"always","type":"text"}]},{"type":"text","text":" waits for all of its child tasks"},{"type":"text","text":" "},{"type":"text","text":"to complete before it returns. Even canceled tasks must run until"},{"type":"text","text":" "},{"type":"text","text":"completion before this function returns."},{"type":"text","text":" "},{"type":"text","text":"Canceled child tasks cooperatively react to cancellation and attempt"},{"type":"text","text":" "},{"type":"text","text":"to return as early as possible."},{"text":" ","type":"text"},{"text":"After this function returns, the task group is always empty.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To collect the results of the group’s child tasks,"},{"type":"text","text":" "},{"type":"text","text":"you can use a "},{"code":"for","type":"codeVoice"},{"type":"text","text":"-"},{"code":"await","type":"codeVoice"},{"type":"text","text":"-"},{"code":"in","type":"codeVoice"},{"type":"text","text":" loop:"}],"type":"paragraph"},{"code":["var sum = 0","for try await result in group {","    sum += result","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you need more control or only a few results,"},{"type":"text","text":" "},{"type":"text","text":"you can call "},{"type":"codeVoice","code":"next()"},{"type":"text","text":" directly:"}],"type":"paragraph"},{"syntax":"swift","code":["guard let first = try await group.next() else {","    group.cancelAll()","    return 0","}","let second = await group.next() ?? 0","group.cancelAll()","return first + second"],"type":"codeListing"},{"anchor":"Error-Handling","type":"heading","text":"Error Handling","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"Throwing an error in one of the child tasks of a task group"},{"text":" ","type":"text"},{"text":"doesn’t immediately cancel the other tasks in that group.","type":"text"},{"text":" ","type":"text"},{"text":"However,","type":"text"},{"text":" ","type":"text"},{"text":"throwing out of the ","type":"text"},{"type":"codeVoice","code":"body"},{"type":"text","text":" of the "},{"type":"codeVoice","code":"withThrowingTaskGroup"},{"text":" method does cancel","type":"text"},{"text":" ","type":"text"},{"text":"the group, and all of its child tasks.","type":"text"},{"type":"text","text":" "},{"text":"For example,","type":"text"},{"type":"text","text":" "},{"text":"if you call ","type":"text"},{"code":"next()","type":"codeVoice"},{"type":"text","text":" in the task group and propagate its error,"},{"type":"text","text":" "},{"type":"text","text":"all other tasks are canceled."},{"text":" ","type":"text"},{"type":"text","text":"For example, in the code below,"},{"text":" ","type":"text"},{"text":"nothing is canceled and the group doesn’t throw an error:","type":"text"}]},{"code":["try await withThrowingTaskGroup(of: Void.self) { group in","    group.addTask { throw SomeError() }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"In contrast, this example throws ","type":"text"},{"type":"codeVoice","code":"SomeError"},{"type":"text","text":" "},{"type":"text","text":"and cancels all of the tasks in the group:"}],"type":"paragraph"},{"code":["try await withThrowingTaskGroup(of: Void.self) { group in","    group.addTask { throw SomeError() }","    try await group.next()","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"An individual task throws its error","type":"text"},{"text":" ","type":"text"},{"text":"in the corresponding call to ","type":"text"},{"code":"Group.next()","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"which gives you a chance to handle the individual error","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"or to let the group rethrow the error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Refer to "},{"type":"reference","identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup","isActive":true},{"text":" documentation for detailed discussion of semantics shared between all task groups.","type":"text"}],"type":"paragraph"},{"style":"note","type":"aside","name":"See Also","content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/com.apple.Swift\/documentation\/Swift\/TaskGroup","isActive":true,"type":"reference"